<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!--
      nuget.org is the primary source for all stable packages including:
        - Microsoft.EntityFrameworkCore 10.x
        - Microsoft.AspNetCore.Identity.EntityFrameworkCore 10.x
        - Pomelo.EntityFrameworkCore.MySql 10.x
        - dotnet-ef 10.x
    -->
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />

    <!--
      dotnet-tools feed — needed to restore the dotnet-ef local tool
      (defined in .config/dotnet-tools.json)
    -->
    <add key="dotnet-tools" value="https://pkgs.dev.azure.com/dnceng/public/_packaging/dotnet-tools/nuget/v3/index.json" />

    <!--
      ASP.NET Core / EF Core nightly/preview feed — uncomment if using a
      pre-release SDK build or a preview package version not yet on nuget.org
    -->
    <!-- <add key="dotnet10-preview" value="https://pkgs.dev.azure.com/dnceng/public/_packaging/dotnet10/nuget/v3/index.json" /> -->
  </packageSources>

  <packageSourceMapping>
    <!-- All packages default to nuget.org -->
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="dotnet-tools">
      <package pattern="dotnet-ef" />
    </packageSource>
  </packageSourceMapping>

  <activePackageSource>
    <add key="All" value="(Aggregate source)" />
  </activePackageSource>
</configuration>
