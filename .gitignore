## .NET / ASP.NET Core gitignore

# Generated migration SQL script (produced by make migrations-script)
migrations.sql

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Oo]ut/
[Ll]og/
[Ll]ogs/
# Exception: Razor views folder named Logs is source code, not a log directory
!**/Views/Logs/
!**/Views/Logs/**

# Visual Studio
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates
*.userprefs

# Rider / JetBrains
.idea/
*.DotSettings.user

# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# NuGet
*.nupkg
*.snupkg
**/[Pp]ackages/
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets
nuget.config
project.lock.json
project.fragment.lock.json
artifacts/

# dotnet tools
.config/dotnet-tools.json~

# Entity Framework Core migrations – keep your migration files, ignore snapshots in CI
# (Uncomment the next line if you want to ignore snapshots)
# **/Migrations/*.Designer.cs

# Secrets / local config
appsettings.Development.json
appsettings.Local.json
secrets.json
.env
.env.*

# Publish output
**/publish/
**/PublishProfiles/
*.pubxml
*.pubxml.user

# Node / npm (for any front-end tooling)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Misc
*.DS_Store
Thumbs.db
*.swp
*.bak
*.tmp
*.orig
coverage/
TestResults/
*.trx
