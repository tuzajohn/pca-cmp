@model List<PCA.Modules.Invoicing.Models.InvoiceSchedule>
@using PCA.Modules.Invoicing.Services
@{ ViewData["Title"] = "Invoice Schedules"; }

<div class="page-header">
    <div>
        <h1 class="page-header-title">Invoice Schedules</h1>
        <p class="page-header-sub mb-0">Automated invoice generation schedules</p>
    </div>
    <a asp-action="Create" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i> New Schedule</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-calendar-event" style="font-size:40px;opacity:.3;"></i>
                <p class="mt-3">No schedules configured yet.</p>
            </div>
        }
        else
        {
            <table id="dt-schedules" class="table table-hover mb-0" style="font-size:13px;">
                <thead style="background:var(--bs-tertiary-bg);">
                    <tr>
                        <th class="ps-3">Name</th>
                        <th>Lender</th>
                        <th>Schedule</th>
                        <th>Next Run</th>
                        <th>Last Run</th>
                        <th>Status</th>
                        <th class="pe-3"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model)
                    {
                        <tr>
                            <td class="ps-3 align-middle fw-semibold">
                                <a asp-action="Details" asp-route-id="@s.Id" class="text-decoration-none" style="color:inherit;">@s.Name</a>
                            </td>
                            <td class="align-middle">
                                @s.Lender?.Name
                                <div class="text-muted" style="font-size:11px;">@s.Lender?.CompanyType</div>
                            </td>
                            <td class="align-middle text-muted">@ScheduleCronHelper.Describe(s)</td>
                            <td class="align-middle text-muted" style="white-space:nowrap;">
                                @(s.NextRunAt.HasValue ? s.NextRunAt.Value.ToString("dd MMM yyyy HH:mm") : "—")
                            </td>
                            <td class="align-middle text-muted" style="white-space:nowrap;">
                                @(s.LastRunAt.HasValue ? s.LastRunAt.Value.ToString("dd MMM yyyy HH:mm") : "—")
                            </td>
                            <td class="align-middle">
                                @if (s.IsEnabled)
                                {
                                    <span class="status-badge status-approved" style="font-size:10px;">Enabled</span>
                                }
                                else
                                {
                                    <span class="status-badge status-draft" style="font-size:10px;">Disabled</span>
                                }
                            </td>
                            <td class="pe-3 align-middle text-end">
                                <a asp-action="Details" asp-route-id="@s.Id" class="btn btn-outline-primary btn-sm" style="padding:2px 8px;font-size:11px;">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@section Scripts {
<script>new DataTable('#dt-schedules', { pageLength: 25, order: [[0, 'asc']], columnDefs: [{ orderable: false, targets: -1 }] });</script>
}
