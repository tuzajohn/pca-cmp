@{
    ViewData["Title"] = "Invoice Schedules";
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Invoice Schedules</h1>
        <p class="page-header-sub mb-0">Automated invoice generation schedules</p>
    </div>
    <a asp-action="Create" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i> New Schedule</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div id="tbl-schedules"></div>
</div>

@section Scripts {
<script>
PagedTable.init({
    tableId: 'tbl-schedules',
        tableClass: 'table table-hover mb-0',
    url: '/InvoiceSchedules/IndexData',
    pageSize: 25,
    defaultSort: { col: 'name', dir: 'asc' },
    columns: [
        { key: 'name',      label: 'Name',      thClass: 'ps-3', tdClass: 'ps-3 align-middle fw-semibold', render: r => `<a href="/InvoiceSchedules/Details/${r.id}" class="text-decoration-none" style="color:inherit;">${r.name}</a>` },
        { key: 'lender',    label: 'Lender',    tdClass: 'align-middle', render: r => `${r.lender}<div class="text-muted" style="font-size:11px;">${r.companyType}</div>` },
        { key: 'frequency', label: 'Schedule',  sortable: false, tdClass: 'align-middle text-muted' },
        { key: 'nextRunAt', label: 'Next Run',  tdClass: 'align-middle text-muted', render: r => r.nextRunAt || '—' },
        { key: 'lastRunAt', label: 'Last Run',  tdClass: 'align-middle text-muted', render: r => r.lastRunAt || '—' },
        { key: 'isEnabled', label: 'Status',    tdClass: 'align-middle', render: r => r.isEnabled
            ? '<span class="status-badge status-approved" style="font-size:10px;">Enabled</span>'
            : '<span class="status-badge status-draft" style="font-size:10px;">Disabled</span>' },
        { key: null, label: '', sortable: false, thClass: 'pe-3', tdClass: 'pe-3 align-middle text-end',
          render: r => `<a href="/InvoiceSchedules/Details/${r.id}" class="btn btn-outline-primary btn-sm" style="padding:2px 8px;font-size:11px;"><i class="bi bi-eye"></i></a>` }
    ]
});
</script>
}
