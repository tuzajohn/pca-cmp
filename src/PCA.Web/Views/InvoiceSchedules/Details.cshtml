@model PCA.Modules.Invoicing.Models.InvoiceSchedule
@using PCA.Modules.Invoicing.Models
@{
    ViewData["Title"] = Model.Name;
    var refFiles = ViewBag.HcmRefFiles as List<InvoiceHcmRefFile> ?? new List<InvoiceHcmRefFile>();
    var currentMonth = DateTime.UtcNow.ToString("yyyy-MM");
    var hasRefForThisMonth = refFiles.Any(f => f.MonthYear == currentMonth);
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">@Model.Name</h1>
        <p class="page-header-sub mb-0">
            @if (Model.IsEnabled)
            {
                <span class="status-badge status-approved me-2" style="font-size:10px;">Enabled</span>
            }
            else
            {
                <span class="status-badge status-draft me-2" style="font-size:10px;">Disabled</span>
            }
            @ViewBag.Description
        </p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-pencil me-1"></i> Edit
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i> Back
        </a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-3">
    <div class="col-lg-8">

        <div class="form-section">
            <div class="form-section-header"><i class="bi bi-clock-history"></i> Run History</div>
            <div class="form-section-body p-0">
                @if (!Model.Runs.Any())
                {
                    <div class="text-center py-4 text-muted" style="font-size:13px;">No runs yet.</div>
                }
                else
                {
                    <table class="table table-sm mb-0" style="font-size:13px;">
                        <thead style="background:var(--bs-tertiary-bg);">
                            <tr>
                                <th class="ps-3">Triggered At</th>
                                <th>Triggered By</th>
                                <th>IPPS Rows</th>
                                <th>HCM Rows</th>
                                <th>Final Rows</th>
                                <th>Status</th>
                                <th class="pe-3"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var run in Model.Runs.OrderByDescending(r => r.TriggeredAt))
                            {
                                var statusCls = run.Status switch {
                                    InvoiceRunStatus.Completed => "status-approved",
                                    InvoiceRunStatus.Failed    => "status-rejected",
                                    InvoiceRunStatus.Running   => "status-underreview",
                                    _                          => "status-draft"
                                };
                                <tr>
                                    <td class="ps-3 align-middle" style="white-space:nowrap;">@run.TriggeredAt.ToString("dd MMM yyyy HH:mm")</td>
                                    <td class="align-middle text-muted">@(run.TriggeredBy?.FullName ?? "Scheduler")</td>
                                    <td class="align-middle text-muted">@run.IppsRowCount</td>
                                    <td class="align-middle text-muted">@run.HcmRowCount</td>
                                    <td class="align-middle fw-semibold">@run.FinalRowCount</td>
                                    <td class="align-middle">
                                        <span class="status-badge @statusCls" style="font-size:10px;">@run.Status</span>
                                    </td>
                                    <td class="pe-3 align-middle">
                                        <a asp-controller="InvoiceRuns" asp-action="Details" asp-route-id="@run.Id"
                                           class="btn btn-outline-secondary btn-sm" style="padding:2px 8px;font-size:11px;">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        @if (run.Status == InvoiceRunStatus.Completed && !string.IsNullOrEmpty(run.FilePath))
                                        {
                                            <a asp-controller="InvoiceRuns" asp-action="Download" asp-route-id="@run.Id"
                                               class="btn btn-outline-success btn-sm ms-1" style="padding:2px 8px;font-size:11px;">
                                                <i class="bi bi-download"></i>
                                            </a>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>

        @if (Model.SplitSheets)
        {
        <div class="form-section mt-3">
            <div class="form-section-header">
                <i class="bi bi-file-earmark-spreadsheet"></i> HCM Ref Files
                @if (!hasRefForThisMonth)
                {
                    <span class="badge bg-warning text-dark ms-2" style="font-size:10px;">Missing for @currentMonth</span>
                }
            </div>
            <div class="form-section-body">
                <p class="text-muted small mb-3">
                    Upload the monthly HCM ref file (Excel with IPPS numbers in column A) for each month you plan to run an invoice with split sheets.
                </p>
                <form asp-action="UploadHcmRef" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data" class="row g-2 align-items-end mb-3">
                    @Html.AntiForgeryToken()
                    <div class="col-md-4">
                        <label class="form-label fw-semibold" style="font-size:12px;">Month (YYYY-MM)</label>
                        <input type="month" name="monthYear" class="form-control form-control-sm"
                               value="@currentMonth" required />
                    </div>
                    <div class="col-md-5">
                        <label class="form-label fw-semibold" style="font-size:12px;">Excel File (.xlsx)</label>
                        <input type="file" name="refFile" accept=".xlsx" class="form-control form-control-sm" required />
                    </div>
                    <div class="col-md-3">
                        <button type="submit" class="btn btn-primary btn-sm w-100">
                            <i class="bi bi-upload me-1"></i> Upload
                        </button>
                    </div>
                </form>

                @if (!refFiles.Any())
                {
                    <div class="text-muted small">No ref files uploaded yet.</div>
                }
                else
                {
                    <table class="table table-sm mb-0" style="font-size:12px;">
                        <thead style="background:var(--bs-tertiary-bg);">
                            <tr>
                                <th class="ps-3">Month</th>
                                <th>File</th>
                                <th>Uploaded</th>
                                <th>By</th>
                                <th class="pe-3"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var rf in refFiles)
                            {
                                <tr>
                                    <td class="ps-3 align-middle fw-semibold">@rf.MonthYear</td>
                                    <td class="align-middle text-muted">@rf.OriginalFileName</td>
                                    <td class="align-middle text-muted" style="white-space:nowrap;">@rf.UploadedAt.ToString("dd MMM yyyy HH:mm")</td>
                                    <td class="align-middle text-muted">@(rf.UploadedBy?.FullName ?? "—")</td>
                                    <td class="pe-3 align-middle text-end">
                                        <form asp-action="DeleteHcmRef" asp-route-id="@Model.Id" method="post" class="d-inline"
                                              onsubmit="return confirm('Delete this ref file?')">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="refFileId" value="@rf.Id" />
                                            <button type="submit" class="btn btn-outline-danger btn-sm" style="padding:2px 8px;font-size:11px;">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
        }

    </div>
    <div class="col-lg-4">
        <div class="card position-sticky" style="top:80px;">
            <div class="card-header"><i class="bi bi-info-circle me-2"></i>Schedule Info</div>
            <div class="card-body" style="font-size:13px;">
                <div class="mb-2">
                    <div class="text-muted" style="font-size:11px;text-transform:uppercase;letter-spacing:.05em;">Lender</div>
                    <div>@Model.Lender?.Name <span class="badge bg-secondary ms-1" style="font-size:9px;">@Model.Lender?.CompanyType</span></div>
                </div>
                <div class="mb-2">
                    <div class="text-muted" style="font-size:11px;text-transform:uppercase;letter-spacing:.05em;">Deduction Code</div>
                    <div>@Model.Lender?.DeductionCode</div>
                </div>
                <div class="mb-2">
                    <div class="text-muted" style="font-size:11px;text-transform:uppercase;letter-spacing:.05em;">Frequency</div>
                    <div>@ViewBag.Description</div>
                </div>
                <div class="mb-2">
                    <div class="text-muted" style="font-size:11px;text-transform:uppercase;letter-spacing:.05em;">Next Run</div>
                    <div>@(Model.NextRunAt.HasValue ? Model.NextRunAt.Value.ToString("dd MMM yyyy HH:mm") + " UTC" : "—")</div>
                </div>
                <div class="mb-2">
                    <div class="text-muted" style="font-size:11px;text-transform:uppercase;letter-spacing:.05em;">Split Sheets</div>
                    <div>
                        @if (Model.SplitSheets)
                        {
                            <span class="badge bg-primary" style="font-size:10px;">Enabled</span>
                            if (!hasRefForThisMonth)
                            {
                                <span class="badge bg-warning text-dark ms-1" style="font-size:10px;">Ref missing for @currentMonth</span>
                            }
                        }
                        else
                        {
                            <span class="text-muted" style="font-size:12px;">Disabled</span>
                        }
                    </div>
                </div>
                <div class="mb-2">
                    <div class="text-muted" style="font-size:11px;text-transform:uppercase;letter-spacing:.05em;">Recipients</div>
                    <div>
                        @foreach (var sr in Model.ScheduleRecipients)
                        {
                            <div>@sr.Recipient?.Name <span class="text-muted" style="font-size:11px;">@sr.Recipient?.Email</span></div>
                        }
                        @if (!Model.ScheduleRecipients.Any()) { <span class="text-muted">None configured</span> }
                    </div>
                </div>
            </div>
            <div class="card-footer d-flex flex-column gap-2">
                <form asp-action="RunNow" asp-route-id="@Model.Id" method="post"
                      onsubmit="return confirm('Trigger an invoice run now?')">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-success btn-sm w-100">
                        <i class="bi bi-play-circle me-1"></i> Run Now
                    </button>
                </form>
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post"
                      onsubmit="return confirm('Delete this schedule and all its run history?')">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-danger btn-sm w-100">
                        <i class="bi bi-trash me-1"></i> Delete Schedule
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
