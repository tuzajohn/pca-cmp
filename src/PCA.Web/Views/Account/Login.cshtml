@model LoginViewModel
@{
    ViewData["Title"] = "Sign In";
    Layout = "_AuthLayout";
}

<div class="auth-split">

    <!-- Left: Form -->
    <div class="auth-left">
        <div class="auth-logo-mark">
            <div class="dot"></div>
            <span>PCA Change Management</span>
        </div>

        <div>
            <h1 class="auth-heading">Holla,<br/>Welcome Back</h1>
            <p class="auth-sub">Sign in to your change management portal</p>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="auth-errors">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div>@error.ErrorMessage</div>
                    }
                </div>
            }

            <form asp-action="Login" method="post">
                <input type="hidden" asp-for="ReturnUrl" />
                <input asp-for="Email" class="auth-field" placeholder="Email address" autocomplete="email" />
                <input asp-for="Password" type="password" class="auth-field" placeholder="Password" autocomplete="current-password" />

                <div class="auth-row">
                    <label class="auth-check">
                        <input asp-for="RememberMe" type="checkbox" />
                        Remember me
                    </label>
                </div>

                <button type="submit" class="auth-btn">Sign In</button>
            </form>

            <p class="auth-footer text-muted" style="font-size:12px;text-align:center;">
                Access is by invitation only. Contact your system administrator to request an account.
            </p>
        </div>
    </div>

    <!-- Right: Illustration -->
    <div class="auth-right">
        <div class="auth-badge top-badge">
            <div class="badge-dot"></div>
            Secure Access
        </div>
        <div class="auth-badge bottom-badge">
            <i class="bi bi-shield-check" style="color:var(--color-primary);font-size:16px;"></i>
            Role-Based Controls
        </div>

        <div class="auth-illustration">
            <div class="icon-stack" style="flex-direction:column;gap:16px;margin-bottom:40px;">
                <div class="d-flex gap-4 justify-content-center">
                    <div class="icon-card">
                        <i class="bi bi-ticket-detailed"></i>
                    </div>
                    <div class="icon-card main">
                        <i class="bi bi-clipboard2-check"></i>
                    </div>
                    <div class="icon-card">
                        <i class="bi bi-check2-circle"></i>
                    </div>
                </div>
                <div class="d-flex gap-4 justify-content-center">
                    <div class="icon-card">
                        <i class="bi bi-diagram-3"></i>
                    </div>
                    <div class="icon-card">
                        <i class="bi bi-bar-chart-line"></i>
                    </div>
                </div>
            </div>

            <h2 class="auth-right-title">Change Management<br/>Made Simple</h2>
            <p class="auth-right-sub">
                Manage change requests, approval workflows, and
                implementation tracking — all in one unified platform.
            </p>
        </div>
    </div>

</div>
