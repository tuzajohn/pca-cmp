@{
    ViewData["Title"] = "Server Room Access";
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Server Room Access</h1>
        <p class="page-header-sub mb-0">Manage physical server room access requests</p>
    </div>
    <a asp-action="Create" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg me-1"></i> New Request
    </a>
</div>

<div class="card">
    <div id="tbl-sr"></div>
</div>

@section Scripts {
<script>
(function () {
    const badge = d => `<span class="status-badge status-${d.toLowerCase()}">${d}</span>`;

    PagedTable.init({
        tableId: 'tbl-sr',
        url: '/ServerRoomAccess/Data',
        pageSize: 20,
        defaultSort: { col: 'plannedEntry', dir: 'desc' },
        filterBar: [
            { key: 'status', label: 'Status', type: 'select', options: ['Pending','Approved','Rejected','CheckedIn','CheckedOut','Cancelled'] },
            { key: 'search', label: 'Search', type: 'text',   placeholder: 'Visitor or purpose…' }
        ],
        columns: [
            { key: 'serial',         label: 'Serial',        thClass: 'ps-3', tdClass: 'ps-3 align-middle', render: r => `<a href="/ServerRoomAccess/Details/${r.id}" class="fw-semibold text-decoration-none">${r.serial}</a>` },
            { key: 'visitorName',    label: 'Visitor',       tdClass: 'align-middle' },
            { key: 'visitorCompany', label: 'Company',       tdClass: 'align-middle text-muted', render: r => r.visitorCompany || '—' },
            { key: 'isExternal',     label: 'External',      sortable: false, tdClass: 'align-middle', render: r => r.isExternal ? '<span class="status-badge status-submitted">External</span>' : '' },
            { key: 'purpose',        label: 'Purpose',       tdClass: 'align-middle text-muted' },
            { key: 'plannedEntry',   label: 'Planned Entry', tdClass: 'align-middle text-muted' },
            { key: 'plannedExit',    label: 'Planned Exit',  tdClass: 'align-middle text-muted', render: r => r.plannedExit || '—' },
            { key: 'status',         label: 'Status',        tdClass: 'align-middle', render: r => badge(r.status) },
            { key: null, label: '', sortable: false, thClass: 'pe-3', tdClass: 'pe-3 align-middle text-end',
              render: r => `<a href="/ServerRoomAccess/Details/${r.id}" class="btn btn-sm btn-outline-secondary" style="padding:2px 8px;"><i class="bi bi-eye"></i></a>` }
        ]
    });
})();
</script>
}
