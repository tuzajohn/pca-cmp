@model PCA.Web.Models.ServerRoomCreateViewModel
@{
    ViewData["Title"] = "New Server Room Access Request";
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Server Room Access Request</h1>
        <p class="page-header-sub mb-0">Requires Senior Systems Administrator and General Manager approval</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i> Back
    </a>
</div>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <div class="row g-3">
        <div class="col-lg-8">

            <div class="form-section">
                <div class="form-section-header"><i class="bi bi-person"></i> Visitor Details</div>
                <div class="form-section-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="VisitorName" class="form-label fw-semibold"></label>
                            <input asp-for="VisitorName" class="form-control" />
                            <span asp-validation-for="VisitorName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="VisitorTitle" class="form-label fw-semibold"></label>
                            <input asp-for="VisitorTitle" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="VisitorCompany" class="form-label fw-semibold"></label>
                            <input asp-for="VisitorCompany" class="form-control" placeholder="Company or department" />
                        </div>
                        <div class="col-md-6 d-flex align-items-end">
                            <div class="form-check mb-2">
                                <input asp-for="IsExternal" class="form-check-input" />
                                <label asp-for="IsExternal" class="form-check-label fw-semibold"></label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="form-section">
                <div class="form-section-header"><i class="bi bi-server"></i> Visit Details</div>
                <div class="form-section-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="Purpose" class="form-label fw-semibold"></label>
                            <textarea asp-for="Purpose" class="form-control" rows="3" placeholder="Describe the purpose of the visit…"></textarea>
                            <span asp-validation-for="Purpose" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PlannedEntryDateTime" class="form-label fw-semibold"></label>
                            <input asp-for="PlannedEntryDateTime" type="datetime-local" class="form-control" />
                            <span asp-validation-for="PlannedEntryDateTime" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PlannedExitDateTime" class="form-label fw-semibold"></label>
                            <input asp-for="PlannedExitDateTime" type="datetime-local" class="form-control" />
                            <span asp-validation-for="PlannedExitDateTime" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EscortedBy" class="form-label fw-semibold"></label>
                            <input asp-for="EscortedBy" class="form-control" placeholder="Internal staff member escorting" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="WrittenRequestReference" class="form-label fw-semibold"></label>
                            <input asp-for="WrittenRequestReference" class="form-control" placeholder="e.g. email ref, ticket number" />
                        </div>
                    </div>
                </div>
            </div>

        </div>
        <div class="col-lg-4">
            <div class="card position-sticky" style="top:80px;">
                <div class="card-header"><i class="bi bi-info-circle me-2"></i>Approval Required</div>
                <div class="card-body" style="font-size:13px;">
                    <p class="text-muted">Server room access requires written approval from:</p>
                    <ol class="text-muted ps-3">
                        <li>Senior Systems Administrator</li>
                        <li>General Manager</li>
                    </ol>
                </div>
                <div class="card-footer d-flex gap-2">
                    <button type="submit" class="btn btn-primary btn-sm flex-fill">
                        <i class="bi bi-save me-1"></i> Save as Draft
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Cancel</a>
                </div>
            </div>
        </div>
    </div>
</form>
