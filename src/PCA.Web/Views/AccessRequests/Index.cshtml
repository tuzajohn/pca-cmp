@model List<PCA.Modules.AccessManagement.Models.AccessRequest>
@using PCA.Shared.Enums
@{
    ViewData["Title"] = "Access Requests";
    var statusFilter = ViewBag.StatusFilter as string;
    var systemFilter = ViewBag.SystemFilter as string;
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Access Requests</h1>
        <p class="page-header-sub mb-0">Manage system access provisioning requests</p>
    </div>
    <a asp-action="Create" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg me-1"></i> New Access Request
    </a>
</div>

<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" class="d-flex flex-wrap gap-2 align-items-center">
            <select name="status" class="form-select form-select-sm" style="width:auto;">
                <option value="">All Statuses</option>
                @foreach (var s in Enum.GetValues<AccessRequestStatus>())
                {
                    if (s.ToString() == statusFilter)
                    {
                        <option value="@s" selected>@s</option>
                    }
                    else
                    {
                        <option value="@s">@s</option>
                    }
                }
            </select>
            <input type="text" name="system" class="form-control form-control-sm" style="width:180px;"
                   placeholder="System name…" value="@systemFilter" />
            <input type="date" name="from" class="form-control form-control-sm" style="width:auto;" value="@ViewBag.FromFilter" />
            <input type="date" name="to" class="form-control form-control-sm" style="width:auto;" value="@ViewBag.ToFilter" />
            <button class="btn btn-outline-secondary btn-sm" type="submit">Filter</button>
            @if (!string.IsNullOrEmpty(statusFilter) || !string.IsNullOrEmpty(systemFilter))
            {
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Clear</a>
            }
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-person-lock" style="font-size:40px;opacity:.3;"></i>
                <p class="mt-3">No access requests found.</p>
            </div>
        }
        else
        {
            <table class="table table-hover mb-0" style="font-size:13px;">
                <thead style="background:var(--bs-tertiary-bg);">
                    <tr>
                        <th class="ps-3">Serial</th>
                        <th>Employee</th>
                        <th>System</th>
                        <th>Type</th>
                        <th>Privileged</th>
                        <th>Status</th>
                        <th>Requested</th>
                        <th class="pe-3"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var req in Model)
                    {
                        var statusCls = req.Status switch
                        {
                            AccessRequestStatus.Approved => "status-approved",
                            AccessRequestStatus.Rejected => "status-rejected",
                            AccessRequestStatus.Provisioned => "status-implemented",
                            AccessRequestStatus.UnderReview => "status-underreview",
                            AccessRequestStatus.Submitted => "status-submitted",
                            AccessRequestStatus.Cancelled => "status-draft",
                            _ => "status-draft"
                        };
                        <tr>
                            <td class="ps-3 align-middle text-muted" style="white-space:nowrap;">
                                @(string.IsNullOrEmpty(req.SerialNumber) ? "Draft" : req.SerialNumber)
                            </td>
                            <td class="align-middle fw-semibold">
                                <a asp-action="Details" asp-route-id="@req.Id" class="text-decoration-none" style="color:inherit;">
                                    @req.EmployeeName
                                </a>
                                <div class="text-muted fw-normal" style="font-size:11px;">@req.Department</div>
                            </td>
                            <td class="align-middle">@req.SystemName</td>
                            <td class="align-middle text-muted">@req.AccessType</td>
                            <td class="align-middle">
                                @if (req.IsPrivileged)
                                {
                                    <span class="badge bg-warning text-dark" style="font-size:10px;">Privileged</span>
                                }
                                else
                                {
                                    <span class="text-muted" style="font-size:11px;">Standard</span>
                                }
                            </td>
                            <td class="align-middle">
                                <span class="status-badge @statusCls" style="font-size:10px;">@req.Status</span>
                            </td>
                            <td class="align-middle text-muted" style="white-space:nowrap;">@req.CreatedAt.ToString("dd MMM yyyy")</td>
                            <td class="pe-3 align-middle">
                                <a asp-action="Details" asp-route-id="@req.Id" class="btn btn-outline-primary btn-sm" style="padding:2px 8px;font-size:11px;">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
