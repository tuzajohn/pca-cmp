@using PCA.Shared.Enums
@{
    ViewData["Title"] = "Access Requests";
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Access Requests</h1>
        <p class="page-header-sub mb-0">Manage system access provisioning requests</p>
    </div>
    <a asp-action="Create" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg me-1"></i> New Access Request
    </a>
</div>

<div class="card mb-3">
    <div class="card-body py-2">
        <div class="d-flex flex-wrap gap-2 align-items-center">
            <select id="f-status" class="form-select form-select-sm" style="width:auto;">
                <option value="">All Statuses</option>
                @foreach (var s in Enum.GetValues<AccessRequestStatus>())
                {
                    <option value="@s">@s</option>
                }
            </select>
            <input type="text" id="f-system" class="form-control form-control-sm" style="width:180px;" placeholder="System name…" />
            <button class="btn btn-primary btn-sm" id="btn-filter">Filter</button>
            <button class="btn btn-outline-secondary btn-sm" id="btn-clear">Clear</button>
        </div>
    </div>
</div>

<div class="card">
    <div id="tbl-ar"></div>
</div>

@section Scripts {
<script>
(function () {
    const badge = d => `<span class="status-badge status-${d.toLowerCase()}">${d}</span>`;

    const tbl = PagedTable.init({
        tableId: 'tbl-ar',
        url: '/AccessRequests/Data',
        pageSize: 20,
        defaultSort: { col: 'createdAt', dir: 'desc' },
        filters: () => ({
            status: document.getElementById('f-status').value,
            system: document.getElementById('f-system').value
        }),
        columns: [
            { key: 'serial',     label: 'Serial',     thClass: 'ps-3', tdClass: 'ps-3 align-middle', render: r => `<a href="/AccessRequests/Details/${r.id}" class="fw-semibold text-decoration-none">${r.serial}</a>` },
            { key: 'employee',   label: 'Employee',   tdClass: 'align-middle' },
            { key: 'system',     label: 'System',     tdClass: 'align-middle' },
            { key: 'type',       label: 'Type',       tdClass: 'align-middle text-muted' },
            { key: 'privileged', label: 'Privileged', tdClass: 'align-middle', render: r => r.privileged ? '<span class="status-badge status-closed">Privileged</span>' : '' },
            { key: 'status',     label: 'Status',     tdClass: 'align-middle', render: r => badge(r.status) },
            { key: 'createdAt',  label: 'Requested',  tdClass: 'align-middle text-muted' },
            { key: null, label: '', sortable: false, thClass: 'pe-3', tdClass: 'pe-3 align-middle text-end',
              render: r => `<a href="/AccessRequests/Details/${r.id}" class="btn btn-sm btn-outline-secondary" style="padding:2px 8px;"><i class="bi bi-eye"></i></a>` }
        ]
    });

    document.getElementById('btn-filter').addEventListener('click', () => tbl.reload());
    document.getElementById('btn-clear').addEventListener('click', () => {
        document.getElementById('f-status').value = '';
        document.getElementById('f-system').value = '';
        tbl.reload();
    });
})();
</script>
}
