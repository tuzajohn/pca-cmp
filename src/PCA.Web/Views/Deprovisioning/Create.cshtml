@model PCA.Web.Models.DeprovisioningCreateViewModel
@using PCA.Shared.Enums
@{
    ViewData["Title"] = "Log Deprovisioning Event";
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Log Deprovisioning Event</h1>
        <p class="page-header-sub mb-0">Record HR notification — 24h SLA starts from notification time</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i> Back
    </a>
</div>

<form asp-action="Create" method="post" id="deprovForm">
    @Html.AntiForgeryToken()
    <div class="row g-3">
        <div class="col-lg-8">

            <div class="form-section">
                <div class="form-section-header"><i class="bi bi-person-dash"></i> Employee Details</div>
                <div class="form-section-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="EmployeeName" class="form-label fw-semibold"></label>
                            <input asp-for="EmployeeName" class="form-control" />
                            <span asp-validation-for="EmployeeName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EmployeeId" class="form-label fw-semibold"></label>
                            <input asp-for="EmployeeId" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Department" class="form-label fw-semibold"></label>
                            <input asp-for="Department" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="JobTitle" class="form-label fw-semibold"></label>
                            <input asp-for="JobTitle" class="form-control" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="form-section">
                <div class="form-section-header"><i class="bi bi-clock-history"></i> Event Details</div>
                <div class="form-section-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Trigger" class="form-label fw-semibold"></label>
                            <select asp-for="Trigger" class="form-select" asp-items="Html.GetEnumSelectList<DeprovisioningTrigger>()"></select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="HrNotificationReceivedAt" class="form-label fw-semibold"></label>
                            <input asp-for="HrNotificationReceivedAt" type="datetime-local" class="form-control" />
                            <div class="form-text text-warning"><i class="bi bi-exclamation-triangle me-1"></i>SLA deadline is 24 hours from this time.</div>
                        </div>
                        <div class="col-12">
                            <label asp-for="TriggerDetails" class="form-label fw-semibold"></label>
                            <textarea asp-for="TriggerDetails" class="form-control" rows="2" placeholder="Additional context…"></textarea>
                        </div>
                        <div class="col-12">
                            <label asp-for="Notes" class="form-label fw-semibold"></label>
                            <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                        </div>
                    </div>
                </div>
            </div>

            <div class="form-section">
                <div class="form-section-header d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-hdd-network me-2"></i>Systems to Deprovision</span>
                    <button type="button" class="btn btn-outline-primary btn-sm" id="addSystem">
                        <i class="bi bi-plus-lg me-1"></i> Add System
                    </button>
                </div>
                <div class="form-section-body p-0">
                    <table class="table table-sm mb-0" style="font-size:13px;" id="systemsTable">
                        <thead style="background:var(--bs-tertiary-bg);">
                            <tr>
                                <th class="ps-3">System Name</th>
                                <th>Access to Revoke</th>
                                <th class="pe-3"></th>
                            </tr>
                        </thead>
                        <tbody id="systemsBody"></tbody>
                    </table>
                    <div id="noSystems" class="text-center py-3 text-muted" style="font-size:13px;">
                        No systems added yet. At least one system entry is recommended.
                    </div>
                </div>
            </div>

        </div>
        <div class="col-lg-4">
            <div class="card position-sticky" style="top:80px;">
                <div class="card-header"><i class="bi bi-exclamation-triangle me-2 text-danger"></i>SLA Policy</div>
                <div class="card-body" style="font-size:13px;">
                    <p class="text-muted">All system access must be deactivated within <strong>24 hours</strong> of HR notification.</p>
                    <p class="text-muted mb-0">Admins will receive an email warning when less than 4 hours remain on the SLA.</p>
                </div>
                <div class="card-footer d-flex gap-2">
                    <button type="submit" class="btn btn-primary btn-sm flex-fill">
                        <i class="bi bi-save me-1"></i> Log Event
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Cancel</a>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
<script>
var sysIndex = 0;
function renderSystems() {
    document.getElementById('noSystems').style.display = sysIndex === 0 ? 'block' : 'none';
}
document.getElementById('addSystem').addEventListener('click', function () {
    var tbody = document.getElementById('systemsBody');
    var i = sysIndex++;
    var tr = document.createElement('tr');
    tr.innerHTML = `
        <td class="ps-3 align-middle">
            <input type="text" name="SystemEntries[${i}].SystemName" class="form-control form-control-sm" placeholder="e.g. Active Directory" required />
        </td>
        <td class="align-middle">
            <input type="text" name="SystemEntries[${i}].AccessDescription" class="form-control form-control-sm" placeholder="e.g. All AD groups, email account" />
        </td>
        <td class="pe-3 align-middle">
            <button type="button" class="btn btn-outline-danger btn-sm" style="padding:2px 7px;" onclick="this.closest('tr').remove();renderSystems();">
                <i class="bi bi-trash"></i>
            </button>
        </td>`;
    tbody.appendChild(tr);
    renderSystems();
});
renderSystems();

// Set datetime-local default to now
var dtInput = document.querySelector('[name="HrNotificationReceivedAt"]');
if (dtInput && !dtInput.value) {
    var now = new Date();
    now.setSeconds(0, 0);
    dtInput.value = now.toISOString().slice(0, 16);
}
</script>
}
