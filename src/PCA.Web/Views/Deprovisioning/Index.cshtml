@model List<PCA.Modules.AccessManagement.Models.DeprovisioningEvent>
@using PCA.Shared.Enums
@{
    ViewData["Title"] = "Deprovisioning";
    var statusFilter = ViewBag.StatusFilter as string;
    bool allTime = ViewBag.AllTime == true;
    var overdueCount = (int)(ViewBag.OverdueCount ?? 0);
}

@if (overdueCount > 0)
{
    <div class="alert alert-danger d-flex align-items-center gap-2 mb-3" style="border-radius:10px;">
        <i class="bi bi-exclamation-triangle-fill fs-5 flex-shrink-0"></i>
        <div class="flex-grow-1">
            <strong>@overdueCount deprovisioning event@(overdueCount == 1 ? "" : "s") overdue</strong> — SLA breached. Immediate action required.
        </div>
    </div>
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Deprovisioning</h1>
        <p class="page-header-sub mb-0">Track user deprovisioning events · 24h SLA from HR notification</p>
    </div>
    @if (User.IsInRole("Admin") || User.IsInRole("Approver"))
    {
        <a asp-action="Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i> Log Event
        </a>
    }
</div>

<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" class="d-flex flex-wrap gap-2 align-items-center">
            <select name="status" class="form-select form-select-sm" style="width:auto;">
                <option value="">All Statuses</option>
                @foreach (var status in Enum.GetValues<DeprovisioningStatus>())
                {
                    if (status.ToString() == statusFilter)
                    {
                        <option value="@status" selected>@status</option>
                    }
                    else
                    {
                        <option value="@status">@status</option>
                    }
                }
            </select>
            <div class="form-check ms-2 mb-0">
                <input type="checkbox" name="allTime" value="true" id="allTime" class="form-check-input" @(allTime ? "checked" : "") />
                <label for="allTime" class="form-check-label" style="font-size:13px;">Show all time</label>
            </div>
            <button class="btn btn-outline-secondary btn-sm" type="submit">Filter</button>
            @if (!string.IsNullOrEmpty(statusFilter) || allTime)
            {
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Clear</a>
            }
            @if (!allTime)
            {
                <span class="text-muted ms-2" style="font-size:12px;">Showing last 12 months</span>
            }
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-person-dash" style="font-size:40px;opacity:.3;"></i>
                <p class="mt-3">No deprovisioning events found.</p>
            </div>
        }
        else
        {
            <table class="table table-hover mb-0" style="font-size:13px;">
                <thead style="background:var(--bs-tertiary-bg);">
                    <tr>
                        <th class="ps-3">Serial</th>
                        <th>Employee</th>
                        <th>Trigger</th>
                        <th>HR Notified</th>
                        <th>SLA Deadline</th>
                        <th>SLA Remaining</th>
                        <th>Status</th>
                        <th class="pe-3"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var evt in Model)
                    {
                        var remaining = evt.SlaDeadline - DateTime.UtcNow;
                        var isOverdue = evt.Status != DeprovisioningStatus.Completed && remaining.TotalSeconds <= 0;
                        var statusCls = evt.Status switch {
                            DeprovisioningStatus.Completed  => "status-approved",
                            DeprovisioningStatus.Overdue    => "status-rejected",
                            DeprovisioningStatus.InProgress => "status-underreview",
                            _                               => "status-submitted"
                        };
                        <tr class="@(isOverdue ? "table-danger" : "")">
                            <td class="ps-3 align-middle text-muted" style="white-space:nowrap;">@evt.SerialNumber</td>
                            <td class="align-middle fw-semibold">
                                <a asp-action="Details" asp-route-id="@evt.Id" class="text-decoration-none" style="color:inherit;">
                                    @evt.EmployeeName
                                </a>
                                <div class="text-muted fw-normal" style="font-size:11px;">@evt.Department</div>
                            </td>
                            <td class="align-middle text-muted">@evt.Trigger</td>
                            <td class="align-middle text-muted" style="white-space:nowrap;">@evt.HrNotificationReceivedAt.ToString("dd MMM yyyy HH:mm")</td>
                            <td class="align-middle @(isOverdue ? "text-danger fw-semibold" : "text-muted")" style="white-space:nowrap;">
                                @evt.SlaDeadline.ToString("dd MMM yyyy HH:mm")
                            </td>
                            <td class="align-middle" style="white-space:nowrap;">
                                @if (evt.Status == DeprovisioningStatus.Completed)
                                {
                                    <span class="text-muted">—</span>
                                }
                                else if (isOverdue)
                                {
                                    <span class="text-danger fw-semibold">
                                        <i class="bi bi-exclamation-circle me-1"></i>Overdue
                                    </span>
                                }
                                else
                                {
                                    var h = (int)remaining.TotalHours;
                                    var m = remaining.Minutes;
                                    var urgentClass = h < 4 ? "text-danger fw-semibold" : h < 12 ? "text-warning fw-semibold" : "text-muted";
                                    <span class="@urgentClass">@h h @m m</span>
                                }
                            </td>
                            <td class="align-middle">
                                <span class="status-badge @statusCls" style="font-size:10px;">@evt.Status</span>
                            </td>
                            <td class="pe-3 align-middle">
                                <a asp-action="Details" asp-route-id="@evt.Id" class="btn btn-outline-primary btn-sm" style="padding:2px 8px;font-size:11px;">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
