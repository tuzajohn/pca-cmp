@using PCA.Shared.Enums
@{
    ViewData["Title"] = "Deprovisioning";
    var statusFilter = ViewBag.StatusFilter as string;
    bool allTime = ViewBag.AllTime == true;
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Deprovisioning</h1>
        <p class="page-header-sub mb-0">Track user deprovisioning events · 24h SLA from HR notification</p>
    </div>
    @if (User.IsInRole("Admin") || User.IsInRole("Approver"))
    {
        <a asp-action="Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i> Log Event
        </a>
    }
</div>

<div id="overdue-alert"></div>

<div class="card mb-3">
    <div class="card-body py-2">
        <form id="filter-form" class="d-flex flex-wrap gap-2 align-items-center">
            <select name="status" id="f-status" class="form-select form-select-sm" style="width:auto;">
                <option value="">All Statuses</option>
                @foreach (var s in Enum.GetValues<DeprovisioningStatus>())
                {
                    <option value="@s" selected="@(s.ToString() == statusFilter)">@s</option>
                }
            </select>
            <div class="form-check ms-2 mb-0">
                <input type="checkbox" id="f-alltime" class="form-check-input" @(allTime ? "checked" : "") />
                <label for="f-alltime" class="form-check-label" style="font-size:13px;">Show all time</label>
            </div>
            <button class="btn btn-outline-secondary btn-sm" type="submit">Filter</button>
            <button class="btn btn-outline-secondary btn-sm" type="button" id="btn-clear">Clear</button>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <table id="dt-dep" class="table mb-0" style="font-size:13px;">
            <thead>
                <tr>
                    <th class="ps-3">Serial</th>
                    <th>Employee</th>
                    <th>Department</th>
                    <th>Trigger</th>
                    <th>HR Notified</th>
                    <th>SLA Deadline</th>
                    <th>SLA Remaining</th>
                    <th>Status</th>
                    <th class="pe-3"></th>
                </tr>
            </thead>
        </table>
    </div>
</div>

@section Scripts {
<script>
(function () {
    const badge = d => `<span class="status-badge status-${d.toLowerCase()}">${d}</span>`;

    const table = new DataTable('#dt-dep', {
        serverSide: true,
        processing: true,
        searching: false,
        pageLength: 25,
        order: [[4, 'desc']],
        ajax: {
            url: '/Deprovisioning/Data',
            data: d => {
                d.status  = document.getElementById('f-status').value;
                d.allTime = document.getElementById('f-alltime').checked;
            }
        },
        columns: [
            { data: 'serial',      className: 'ps-3', render: (v, _, r) => `<a href="/Deprovisioning/Details/${r.id}" class="fw-semibold text-decoration-none">${v}</a>` },
            { data: 'employee' },
            { data: 'department',  defaultContent: '—' },
            { data: 'trigger' },
            { data: 'hrNotified' },
            { data: 'slaDeadline', render: (v, _, r) => r.slaOverdue ? `<span class="text-danger fw-semibold">${v}</span>` : v },
            { data: 'slaOverdue',  orderable: false,
              render: (v, _, r) => v ? '<span class="text-danger fw-semibold">Overdue</span>' : `${r.slaH}h ${r.slaM}m` },
            { data: 'status',      render: badge },
            { data: 'id', orderable: false, className: 'pe-3 text-end',
              render: id => `<a href="/Deprovisioning/Details/${id}" class="btn btn-sm btn-outline-secondary" style="padding:2px 8px;"><i class="bi bi-eye"></i></a>` }
        ],
        drawCallback: function (settings) {
            const json = this.api().ajax.json();
            if (!json) return;
            const overdue = json.data.filter(r => r.slaOverdue && !r.completed).length;
            const el = document.getElementById('overdue-alert');
            if (overdue > 0) {
                el.innerHTML = `<div class="alert alert-danger d-flex align-items-center gap-2 mb-3" style="border-radius:10px;">
                    <i class="bi bi-exclamation-triangle-fill fs-5 flex-shrink-0"></i>
                    <div><strong>${overdue} deprovisioning event${overdue === 1 ? '' : 's'} overdue</strong> — SLA breached. Immediate action required.</div>
                </div>`;
            } else {
                el.innerHTML = '';
            }
        }
    });

    document.getElementById('filter-form').addEventListener('submit', e => { e.preventDefault(); table.ajax.reload(); });
    document.getElementById('btn-clear').addEventListener('click', () => {
        document.getElementById('f-status').value = '';
        document.getElementById('f-alltime').checked = false;
        table.ajax.reload();
    });
})();
</script>
}
