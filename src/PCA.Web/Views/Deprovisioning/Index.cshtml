@using PCA.Shared.Enums
@{
    ViewData["Title"] = "Deprovisioning";
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Deprovisioning</h1>
        <p class="page-header-sub mb-0">Track user deprovisioning events · 24h SLA from HR notification</p>
    </div>
    @if (User.IsInRole("Admin") || User.IsInRole("Approver"))
    {
        <a asp-action="Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i> Log Event
        </a>
    }
</div>

<div id="overdue-alert"></div>

<div class="card mb-3">
    <div class="card-body py-2">
        <div class="d-flex flex-wrap gap-2 align-items-center">
            <select id="f-status" class="form-select form-select-sm" style="width:auto;">
                <option value="">All Statuses</option>
                @foreach (var s in Enum.GetValues<DeprovisioningStatus>())
                {
                    <option value="@s">@s</option>
                }
            </select>
            <div class="form-check ms-2 mb-0">
                <input type="checkbox" id="f-alltime" class="form-check-input" />
                <label for="f-alltime" class="form-check-label" style="font-size:13px;">Show all time</label>
            </div>
            <button class="btn btn-primary btn-sm" id="btn-filter">Filter</button>
            <button class="btn btn-outline-secondary btn-sm" id="btn-clear">Clear</button>
        </div>
    </div>
</div>

<div class="card">
    <div id="tbl-dep"></div>
</div>

@section Scripts {
<script>
(function () {
    const badge = d => `<span class="status-badge status-${d.toLowerCase()}">${d}</span>`;

    const tbl = PagedTable.init({
        tableId: 'tbl-dep',
        url: '/Deprovisioning/Data',
        pageSize: 25,
        defaultSort: { col: 'slaDeadline', dir: 'desc' },
        filters: () => ({
            status:  document.getElementById('f-status').value,
            allTime: document.getElementById('f-alltime').checked
        }),
        columns: [
            { key: 'serial',      label: 'Serial',        thClass: 'ps-3', tdClass: 'ps-3 align-middle', render: r => `<a href="/Deprovisioning/Details/${r.id}" class="fw-semibold text-decoration-none">${r.serial}</a>` },
            { key: 'employee',    label: 'Employee',      tdClass: 'align-middle' },
            { key: 'department',  label: 'Department',    tdClass: 'align-middle text-muted', render: r => r.department || '—' },
            { key: 'trigger',     label: 'Trigger',       tdClass: 'align-middle text-muted' },
            { key: 'hrNotified',  label: 'HR Notified',   tdClass: 'align-middle text-muted' },
            { key: 'slaDeadline', label: 'SLA Deadline',  tdClass: 'align-middle', render: r => r.slaOverdue ? `<span class="text-danger fw-semibold">${r.slaDeadline}</span>` : r.slaDeadline },
            { key: 'slaOverdue',  label: 'SLA Remaining', sortable: false, tdClass: 'align-middle', render: r => r.slaOverdue ? '<span class="text-danger fw-semibold">Overdue</span>' : `${r.slaH}h ${r.slaM}m` },
            { key: 'status',      label: 'Status',        tdClass: 'align-middle', render: r => badge(r.status) },
            { key: null, label: '', sortable: false, thClass: 'pe-3', tdClass: 'pe-3 align-middle text-end',
              render: r => `<a href="/Deprovisioning/Details/${r.id}" class="btn btn-sm btn-outline-secondary" style="padding:2px 8px;"><i class="bi bi-eye"></i></a>` }
        ]
    });

    // Overdue alert — re-check after each load by refetching current data
    const origLoad = tbl.reload.bind(tbl);

    function checkOverdue() {
        fetch('/Deprovisioning/Data?page=1&pageSize=500&status=&allTime=' + document.getElementById('f-alltime').checked)
            .then(r => r.json())
            .then(result => {
                const overdue = (result.items || []).filter(r => r.slaOverdue && !r.completed).length;
                const el = document.getElementById('overdue-alert');
                el.innerHTML = overdue > 0
                    ? `<div class="alert alert-danger d-flex align-items-center gap-2 mb-3" style="border-radius:10px;">
                           <i class="bi bi-exclamation-triangle-fill fs-5 flex-shrink-0"></i>
                           <div><strong>${overdue} deprovisioning event${overdue === 1 ? '' : 's'} overdue</strong> — SLA breached. Immediate action required.</div>
                       </div>`
                    : '';
            });
    }

    checkOverdue();

    document.getElementById('btn-filter').addEventListener('click', () => { tbl.reload(); checkOverdue(); });
    document.getElementById('btn-clear').addEventListener('click', () => {
        document.getElementById('f-status').value = '';
        document.getElementById('f-alltime').checked = false;
        tbl.reload();
        checkOverdue();
    });
})();
</script>
}
