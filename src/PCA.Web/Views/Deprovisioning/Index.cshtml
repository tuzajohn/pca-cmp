@model PCA.Shared.PagedResult<PCA.Modules.AccessManagement.Models.DeprovisioningEvent>
@using PCA.Shared.Enums
@{
    ViewData["Title"] = "Deprovisioning";
    var statusFilter = ViewBag.StatusFilter as string;
    bool allTime = ViewBag.AllTime == true;
    var overdueCount = (int)(ViewBag.OverdueCount ?? 0);
}

@if (overdueCount > 0)
{
    <div class="alert alert-danger d-flex align-items-center gap-2 mb-3" style="border-radius:10px;">
        <i class="bi bi-exclamation-triangle-fill fs-5 flex-shrink-0"></i>
        <div class="flex-grow-1">
            <strong>@overdueCount deprovisioning event@(overdueCount == 1 ? "" : "s") overdue</strong> — SLA breached. Immediate action required.
        </div>
    </div>
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Deprovisioning</h1>
        <p class="page-header-sub mb-0">Track user deprovisioning events · 24h SLA from HR notification</p>
    </div>
    @if (User.IsInRole("Admin") || User.IsInRole("Approver"))
    {
        <a asp-action="Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i> Log Event
        </a>
    }
</div>

<div class="card mb-3">
    <div class="card-body py-2">
        <form id="filter-form" method="get" class="d-flex flex-wrap gap-2 align-items-center">
            <select name="status" class="form-select form-select-sm" style="width:auto;">
                <option value="">All Statuses</option>
                @foreach (var status in Enum.GetValues<DeprovisioningStatus>())
                {
                    <option value="@status" selected="@(status.ToString() == statusFilter)">@status</option>
                }
            </select>
            <div class="form-check ms-2 mb-0">
                <input type="checkbox" name="allTime" value="true" id="allTime" class="form-check-input" @(allTime ? "checked" : "") />
                <label for="allTime" class="form-check-label" style="font-size:13px;">Show all time</label>
            </div>
            <button class="btn btn-outline-secondary btn-sm" type="submit">Filter</button>
            @if (!string.IsNullOrEmpty(statusFilter) || allTime)
            {
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Clear</a>
            }
            @if (!allTime)
            {
                <span class="text-muted ms-2" style="font-size:12px;">Showing last 12 months</span>
            }
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0" id="list-container">
        @await Html.PartialAsync("_DeprovisioningList", Model)
    </div>
</div>

@section Scripts {
<script>
(function () {
    const form = document.getElementById('filter-form');
    const container = document.getElementById('list-container');

    async function loadPage(url) {
        container.style.opacity = '0.5';
        const resp = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
        container.innerHTML = await resp.text();
        container.style.opacity = '1';
        history.pushState(null, '', url);
        bindPagination();
    }

    function bindPagination() {
        container.querySelectorAll('.pagination-link').forEach(a => {
            a.addEventListener('click', e => {
                e.preventDefault();
                const url = new URL(window.location.href);
                url.searchParams.set('page', a.dataset.page);
                loadPage(url.toString());
            });
        });
    }

    form.addEventListener('submit', e => {
        e.preventDefault();
        const url = new URL(window.location.pathname, window.location.origin);
        new FormData(form).forEach((v, k) => { if (v) url.searchParams.set(k, v); });
        url.searchParams.set('page', '1');
        loadPage(url.toString());
    });

    bindPagination();
})();
</script>
}
