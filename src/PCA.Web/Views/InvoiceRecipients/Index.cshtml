@model List<PCA.Modules.Invoicing.Models.InvoiceRecipient>
@{ ViewData["Title"] = "Invoice Recipients"; }

<div class="page-header">
    <div>
        <h1 class="page-header-title">Invoice Recipients</h1>
        <p class="page-header-sub mb-0">Global list of people who receive invoice emails</p>
    </div>
    <a asp-action="Create" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i> Add Recipient</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-envelope" style="font-size:40px;opacity:.3;"></i>
                <p class="mt-3">No recipients configured yet.</p>
            </div>
        }
        else
        {
            <table class="table table-hover mb-0" style="font-size:13px;">
                <thead style="background:var(--bs-tertiary-bg);">
                    <tr>
                        <th class="ps-3">Name</th>
                        <th>Email</th>
                        <th>Default</th>
                        <th class="pe-3"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        <tr>
                            <td class="ps-3 align-middle fw-semibold">@r.Name</td>
                            <td class="align-middle text-muted">@r.Email</td>
                            <td class="align-middle">
                                @if (r.IsDefault)
                                {
                                    <span class="badge bg-primary" style="font-size:10px;">Default</span>
                                }
                            </td>
                            <td class="pe-3 align-middle text-end">
                                <a asp-action="Edit" asp-route-id="@r.Id" class="btn btn-outline-secondary btn-sm me-1" style="padding:2px 8px;font-size:11px;">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@r.Id" method="post" class="d-inline"
                                      onsubmit="return confirm('Remove this recipient?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger btn-sm" style="padding:2px 8px;font-size:11px;">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
