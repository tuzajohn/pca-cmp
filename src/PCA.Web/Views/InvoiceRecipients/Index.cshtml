@{ ViewData["Title"] = "Invoice Recipients"; }

<div class="page-header">
    <div>
        <h1 class="page-header-title">Invoice Recipients</h1>
        <p class="page-header-sub mb-0">Global list of people who receive invoice emails</p>
    </div>
    <a asp-action="Create" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i> Add Recipient</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div id="tbl-recipients"></div>
</div>

@section Scripts {
<script>
PagedTable.init({
    tableId: 'tbl-recipients',
        tableClass: 'table table-hover mb-0',
    url: '/InvoiceRecipients/IndexData',
    pageSize: 25,
    defaultSort: { col: 'name', dir: 'asc' },
    columns: [
        { key: 'name',      label: 'Name',      thClass: 'ps-3', tdClass: 'ps-3 align-middle fw-semibold' },
        { key: 'email',     label: 'Email',     tdClass: 'align-middle text-muted' },
        { key: 'isDefault', label: 'Default',   tdClass: 'align-middle', render: r => r.isDefault ? '<span class="badge bg-success" style="font-size:10px;">Default</span>' : '' },
        { key: null, label: '', sortable: false, thClass: 'pe-3', tdClass: 'pe-3 align-middle text-end',
          render: r => `<a href="/InvoiceRecipients/Edit/${r.id}" class="btn btn-outline-secondary btn-sm me-1" style="padding:2px 8px;font-size:11px;"><i class="bi bi-pencil"></i></a>
                        <button class="btn btn-outline-danger btn-sm" style="padding:2px 8px;font-size:11px;"
                                onclick="if(confirm('Delete this recipient?')){const f=document.createElement('form');f.method='post';f.action='/InvoiceRecipients/Delete/${r.id}';const t=document.createElement('input');t.type='hidden';t.name='__RequestVerificationToken';t.value=document.querySelector('input[name=__RequestVerificationToken]')?.value||'';f.appendChild(t);document.body.appendChild(f);f.submit();}"><i class="bi bi-trash"></i></button>` }
    ]
});
</script>
}
