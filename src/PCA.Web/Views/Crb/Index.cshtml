@{
    ViewData["Title"] = "CRB Payroll Deductions";
}

<div class="page-header d-flex align-items-center mb-4">
    <div>
        <h1 class="page-title">CRB Payroll Deductions</h1>
        <p class="text-muted mb-0">Generate monthly CRB deductions reports from HCM and IPPS sources.</p>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card h-100 shadow-sm">
            <div class="card-body d-flex flex-column">
                <div class="d-flex align-items-center mb-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center me-3"
                         style="width:48px;height:48px;background:var(--color-primary);color:#fff;font-size:20px;">
                        <i class="bi bi-1-circle-fill"></i>
                    </div>
                    <div>
                        <h5 class="mb-0">Module 1 — HCM Report</h5>
                        <small class="text-muted">+ Auto-runs Module 2 for unmatched IPPS</small>
                    </div>
                </div>
                <p class="text-muted small flex-grow-1">
                    Upload the <strong>HCM Excel file</strong> and the <strong>Stanbic monthly IPPS reference</strong>.
                    Matches Stanbic employees in HCM data, computes salary/stat/allow from the file,
                    then queries the HCM DB for live deduction figures.
                    Unmatched IPPS numbers are automatically passed to Module 2.
                </p>
                <div class="mt-3">
                    <a asp-controller="Crb" asp-action="HcmRun" class="btn btn-primary">
                        <i class="bi bi-play-fill me-1"></i>Run HCM Report
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card h-100 shadow-sm">
            <div class="card-body d-flex flex-column">
                <div class="d-flex align-items-center mb-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center me-3"
                         style="width:48px;height:48px;background:#6c757d;color:#fff;font-size:20px;">
                        <i class="bi bi-2-circle-fill"></i>
                    </div>
                    <div>
                        <h5 class="mb-0">Module 2 — IPPS Report</h5>
                        <small class="text-muted">Standalone run for IPPS-only employees</small>
                    </div>
                </div>
                <p class="text-muted small flex-grow-1">
                    Upload a plain list of <strong>IPPS numbers</strong>.
                    Queries the IPPS DB directly for employee data, statutory deductions,
                    allowances, and loan deductions.
                    Use this independently when no HCM file is available.
                </p>
                <div class="mt-3">
                    <a asp-controller="Crb" asp-action="IppsRun" class="btn btn-outline-secondary">
                        <i class="bi bi-play me-1"></i>Run IPPS Report
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card h-100 shadow-sm border-0 bg-light">
            <div class="card-body d-flex flex-column">
                <div class="d-flex align-items-center mb-3">
                    <i class="bi bi-table text-muted me-2" style="font-size:1.4rem;"></i>
                    <h6 class="mb-0">Mapping Table</h6>
                </div>
                <p class="text-muted small flex-grow-1">
                    Manage how HCM <code>COSTITEM</code> and <code>VENDOR_NAME</code> values
                    are classified (Basic Salary, Allowance, Statutory, Loan, Ignore).
                    Unknown values are flagged during Module 1 processing.
                </p>
                <div class="mt-3">
                    <a asp-controller="Crb" asp-action="Mappings" class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-pencil-square me-1"></i>View / Edit Mappings
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
