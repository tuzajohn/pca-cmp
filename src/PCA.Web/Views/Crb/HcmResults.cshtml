@using PCA.Modules.Invoicing.Services
@{
    ViewData["Title"] = "CRB Report — Complete";
    var result = ViewBag.Result as HcmRunResult;
}

<div class="page-header d-flex align-items-center mb-4">
    <a asp-controller="Crb" asp-action="Index" class="btn btn-sm btn-outline-secondary me-3">
        <i class="bi bi-arrow-left"></i>
    </a>
    <div>
        <h1 class="page-title">CRB Report Complete</h1>
        <p class="text-muted mb-0">Both output files are ready for download.</p>
    </div>
</div>

@if (result != null)
{
    <div class="alert alert-success">
        <i class="bi bi-check-circle-fill me-2"></i>
        Report generated successfully.
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-body d-flex flex-column">
                    <h5 class="mb-1"><i class="bi bi-file-earmark-spreadsheet me-2 text-success"></i>Module 1 — HCM</h5>
                    <p class="text-muted small mb-3">@result.HcmFileName</p>
                    <a asp-controller="Crb" asp-action="DownloadResult"
                       asp-route-path="@result.HcmFilePath"
                       asp-route-name="@result.HcmFileName"
                       class="btn btn-success mt-auto">
                        <i class="bi bi-download me-1"></i>Download HCM Report
                    </a>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-body d-flex flex-column">
                    <h5 class="mb-1"><i class="bi bi-file-earmark-spreadsheet me-2 text-primary"></i>Module 2 — IPPS</h5>
                    <p class="text-muted small mb-3">@result.IppsFileName</p>
                    <a asp-controller="Crb" asp-action="DownloadResult"
                       asp-route-path="@result.IppsFilePath"
                       asp-route-name="@result.IppsFileName"
                       class="btn btn-primary mt-auto">
                        <i class="bi bi-download me-1"></i>Download IPPS Report
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header"><h6 class="mb-0">Run Log</h6></div>
        <div class="card-body p-0">
            <table class="table table-sm mb-0">
                <tbody>
                    <tr><td class="text-muted ps-3">Total Stanbic IPPS submitted</td>      <td class="fw-semibold text-end pe-3">@result.TotalStanbicSubmitted</td></tr>
                    <tr><td class="text-muted ps-3">Matched to HCM Sheet1</td>             <td class="fw-semibold text-end pe-3">@result.MatchedToHcm</td></tr>
                    <tr><td class="text-muted ps-3">Passed to IPPS module</td>             <td class="fw-semibold text-end pe-3">@result.PassedToIpps</td></tr>
                    <tr><td class="text-muted ps-3">Unknown COSTITEM/VENDOR flagged</td>   <td class="fw-semibold text-end pe-3">@result.UnknownsFlagged</td></tr>
                    <tr><td class="text-muted ps-3">Employees with stat &gt; 0</td>        <td class="fw-semibold text-end pe-3">@result.WithStat</td></tr>
                    <tr><td class="text-muted ps-3">Employees with allow &gt; 0</td>       <td class="fw-semibold text-end pe-3">@result.WithAllow</td></tr>
                    <tr><td class="text-muted ps-3">Employees with ded &gt; 0</td>         <td class="fw-semibold text-end pe-3">@result.WithDed</td></tr>
                    <tr><td class="text-muted ps-3">Employees with stanbic &gt; 0</td>     <td class="fw-semibold text-end pe-3">@result.WithStanbic</td></tr>
                    <tr><td class="text-muted ps-3">Employees with affordability = 0</td>  <td class="fw-semibold text-end pe-3">@result.ZeroAfford</td></tr>
                </tbody>
            </table>
        </div>
    </div>
}
