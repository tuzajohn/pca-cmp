@{
    ViewData["Title"] = "Module 2 — IPPS CRB Report";
}

<div class="page-header d-flex align-items-center mb-4">
    <a asp-controller="Crb" asp-action="Index" class="btn btn-sm btn-outline-secondary me-3">
        <i class="bi bi-arrow-left"></i>
    </a>
    <div>
        <h1 class="page-title">Module 2 — IPPS CRB Report</h1>
        <p class="text-muted mb-0">Standalone run for employees not found in HCM.</p>
    </div>
</div>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <div>@error.ErrorMessage</div>
        }
    </div>
}

<div class="row">
    <div class="col-lg-6">
        <div class="card shadow-sm">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-upload me-2"></i>Upload IPPS File</h5>
            </div>
            <div class="card-body">
                <form method="post" action="/Crb/IppsGenerate" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()

                    <div class="mb-4">
                        <label for="ippsFile" class="form-label fw-semibold">IPPS Numbers File</label>
                        <input type="file" class="form-control" id="ippsFile" name="ippsFile"
                               accept=".txt,.csv,.xlsx,.xls" required>
                        <div class="form-text">
                            Accepted: <strong>.txt</strong>, <strong>.csv</strong>, <strong>.xlsx</strong>.<br>
                            One IPPS number per row or comma-separated. Numbers padded to 15 digits automatically.
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-play-fill me-1"></i>Generate IPPS Report
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
