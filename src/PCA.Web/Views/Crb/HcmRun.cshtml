@{
    ViewData["Title"] = "Module 1 — HCM CRB Report";
}

<div class="page-header d-flex align-items-center mb-4">
    <a asp-controller="Crb" asp-action="Index" class="btn btn-sm btn-outline-secondary me-3">
        <i class="bi bi-arrow-left"></i>
    </a>
    <div>
        <h1 class="page-title">Module 1 — HCM CRB Report</h1>
        <p class="text-muted mb-0">Upload HCM file + Stanbic IPPS reference to generate the combined report.</p>
    </div>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <div>@error.ErrorMessage</div>
        }
    </div>
}

<div class="row">
    <div class="col-lg-7">
        <div class="card shadow-sm">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-upload me-2"></i>Upload Files</h5>
            </div>
            <div class="card-body">
                <form method="post" action="/Crb/HcmUpload" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()

                    <div class="mb-4">
                        <label for="hcmFile" class="form-label fw-semibold">HCM Excel File (Sheet1)</label>
                        <input type="file" class="form-control" id="hcmFile" name="hcmFile"
                               accept=".xlsx,.xls" required>
                        <div class="form-text">
                            Must contain columns: <code>EMP_NUMBER, EMPLOYEE_NO, EMPLOYEE_NAME,
                            VOTE_CODE, VOTE_NAME, COSTITEM, COSTITEM_AMT, VENDOR_NAME, VENDOR_AMOUNT</code>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label for="stanbicFile" class="form-label fw-semibold">Stanbic Monthly IPPS Reference</label>
                        <input type="file" class="form-control" id="stanbicFile" name="stanbicFile"
                               accept=".txt,.csv,.xlsx,.xls" required>
                        <div class="form-text">
                            One IPPS number per row (or comma-separated). Numbers are padded to 15 digits automatically.
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-play-fill me-1"></i>Process &amp; Generate
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-5 mt-4 mt-lg-0">
        <div class="card border-0 bg-light shadow-sm">
            <div class="card-body">
                <h6 class="fw-semibold mb-3"><i class="bi bi-diagram-3 me-1"></i>Processing Pipeline</h6>
                <ol class="small mb-0" style="padding-left:1.2rem;">
                    <li class="mb-2"><strong>Cross-reference</strong> — Stanbic IPPS matched against HCM EMP_NUMBER. Unmatched → Module 2.</li>
                    <li class="mb-2"><strong>Mapping check</strong> — all COSTITEM and VENDOR_NAME values checked. Unknown values trigger classification before continuing.</li>
                    <li class="mb-2"><strong>Salary</strong> — MAX(COSTITEM_AMT) where classification = BASIC_SALARY.</li>
                    <li class="mb-2"><strong>Statutory</strong> — per unique VENDOR_NAME classified STATUTORY: MAX(VENDOR_AMOUNT), then sum.</li>
                    <li class="mb-2"><strong>Allowances</strong> — per unique COSTITEM classified ALLOWANCE: MAX(COSTITEM_AMT), then sum.</li>
                    <li class="mb-2"><strong>HCM DB</strong> — live isactive, terms, total deductions, Stanbic reservations.</li>
                    <li class="mb-2"><strong>Affordability</strong> — <code>MAX(0, salary × 48% − (stat + ded))</code></li>
                    <li><strong>Output</strong> — <code>CRB_HCM_YYYYMMDD.xlsx</code> + <code>CRB_IPPS_YYYYMMDD.xlsx</code></li>
                </ol>
            </div>
        </div>
    </div>
</div>
