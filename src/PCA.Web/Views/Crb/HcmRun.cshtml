@{
    ViewData["Title"] = "Module 1 — HCM CRB Report";
}

<div class="page-header d-flex align-items-center mb-4">
    <a asp-controller="Crb" asp-action="Index" class="btn btn-sm btn-outline-secondary me-3">
        <i class="bi bi-arrow-left"></i>
    </a>
    <div>
        <h1 class="page-title">Module 1 — HCM CRB Report</h1>
        <p class="text-muted mb-0">Upload HCM file + Stanbic IPPS reference to generate the combined report.</p>
    </div>
</div>

{{-- upload form --}}
<div id="step-upload">
    <div class="row">
        <div class="col-lg-7">
            <div class="card shadow-sm">
                <div class="card-header"><h5 class="mb-0"><i class="bi bi-upload me-2"></i>Upload Files</h5></div>
                <div class="card-body">
                    <div id="upload-error" class="alert alert-danger d-none"></div>
                    <form id="upload-form" novalidate>
                        <div class="mb-4">
                            <label class="form-label fw-semibold">HCM Excel File (Sheet1)</label>
                            <input type="file" class="form-control" id="hcmFile" accept=".xlsx,.xls" required>
                            <div class="form-text">Columns: <code>EMP_NUMBER, EMPLOYEE_NO, EMPLOYEE_NAME, VOTE_CODE, VOTE_NAME, COSTITEM, COSTITEM_AMT, VENDOR_NAME, VENDOR_AMOUNT</code></div>
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Stanbic Monthly IPPS Reference</label>
                            <input type="file" class="form-control" id="stanbicFile" accept=".txt,.csv,.xlsx,.xls" required>
                            <div class="form-text">One IPPS number per row or comma-separated.</div>
                        </div>
                        <button type="submit" class="btn btn-primary" id="btn-upload">
                            <i class="bi bi-play-fill me-1"></i>Process &amp; Generate
                        </button>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-lg-5 mt-4 mt-lg-0">
            <div class="card border-0 bg-light shadow-sm">
                <div class="card-body">
                    <h6 class="fw-semibold mb-3"><i class="bi bi-diagram-3 me-1"></i>Pipeline</h6>
                    <ol class="small mb-0" style="padding-left:1.2rem;">
                        <li class="mb-1">Cross-reference Stanbic IPPS vs HCM EMP_NUMBER</li>
                        <li class="mb-1">Mapping check — unknown values paused for classification</li>
                        <li class="mb-1">Salary, Statutory, Allowances from HCM file</li>
                        <li class="mb-1">HCM DB — isactive, terms, deductions, stanbic</li>
                        <li class="mb-1">Affordability = MAX(0, salary × 48% − (stat + ded))</li>
                        <li>Output: CRB_HCM + CRB_IPPS Excel files</li>
                    </ol>
                </div>
            </div>
        </div>
    </div>
</div>

{{-- processing spinner --}}
<div id="step-processing" class="d-none text-center py-5">
    <div class="spinner-border text-primary mb-3" style="width:3rem;height:3rem;"></div>
    <p class="text-muted" id="processing-msg">Processing files…</p>
</div>

{{-- classify unknowns --}}
<div id="step-classify" class="d-none">
    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        Processing paused — <strong id="unknown-count">0</strong> unrecognised value(s) found.
        Classify each one and click <strong>Save &amp; Resume</strong>.
    </div>
    <div class="card shadow-sm mb-4">
        <div class="card-body p-0">
            <table class="table table-bordered mb-0" id="classify-table">
                <thead class="table-light">
                    <tr><th>Source</th><th>Raw Value</th><th style="width:200px;">Classification</th></tr>
                </thead>
                <tbody id="classify-body"></tbody>
            </table>
        </div>
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-primary" id="btn-save-mappings">
            <i class="bi bi-check-lg me-1"></i>Save &amp; Resume
        </button>
        <button class="btn btn-outline-secondary" id="btn-cancel-classify">Cancel</button>
    </div>
</div>

{{-- results --}}
<div id="step-results" class="d-none">
    <div class="alert alert-success"><i class="bi bi-check-circle-fill me-2"></i>Report generated successfully.</div>
    <div class="row g-4 mb-4" id="result-files"></div>
    <div class="card shadow-sm">
        <div class="card-header"><h6 class="mb-0">Run Log</h6></div>
        <div class="card-body p-0">
            <table class="table table-sm mb-0" id="run-log"></table>
        </div>
    </div>
    <div class="mt-3">
        <button class="btn btn-outline-secondary btn-sm" id="btn-run-again">
            <i class="bi bi-arrow-counterclockwise me-1"></i>Run Again
        </button>
    </div>
</div>

@section Scripts {
<script>
(function () {
    const CLASSIFICATIONS = ['BASIC_SALARY','ALLOWANCE','STATUTORY','LOAN_DEDUCTION','IGNORE'];
    let pendingRunId = null;

    const show = id => document.getElementById(id).classList.remove('d-none');
    const hide = id => document.getElementById(id).classList.add('d-none');
    const showError = msg => {
        const el = document.getElementById('upload-error');
        el.textContent = msg;
        el.classList.remove('d-none');
    };

    // ── Upload form submit ──────────────────────────────────────────────────
    document.getElementById('upload-form').addEventListener('submit', async e => {
        e.preventDefault();
        const hcmFile     = document.getElementById('hcmFile').files[0];
        const stanbicFile = document.getElementById('stanbicFile').files[0];
        if (!hcmFile || !stanbicFile) { showError('Both files are required.'); return; }

        document.getElementById('upload-error').classList.add('d-none');
        document.getElementById('processing-msg').textContent = 'Checking mappings and loading files…';
        hide('step-upload'); show('step-processing');

        const fd = new FormData();
        fd.append('hcmFile',     hcmFile);
        fd.append('stanbicFile', stanbicFile);

        let data;
        try {
            const res = await fetch('/Crb/HcmUpload', { method: 'POST', body: fd });
            data = await res.json();
        } catch (err) {
            hide('step-processing'); show('step-upload');
            showError('Request failed: ' + err.message);
            return;
        }

        handleResponse(data);
    });

    // ── Save mappings ───────────────────────────────────────────────────────
    document.getElementById('btn-save-mappings').addEventListener('click', async () => {
        const rows = document.querySelectorAll('#classify-body tr');
        const mappings = [];
        let valid = true;
        rows.forEach(row => {
            const sel = row.querySelector('select');
            if (!sel.value) { sel.classList.add('is-invalid'); valid = false; }
            else { sel.classList.remove('is-invalid'); }
            mappings.push({
                rawValue:       row.dataset.raw,
                sourceColumn:   row.dataset.source,
                classification: sel.value
            });
        });
        if (!valid) return;

        document.getElementById('processing-msg').textContent = 'Saving mappings and resuming…';
        hide('step-classify'); show('step-processing');

        let data;
        try {
            const res = await fetch('/Crb/SaveMappings', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ runId: pendingRunId, mappings })
            });
            data = await res.json();
        } catch (err) {
            hide('step-processing'); show('step-classify');
            alert('Request failed: ' + err.message);
            return;
        }

        handleResponse(data);
    });

    document.getElementById('btn-cancel-classify').addEventListener('click', () => {
        hide('step-classify'); show('step-upload');
        pendingRunId = null;
    });

    document.getElementById('btn-run-again').addEventListener('click', () => {
        hide('step-results'); show('step-upload');
        document.getElementById('upload-form').reset();
    });

    // ── Response router ─────────────────────────────────────────────────────
    function handleResponse(data) {
        hide('step-processing');
        if (data.status === 'error') {
            show('step-upload'); showError(data.message);
        } else if (data.status === 'classify') {
            pendingRunId = data.runId;
            buildClassifyTable(data.unknowns);
            show('step-classify');
        } else if (data.status === 'complete') {
            buildResults(data);
            show('step-results');
        }
    }

    // ── Build classify table ─────────────────────────────────────────────────
    function buildClassifyTable(unknowns) {
        document.getElementById('unknown-count').textContent = unknowns.length;
        const tbody = document.getElementById('classify-body');
        tbody.innerHTML = '';
        unknowns.forEach(u => {
            const tr = document.createElement('tr');
            tr.dataset.raw    = u.rawValue;
            tr.dataset.source = u.sourceColumn;
            const badge = u.sourceColumn === 'COSTITEM'
                ? '<span class="badge bg-primary">COSTITEM</span>'
                : '<span class="badge bg-secondary">VENDOR_NAME</span>';
            const opts = CLASSIFICATIONS.map(c =>
                `<option value="${c}">${c.replace(/_/g,' ')}</option>`).join('');
            tr.innerHTML = `
                <td>${badge}</td>
                <td class="font-monospace small">${u.rawValue}</td>
                <td><select class="form-select form-select-sm"><option value="">— select —</option>${opts}</select></td>`;
            tbody.appendChild(tr);
        });
    }

    // ── Build results ────────────────────────────────────────────────────────
    function buildResults(data) {
        // File download cards
        const filesEl = document.getElementById('result-files');
        filesEl.innerHTML = '';
        const files = data.hcmFile
            ? [{ label:'Module 1 — HCM', f: data.hcmFile, color:'success' },
               { label:'Module 2 — IPPS', f: data.ippsFile, color:'primary' }]
            : [{ label:'IPPS Report', f: data.file, color:'primary' }];

        files.forEach(({ label, f, color }) => {
            const col = document.createElement('div');
            col.className = 'col-md-6';
            col.innerHTML = `
                <div class="card shadow-sm h-100">
                    <div class="card-body d-flex flex-column">
                        <h5 class="mb-1"><i class="bi bi-file-earmark-spreadsheet me-2 text-${color}"></i>${label}</h5>
                        <p class="text-muted small mb-3">${f.name}</p>
                        <a href="${f.url}" class="btn btn-${color} mt-auto">
                            <i class="bi bi-download me-1"></i>Download
                        </a>
                    </div>
                </div>`;
            filesEl.appendChild(col);
        });

        // Run log
        const s = data.stats || {};
        const logEl = document.getElementById('run-log');
        const rows = data.hcmFile ? [
            ['Total Stanbic IPPS submitted',    s.totalStanbicSubmitted],
            ['Matched to HCM Sheet1',           s.matchedToHcm],
            ['Passed to IPPS module',           s.passedToIpps],
            ['Employees with stat > 0',         s.withStat],
            ['Employees with allow > 0',        s.withAllow],
            ['Employees with ded > 0',          s.withDed],
            ['Employees with stanbic > 0',      s.withStanbic],
            ['Employees with affordability = 0',s.zeroAfford],
        ] : [
            ['Total submitted',      s.totalSubmitted],
            ['Matched',              s.matched],
            ['Unmatched',            s.unmatched],
            ['With stat > 0',        s.withStat],
            ['With allow > 0',       s.withAllow],
            ['With ded > 0',         s.withDed],
            ['With stanbic > 0',     s.withStanbic],
            ['Affordability = 0',    s.zeroAfford],
        ];
        logEl.innerHTML = '<tbody>' + rows.map(([label, val]) =>
            `<tr><td class="text-muted ps-3">${label}</td><td class="fw-semibold text-end pe-3">${val ?? 0}</td></tr>`
        ).join('') + '</tbody>';
    }
})();
</script>
}
