@model List<PCA.Web.Models.AppLog>
@{
    ViewData["Title"] = "Log Viewer";
    var sources    = ViewBag.Sources as List<string> ?? new();
    var page       = (int)ViewBag.Page;
    var totalPages = (int)ViewBag.TotalPages;
    var total      = (int)ViewBag.Total;
}

<div class="page-header">
    <h1 class="page-header-title">Log Viewer</h1>
    <div class="d-flex gap-2">
        <button class="btn btn-outline-danger btn-sm" data-bs-toggle="modal" data-bs-target="#clearModal">
            <i class="bi bi-trash me-1"></i> Clear Logs
        </button>
    </div>
</div>

<!-- Filters -->
<form method="get" class="card mb-3">
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-sm-3">
                <label class="form-label small fw-semibold">Source</label>
                <select name="source" class="form-select form-select-sm">
                    <option value="">All Sources</option>
                    @foreach (var s in sources)
                    {
                        if (ViewBag.Source == s) { <option value="@s" selected>@s</option> }
                        else                     { <option value="@s">@s</option> }
                    }
                </select>
            </div>
            <div class="col-sm-2">
                <label class="form-label small fw-semibold">Level</label>
                <select name="level" class="form-select form-select-sm">
                    <option value="">All Levels</option>
                    @foreach (var l in new[] { "Info", "Warning", "Error", "Critical" })
                    {
                        if ((string?)ViewBag.Level == l) { <option value="@l" selected>@l</option> }
                        else                             { <option value="@l">@l</option> }
                    }
                </select>
            </div>
            <div class="col-sm-2">
                <label class="form-label small fw-semibold">Category</label>
                <select name="category" class="form-select form-select-sm">
                    <option value="">All</option>
                    @foreach (var c in new[] { "App", "Audit", "External" })
                    {
                        if ((string?)ViewBag.Category == c) { <option value="@c" selected>@c</option> }
                        else                                { <option value="@c">@c</option> }
                    }
                </select>
            </div>
            <div class="col-sm-2">
                <label class="form-label small fw-semibold">From</label>
                <input type="date" name="from" value="@ViewBag.From" class="form-control form-control-sm" />
            </div>
            <div class="col-sm-2">
                <label class="form-label small fw-semibold">To</label>
                <input type="date" name="to" value="@ViewBag.To" class="form-control form-control-sm" />
            </div>
            <div class="col-sm-3">
                <label class="form-label small fw-semibold">Search</label>
                <input type="text" name="search" value="@ViewBag.Search" class="form-control form-control-sm"
                       placeholder="message, action, email…" />
            </div>
            <div class="col-sm-auto">
                <button type="submit" class="btn btn-primary btn-sm">Filter</button>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm ms-1">Reset</a>
            </div>
        </div>
    </div>
</form>

<div class="d-flex justify-content-between align-items-center mb-2" style="font-size:12px;color:var(--bs-secondary-color);">
    <span>@total result@(total == 1 ? "" : "s")</span>
    <span>Page @(page) of @(totalPages)</span>
</div>

@if (!Model.Any())
{
    <div class="card">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-journal-text fs-1 d-block mb-2 opacity-25"></i>
            No log entries match your filters.
        </div>
    </div>
}
else
{
    <div class="card">
        <table class="table mb-0" style="font-size:12px;">
            <thead>
                <tr>
                    <th style="width:150px;">Timestamp</th>
                    <th style="width:80px;">Level</th>
                    <th style="width:80px;">Category</th>
                    <th style="width:130px;">Source</th>
                    <th>Message</th>
                    <th style="width:140px;">User</th>
                    <th style="width:40px;"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in Model)
                {
                    var rowBg    = (log.Level == "Error" || log.Level == "Critical") ? "background:rgba(239,68,68,.04);" : "";
                    var levelCls = log.Level == "Error" ? "bg-danger"
                                 : log.Level == "Critical" ? "bg-dark"
                                 : log.Level == "Warning" ? "bg-warning text-dark"
                                 : "bg-secondary";
                    var catCls   = log.Category == "Audit" ? "bg-primary"
                                 : log.Category == "External" ? "bg-info text-dark"
                                 : "bg-light text-dark border";
                    <tr style="@rowBg">
                        <td class="text-muted">@log.Timestamp.ToString("dd MMM yyyy HH:mm:ss")</td>
                        <td><span class="badge @levelCls" style="font-size:10px;">@log.Level</span></td>
                        <td><span class="badge @catCls"   style="font-size:10px;">@log.Category</span></td>
                        <td class="text-truncate" style="max-width:130px;">@log.Source</td>
                        <td>
                            <div class="text-truncate" style="max-width:400px;" title="@log.Message">@log.Message</div>
                            @if (!string.IsNullOrEmpty(log.Action))
                            {
                                <div class="text-muted" style="font-size:10px;">@log.Action</div>
                            }
                        </td>
                        <td class="text-muted text-truncate" style="max-width:140px;">@log.UserEmail</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@log.Id" class="btn btn-outline-secondary btn-sm"
                               style="padding:1px 6px;">
                                <i class="bi bi-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (totalPages > 1)
    {
        <nav class="mt-3 d-flex justify-content-center">
            <ul class="pagination pagination-sm mb-0">
                @if (page > 1)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Index" asp-route-page="@(page - 1)"
                           asp-route-source="@ViewBag.Source" asp-route-level="@ViewBag.Level"
                           asp-route-category="@ViewBag.Category" asp-route-search="@ViewBag.Search"
                           asp-route-from="@ViewBag.From" asp-route-to="@ViewBag.To">‹</a>
                    </li>
                }
                @for (var p = Math.Max(1, page - 2); p <= Math.Min(totalPages, page + 2); p++)
                {
                    <li class="page-item @(p == page ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@p"
                           asp-route-source="@ViewBag.Source" asp-route-level="@ViewBag.Level"
                           asp-route-category="@ViewBag.Category" asp-route-search="@ViewBag.Search"
                           asp-route-from="@ViewBag.From" asp-route-to="@ViewBag.To">@p</a>
                    </li>
                }
                @if (page < totalPages)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Index" asp-route-page="@(page + 1)"
                           asp-route-source="@ViewBag.Source" asp-route-level="@ViewBag.Level"
                           asp-route-category="@ViewBag.Category" asp-route-search="@ViewBag.Search"
                           asp-route-from="@ViewBag.From" asp-route-to="@ViewBag.To">›</a>
                    </li>
                }
            </ul>
        </nav>
    }
}

<!-- Clear modal -->
<div class="modal fade" id="clearModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Clear Logs</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Clear" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Source (leave blank for all)</label>
                        <select name="source" class="form-select">
                            <option value="">All Sources</option>
                            @foreach (var s in sources)
                            {
                                <option value="@s">@s</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Older than (days)</label>
                        <input type="number" name="olderThanDays" class="form-control" placeholder="e.g. 30" min="1" />
                        <div class="form-text">Leave blank to clear all matching logs regardless of age.</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger"
                            onclick="return confirm('This is permanent. Continue?')">Clear</button>
                </div>
            </form>
        </div>
    </div>
</div>
