@{
    ViewData["Title"] = "Log Viewer";
    var sources = ViewBag.Sources as List<string> ?? new List<string>();
}

<div class="page-header">
    <h1 class="page-header-title">Log Viewer</h1>
    <div class="d-flex gap-2">
        <button class="btn btn-outline-danger btn-sm" data-bs-toggle="modal" data-bs-target="#clearModal">
            <i class="bi bi-trash me-1"></i> Clear Logs
        </button>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-sm-3">
                <label class="form-label small fw-semibold">Source</label>
                <select id="f-source" class="form-select form-select-sm">
                    <option value="">All Sources</option>
                    @foreach (var s in sources) { <option value="@s">@s</option> }
                </select>
            </div>
            <div class="col-sm-2">
                <label class="form-label small fw-semibold">Level</label>
                <select id="f-level" class="form-select form-select-sm">
                    <option value="">All Levels</option>
                    @foreach (var l in new[] { "Info", "Warning", "Error", "Critical" }) { <option value="@l">@l</option> }
                </select>
            </div>
            <div class="col-sm-2">
                <label class="form-label small fw-semibold">Category</label>
                <select id="f-category" class="form-select form-select-sm">
                    <option value="">All</option>
                    @foreach (var c in new[] { "App", "Audit", "External" }) { <option value="@c">@c</option> }
                </select>
            </div>
            <div class="col-sm-2">
                <label class="form-label small fw-semibold">From</label>
                <input type="date" id="f-from" class="form-control form-control-sm" />
            </div>
            <div class="col-sm-2">
                <label class="form-label small fw-semibold">To</label>
                <input type="date" id="f-to" class="form-control form-control-sm" />
            </div>
            <div class="col-sm-3">
                <label class="form-label small fw-semibold">Search</label>
                <input type="text" id="f-search" class="form-control form-control-sm" placeholder="message, action, email…" />
            </div>
            <div class="col-sm-auto">
                <button id="btn-filter" class="btn btn-primary btn-sm">Filter</button>
                <button id="btn-clear"  class="btn btn-outline-secondary btn-sm ms-1">Reset</button>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <table id="tbl-logs" class="table mb-0" style="font-size:12px;">
            <thead style="background:var(--bs-tertiary-bg);"></thead>
            <tbody></tbody>
        </table>
    </div>
    <div class="card-footer py-2" id="tbl-logs-pagination"></div>
</div>

<!-- Clear modal -->
<div class="modal fade" id="clearModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Clear Logs</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Clear" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Source (leave blank for all)</label>
                        <select name="source" class="form-select">
                            <option value="">All Sources</option>
                            @foreach (var s in sources) { <option value="@s">@s</option> }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Older than (days)</label>
                        <input type="number" name="olderThanDays" class="form-control" placeholder="e.g. 30" min="1" />
                        <div class="form-text">Leave blank to clear all matching logs regardless of age.</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger" onclick="return confirm('This is permanent. Continue?')">Clear</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    function levelBadge(l) {
        const cls = l === 'Error' ? 'bg-danger' : l === 'Critical' ? 'bg-dark' : l === 'Warning' ? 'bg-warning text-dark' : 'bg-secondary';
        return `<span class="badge ${cls}" style="font-size:10px;">${l}</span>`;
    }
    function catBadge(c) {
        const cls = c === 'Audit' ? 'bg-primary' : c === 'External' ? 'bg-info text-dark' : 'bg-light text-dark border';
        return `<span class="badge ${cls}" style="font-size:10px;">${c}</span>`;
    }

    const g = id => document.getElementById(id);

    const tbl = PagedTable.init({
        tableId: 'tbl-logs',
        url: '/Logs/IndexData',
        pageSize: 50,
        defaultSort: { col: 'timestamp', dir: 'desc' },
        filters: () => ({
            source:   g('f-source').value,
            level:    g('f-level').value,
            category: g('f-category').value,
            from:     g('f-from').value,
            to:       g('f-to').value,
            search:   g('f-search').value
        }),
        paginationId: 'tbl-logs-pagination',
        columns: [
            { key: 'timestamp', label: 'Timestamp', thClass: 'ps-3', tdClass: 'ps-3 align-middle text-muted', render: r => `<span style="white-space:nowrap;">${r.timestamp}</span>` },
            { key: 'level',     label: 'Level',     tdClass: 'align-middle', render: r => levelBadge(r.level) },
            { key: 'category',  label: 'Category',  tdClass: 'align-middle', render: r => catBadge(r.category) },
            { key: 'source',    label: 'Source',    tdClass: 'align-middle text-muted' },
            { key: 'message',   label: 'Message',   sortable: false, tdClass: 'align-middle', render: r => `<div class="text-truncate" style="max-width:400px;" title="${r.message.replace(/"/g,'&quot;')}">${r.message}</div>${r.action ? `<div class="text-muted" style="font-size:10px;">${r.action}</div>` : ''}` },
            { key: 'userEmail', label: 'User',      tdClass: 'align-middle text-muted text-truncate', render: r => `<span style="max-width:140px;display:block;overflow:hidden;text-overflow:ellipsis;">${r.userEmail}</span>` },
            { key: null, label: '', sortable: false, thClass: 'pe-3', tdClass: 'pe-3 align-middle',
              render: r => `<a href="/Logs/Details/${r.id}" class="btn btn-outline-secondary btn-sm" style="padding:1px 6px;"><i class="bi bi-eye"></i></a>` }
        ]
    });

    g('btn-filter').addEventListener('click', () => tbl.reload());
    g('btn-clear').addEventListener('click', () => {
        ['f-source','f-level','f-category','f-from','f-to','f-search'].forEach(id => { const el = g(id); if(el) el.value = ''; });
        tbl.reload();
    });
})();
</script>
}
