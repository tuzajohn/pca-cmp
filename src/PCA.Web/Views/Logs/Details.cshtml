@model PCA.Web.Models.AppLog
@{
    ViewData["Title"] = "Log Entry";
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Log Entry #@Model.Id</h1>
        <p class="page-header-sub mb-0">@Model.Timestamp.ToString("dd MMM yyyy HH:mm:ss UTC")</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i> Back
    </a>
</div>

<div class="row g-3">
    <div class="col-lg-8">
        <div class="form-section">
            <div class="form-section-header"><i class="bi bi-journal-text"></i> Log Details</div>
            <div class="form-section-body">
                <div class="row g-3 mb-3">
                    <div class="col-sm-3">
                        <div class="text-muted" style="font-size:11px;text-transform:uppercase;letter-spacing:.05em;">Level</div>
                        @{ string lvlCls = Model.Level switch { "Error" => "bg-danger", "Critical" => "bg-dark", "Warning" => "bg-warning text-dark", _ => "bg-secondary" }; }
                        <span class="badge @lvlCls">@Model.Level</span>
                    </div>
                    <div class="col-sm-3">
                        <div class="text-muted" style="font-size:11px;text-transform:uppercase;letter-spacing:.05em;">Category</div>
                        <div style="font-size:13px;">@Model.Category</div>
                    </div>
                    <div class="col-sm-6">
                        <div class="text-muted" style="font-size:11px;text-transform:uppercase;letter-spacing:.05em;">Source</div>
                        <div style="font-size:13px;">@Model.Source</div>
                    </div>
                </div>

                <div class="mb-3">
                    <div class="text-muted" style="font-size:11px;text-transform:uppercase;letter-spacing:.05em;">Message</div>
                    <div style="font-size:14px;white-space:pre-wrap;">@Model.Message</div>
                </div>

                @if (!string.IsNullOrEmpty(Model.Action))
                {
                    <div class="mb-3">
                        <div class="text-muted" style="font-size:11px;text-transform:uppercase;letter-spacing:.05em;">Action / Logger</div>
                        <div style="font-size:13px;font-family:monospace;">@Model.Action</div>
                    </div>
                }

                @if (!string.IsNullOrEmpty(Model.Details))
                {
                    <div class="mb-3">
                        <div class="text-muted" style="font-size:11px;text-transform:uppercase;letter-spacing:.05em;">Details / Stack Trace</div>
                        <pre style="font-size:11px;background:#f8f9fa;padding:12px;border-radius:8px;overflow-x:auto;white-space:pre-wrap;border:1px solid var(--bs-border-color);">@Model.Details</pre>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card">
            <div class="card-header"><i class="bi bi-person me-2"></i>Context</div>
            <div class="card-body" style="font-size:13px;">
                <div class="mb-2">
                    <span class="text-muted">User:</span> @(Model.UserEmail ?? "—")
                </div>
                @if (!string.IsNullOrEmpty(Model.EntityType))
                {
                    <div class="mb-2">
                        <span class="text-muted">Entity:</span> @Model.EntityType @(Model.EntityId.HasValue ? $"#{Model.EntityId}" : "")
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.IpAddress))
                {
                    <div class="mb-2">
                        <span class="text-muted">IP:</span> @Model.IpAddress
                    </div>
                }
                <div class="mt-3 pt-3 border-top text-muted" style="font-size:11px;">
                    <div>Logged: @Model.Timestamp.ToString("dd MMM yyyy HH:mm:ss") UTC</div>
                </div>
            </div>
        </div>
    </div>
</div>
