@model ChangeRequestCreateViewModel
@{
    ViewData["Title"] = "New Change Request";
}

<h2 class="mb-4"><i class="bi bi-plus-circle"></i> New Change Request</h2>

<div class="row">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label fw-semibold"></label>
                        <input asp-for="Title" class="form-control" placeholder="Brief description of the change" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-semibold"></label>
                        <textarea asp-for="Description" class="form-control" rows="5" placeholder="Detailed description, justification, and impact..."></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="Type" class="form-label fw-semibold"></label>
                            <select asp-for="Type" asp-items="Html.GetEnumSelectList<ChangeType>()" class="form-select"></select>
                            <span asp-validation-for="Type" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="Priority" class="form-label fw-semibold"></label>
                            <select asp-for="Priority" asp-items="Html.GetEnumSelectList<Priority>()" class="form-select"></select>
                            <span asp-validation-for="Priority" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="TargetDate" class="form-label fw-semibold"></label>
                            <input asp-for="TargetDate" class="form-control" type="date" />
                            <span asp-validation-for="TargetDate" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Save as Draft</button>
                        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
