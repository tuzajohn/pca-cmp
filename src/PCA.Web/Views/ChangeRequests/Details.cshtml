@model ChangeRequest
@using PCA.Modules.Approvals.Models
@using PCA.Shared.Enums
@{
    ViewData["Title"] = Model.SerialNumber.Length > 0 ? Model.SerialNumber : $"CR #{Model.Id}";
    var steps = ViewBag.ApprovalSteps as List<ApprovalStep> ?? new();
    var currentUserId = ViewBag.CurrentUserId as string;
    var myPendingStep = steps.FirstOrDefault(s => s.ApproverId == currentUserId && s.Status == ApprovalStatus.Pending);

    string StatusCls(ChangeStatus st) => st switch {
        ChangeStatus.Draft => "status-draft",
        ChangeStatus.Submitted => "status-submitted",
        ChangeStatus.UnderReview => "status-underreview",
        ChangeStatus.Approved => "status-approved",
        ChangeStatus.Rejected => "status-rejected",
        ChangeStatus.Implemented => "status-implemented",
        ChangeStatus.Closed => "status-closed",
        _ => ""
    };
    string PriCls(Priority p) => p switch {
        Priority.Low => "priority-low",
        Priority.Medium => "priority-medium",
        Priority.High => "priority-high",
        Priority.Critical => "priority-critical",
        _ => ""
    };
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">
            @(string.IsNullOrEmpty(Model.SerialNumber) ? $"Change Request #{Model.Id}" : Model.SerialNumber)
        </h1>
        <div class="d-flex align-items-center gap-2 mt-1">
            <span class="status-badge @StatusCls(Model.Status)">@Model.Status</span>
            <span class="status-badge @PriCls(Model.Priority)">@Model.Priority Risk</span>
            <span class="status-badge status-submitted">@Model.Type</span>
            <span class="text-muted small">Created @Model.CreatedAt.ToString("dd MMM yyyy")</span>
        </div>
    </div>
    <div class="d-flex gap-2">
        @if (Model.Status == ChangeStatus.Draft)
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm">
                <i class="bi bi-pencil me-1"></i> Edit
            </a>
            <form asp-action="Submit" asp-route-id="@Model.Id" method="post" class="d-inline">
                <button type="submit" class="btn btn-primary btn-sm"
                    onclick="return confirm('Submit this CR for approval?')">
                    <i class="bi bi-send me-1"></i> Submit for Approval
                </button>
            </form>
        }
        @if (User.IsInRole("Admin") && Model.Status == ChangeStatus.Approved)
        {
            <form asp-action="MarkImplemented" asp-route-id="@Model.Id" method="post" class="d-inline">
                <button type="submit" class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-gear me-1"></i> Mark Implemented
                </button>
            </form>
        }
        @if (User.IsInRole("Admin") && Model.Status == ChangeStatus.Implemented)
        {
            <a asp-action="Pir" asp-route-id="@Model.Id" class="btn btn-primary btn-sm">
                <i class="bi bi-clipboard2-check me-1"></i> Post-Implementation Review
            </a>
        }
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i> Back</a>
    </div>
</div>

<!-- My approval action banner -->
@if (myPendingStep != null)
{
    <div class="card border-0 mb-4" style="background:color-mix(in srgb,var(--color-primary) 8%,transparent);border-left:4px solid var(--color-primary) !important;border-radius:10px;">
        <div class="card-body d-flex align-items-center justify-content-between gap-3">
            <div>
                <i class="bi bi-bell-fill me-2" style="color:var(--color-primary);"></i>
                <strong>Your approval is required</strong> — Step @myPendingStep.Order
            </div>
            <div class="d-flex gap-2">
                <form asp-controller="Approvals" asp-action="Approve" method="post" class="d-inline">
                    <input type="hidden" name="stepId" value="@myPendingStep.Id" />
                    <input type="hidden" name="changeRequestId" value="@Model.Id" />
                    <input name="comment" class="form-control form-control-sm d-inline-block" style="width:200px;"
                           placeholder="Optional comment…" />
                    <button type="submit" class="btn btn-sm btn-success ms-1">
                        <i class="bi bi-check-lg me-1"></i> Approve
                    </button>
                </form>
                <form asp-controller="Approvals" asp-action="Reject" method="post" class="d-inline">
                    <input type="hidden" name="stepId" value="@myPendingStep.Id" />
                    <input type="hidden" name="changeRequestId" value="@Model.Id" />
                    <input name="comment" class="form-control form-control-sm d-inline-block" style="width:200px;"
                           placeholder="Reason for rejection…" required />
                    <button type="submit" class="btn btn-sm btn-danger ms-1">
                        <i class="bi bi-x-lg me-1"></i> Reject
                    </button>
                </form>
            </div>
        </div>
    </div>
}

<div class="row g-3">
    <div class="col-lg-8">

        <!-- Section A: Change Information -->
        <div class="form-section">
            <div class="form-section-header"><i class="bi bi-info-circle"></i> A. Change Information</div>
            <div class="form-section-body">
                <table class="detail-table">
                    <tr><td>CR Number</td><td><code style="color:var(--color-primary);">@(string.IsNullOrEmpty(Model.SerialNumber) ? "Not yet assigned (Draft)" : Model.SerialNumber)</code></td></tr>
                    <tr><td>Date Submitted</td><td>@(Model.Status == ChangeStatus.Draft ? "—" : Model.UpdatedAt.ToString("dd MMM yyyy HH:mm"))</td></tr>
                    <tr><td>Change Title</td><td class="fw-semibold">@Model.Title</td></tr>
                    <tr><td>Initiator</td><td>@(Model.RequestedBy?.FullName ?? Model.RequestedBy?.UserName ?? "—")</td></tr>
                    <tr><td>Department</td><td>@(Model.RequestedBy?.Department ?? "—")</td></tr>
                    <tr><td>Category</td><td><span class="status-badge status-submitted">@Model.Type</span></td></tr>
                    <tr><td>Description</td><td style="white-space:pre-wrap;">@Model.Description</td></tr>
                    <tr><td>Systems Affected</td><td>@(Model.SystemsAffected ?? "—")</td></tr>
                    <tr><td>Impact on Users</td><td>@(Model.ImpactOnUsers ?? "—")</td></tr>
                    <tr><td>Risk Assessment</td><td><span class="status-badge @PriCls(Model.Priority)">@Model.Priority</span> @(Model.RiskDescription != null ? "— " + Model.RiskDescription : "")</td></tr>
                </table>
            </div>
        </div>

        <!-- Section B: Implementation -->
        <div class="form-section">
            <div class="form-section-header"><i class="bi bi-calendar-check"></i> B. Implementation Plan</div>
            <div class="form-section-body">
                <table class="detail-table">
                    <tr><td>Target Date</td><td>@(Model.TargetDate?.ToString("dd MMM yyyy") ?? "—")</td></tr>
                    <tr><td>Implementation Window</td><td>@(Model.ProposedImplementationWindow ?? "—")</td></tr>
                    <tr><td>Testing / Verification</td><td style="white-space:pre-wrap;">@(Model.TestingSteps ?? "—")</td></tr>
                    <tr><td>Staging Tested?</td><td>@(Model.StagingTested?.ToString() ?? "—")</td></tr>
                    <tr><td>Implementation Notes</td><td style="white-space:pre-wrap;">@(Model.ImplementationNotes ?? "—")</td></tr>
                </table>
            </div>
        </div>

        <!-- Section C: Rollback -->
        <div class="form-section">
            <div class="form-section-header"><i class="bi bi-arrow-counterclockwise"></i> C. Rollback Plan</div>
            <div class="form-section-body">
                <table class="detail-table">
                    <tr><td>Rollback Plan</td><td style="white-space:pre-wrap;">@(Model.RollbackPlan ?? "—")</td></tr>
                    <tr><td>Rollback Trigger / Window</td><td>@(Model.RollbackTrigger ?? "—")</td></tr>
                </table>
            </div>
        </div>

        <!-- Section D: Post-Implementation Review -->
        @if (Model.Status == ChangeStatus.Closed && Model.PirOutcome.HasValue)
        {
            var outcomeStyle = Model.PirOutcome switch {
                ImplementationOutcome.Successful          => "background:#f0fdf4;color:#15803d;border-color:#86efac;",
                ImplementationOutcome.PartiallySuccessful => "background:#fef9c3;color:#854d0e;border-color:#fde047;",
                ImplementationOutcome.Failed              => "background:#fef2f2;color:#b91c1c;border-color:#fca5a5;",
                ImplementationOutcome.RolledBack          => "background:#fff7ed;color:#c2410c;border-color:#fdba74;",
                _ => ""
            };
            var outcomeIcon = Model.PirOutcome switch {
                ImplementationOutcome.Successful          => "bi-check-circle-fill",
                ImplementationOutcome.PartiallySuccessful => "bi-exclamation-circle-fill",
                ImplementationOutcome.Failed              => "bi-x-circle-fill",
                ImplementationOutcome.RolledBack          => "bi-arrow-counterclockwise",
                _ => "bi-circle"
            };
            <div class="form-section">
                <div class="form-section-header">
                    <i class="bi bi-clipboard2-check"></i> D. Post-Implementation Review (PIR)
                    <span class="ms-auto status-badge" style="@outcomeStyle border:1px solid;font-size:12px;">
                        <i class="bi @outcomeIcon me-1"></i>@Model.PirOutcome?.ToString().Replace("Partially", "Partially ")
                    </span>
                </div>
                <div class="form-section-body">
                    <table class="detail-table">
                        <tr><td>Outcome</td><td><span class="status-badge" style="@outcomeStyle border:1px solid;"><i class="bi @outcomeIcon me-1"></i>@Model.PirOutcome?.ToString().Replace("Partially", "Partially ")</span></td></tr>
                        <tr><td>Actual Implementation Date</td><td>@(Model.PirActualDate?.ToString("dd MMM yyyy") ?? "—")</td></tr>
                        <tr><td>Rollback Executed</td><td>@(Model.PirRollbackExecuted == true ? "Yes" : "No")</td></tr>
                        <tr><td>Issues Encountered</td><td style="white-space:pre-wrap;">@(string.IsNullOrEmpty(Model.PirIssuesEncountered) ? "None reported" : Model.PirIssuesEncountered)</td></tr>
                        <tr><td>Lessons Learned</td><td style="white-space:pre-wrap;">@(string.IsNullOrEmpty(Model.PirLessonsLearned) ? "—" : Model.PirLessonsLearned)</td></tr>
                        <tr><td>Closure Notes</td><td style="white-space:pre-wrap;">@(string.IsNullOrEmpty(Model.PirClosureNotes) ? "—" : Model.PirClosureNotes)</td></tr>
                        <tr><td>Completed By</td><td>@(Model.PirCompletedBy?.FullName ?? Model.PirCompletedBy?.UserName ?? "—")</td></tr>
                    </table>
                </div>
            </div>
        }
        else if (Model.Status == ChangeStatus.Implemented)
        {
            <div class="form-section" style="border-color:color-mix(in srgb,var(--color-primary) 30%,transparent);">
                <div class="form-section-body d-flex align-items-center gap-3 py-3">
                    <i class="bi bi-clipboard2-check fs-4" style="color:var(--color-primary);"></i>
                    <div>
                        <div class="fw-semibold" style="font-size:13.5px;">Post-Implementation Review Required</div>
                        <div class="text-muted small">Complete the PIR to formally close this change request.</div>
                    </div>
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Pir" asp-route-id="@Model.Id" class="btn btn-primary btn-sm ms-auto">
                            <i class="bi bi-pencil-square me-1"></i> Complete PIR
                        </a>
                    }
                </div>
            </div>
        }

        <!-- Comments -->
        <div class="form-section">
            <div class="form-section-header"><i class="bi bi-chat-dots"></i> Comments (@Model.Comments.Count)</div>
            <div class="form-section-body">
                @if (!Model.Comments.Any())
                {
                    <p class="text-muted small mb-3">No comments yet.</p>
                }
                else
                {
                    <div class="d-flex flex-column gap-3 mb-4">
                        @foreach (var c in Model.Comments.OrderBy(x => x.CreatedAt))
                        {
                            <div class="d-flex gap-3 align-items-start">
                                <div class="avatar" style="width:32px;height:32px;border-radius:50%;background:var(--color-primary);color:#fff;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;flex-shrink:0;">
                                    @(c.Author?.UserName?.Length >= 2 ? c.Author.UserName[..2].ToUpper() : "?")
                                </div>
                                <div style="flex:1;">
                                    <div class="fw-semibold" style="font-size:13px;">@(c.Author?.FullName ?? c.Author?.UserName)</div>
                                    <div class="text-muted" style="font-size:11px;">@c.CreatedAt.ToString("dd MMM yyyy HH:mm")</div>
                                    <div class="mt-1" style="font-size:13.5px;">@c.Content</div>
                                </div>
                            </div>
                        }
                    </div>
                }
                <form asp-action="AddComment" asp-route-id="@Model.Id" method="post">
                    <div class="d-flex gap-2">
                        <input name="content" class="form-control" placeholder="Add a comment…" required />
                        <button type="submit" class="btn btn-primary btn-sm px-3">
                            <i class="bi bi-send"></i>
                        </button>
                    </div>
                </form>
            </div>
        </div>

        @await Html.PartialAsync("_AttachmentsPanel", (object)null!, new ViewDataDictionary(ViewData)
        {
            ["Controller"] = "ChangeRequests",
            ["EntityId"] = Model.Id,
            ["Attachments"] = ViewBag.Attachments,
            ["CurrentUserId"] = currentUserId,
            ["IsAdmin"] = User.IsInRole("Admin")
        })

    </div>

    <!-- Right: Approval timeline + meta -->
    <div class="col-lg-4">
        <div class="card mb-3">
            <div class="card-header"><i class="bi bi-check2-circle me-2"></i>Approval Flow</div>
            <div class="card-body">
                @if (!steps.Any())
                {
                    <p class="text-muted small mb-0">
                        <i class="bi bi-info-circle me-1"></i>
                        Approval steps will appear after submission.
                    </p>
                }
                else
                {
                    <div class="approval-timeline">
                        @foreach (var step in steps.OrderBy(s => s.Order))
                        {
                            var dotCls = step.Status switch {
                                ApprovalStatus.Approved => "approved",
                                ApprovalStatus.Rejected => "rejected",
                                _ => "pending"
                            };
                            var icon = step.Status switch {
                                ApprovalStatus.Approved => "bi-check-lg",
                                ApprovalStatus.Rejected => "bi-x-lg",
                                _ => "bi-hourglass-split"
                            };
                            <div class="approval-step">
                                <div class="step-dot @dotCls"><i class="bi @icon"></i></div>
                                <div class="step-content">
                                    <div class="step-title">Step @step.Order</div>
                                    <div class="step-meta">
                                        @step.Status
                                        @if (step.ActedAt.HasValue)
                                        {
                                            <span>· @step.ActedAt.Value.ToString("dd MMM yyyy")</span>
                                        }
                                    </div>
                                    @if (!string.IsNullOrEmpty(step.Comment))
                                    {
                                        <div class="mt-1 p-2 rounded" style="background:#f9fafb;font-size:12px;color:#374151;">
                                            "@step.Comment"
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="card">
            <div class="card-header"><i class="bi bi-file-text me-2"></i>Approval Decision</div>
            <div class="card-body">
                <div class="status-badge @StatusCls(Model.Status) w-100 justify-content-center py-2 mb-2">
                    @Model.Status
                </div>
                <table class="detail-table">
                    <tr><td>Review Date</td><td>@(Model.UpdatedAt.ToString("dd MMM yyyy"))</td></tr>
                </table>
            </div>
        </div>
    </div>
</div>
