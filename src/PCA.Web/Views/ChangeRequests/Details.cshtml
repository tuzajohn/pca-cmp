@model ChangeRequest
@using PCA.Modules.Approvals.Models
@{
    ViewData["Title"] = $"CR: {Model.SerialNumber}";
    var steps = ViewBag.ApprovalSteps as List<ApprovalStep> ?? new List<ApprovalStep>();
    var currentUserId = ViewBag.CurrentUserId as string;
    var canEdit = Model.Status == ChangeStatus.Draft && (Model.RequestedById == currentUserId || User.IsInRole("Admin"));
}

<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h2><i class="bi bi-ticket-detailed"></i>
            @(string.IsNullOrEmpty(Model.SerialNumber) ? $"Draft CR #{Model.Id}" : Model.SerialNumber)
        </h2>
        <p class="text-muted mb-0">@Model.Title</p>
    </div>
    <div class="d-flex gap-2">
        @if (canEdit)
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary">
                <i class="bi bi-pencil"></i> Edit
            </a>
        }
        @if (Model.Status == ChangeStatus.Draft && Model.RequestedById == currentUserId)
        {
            <form asp-action="Submit" asp-route-id="@Model.Id" method="post">
                <button type="submit" class="btn btn-success" onclick="return confirm('Submit this change request for approval?')">
                    <i class="bi bi-send"></i> Submit
                </button>
            </form>
        }
        @if (Model.Status == ChangeStatus.Approved && User.IsInRole("Admin"))
        {
            <form asp-action="MarkImplemented" asp-route-id="@Model.Id" method="post">
                <button type="submit" class="btn btn-warning">
                    <i class="bi bi-gear"></i> Mark Implemented
                </button>
            </form>
        }
        @if (Model.Status == ChangeStatus.Implemented && User.IsInRole("Admin"))
        {
            <form asp-action="Close" asp-route-id="@Model.Id" method="post">
                <button type="submit" class="btn btn-dark">
                    <i class="bi bi-archive"></i> Close
                </button>
            </form>
        }
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card mb-4">
            <div class="card-header"><strong>Details</strong></div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-3">Status</dt>
                    <dd class="col-sm-9"><span class="badge bg-secondary fs-6">@Model.Status</span></dd>

                    <dt class="col-sm-3">Type</dt>
                    <dd class="col-sm-9"><span class="badge bg-info text-dark">@Model.Type</span></dd>

                    <dt class="col-sm-3">Priority</dt>
                    <dd class="col-sm-9">
                        @{
                            var pColor = Model.Priority switch {
                                Priority.Critical => "danger",
                                Priority.High => "warning",
                                Priority.Medium => "primary",
                                _ => "secondary"
                            };
                        }
                        <span class="badge bg-@pColor">@Model.Priority</span>
                    </dd>

                    <dt class="col-sm-3">Requested By</dt>
                    <dd class="col-sm-9">@Model.RequestedBy?.FullName (@Model.RequestedBy?.Department)</dd>

                    <dt class="col-sm-3">Created</dt>
                    <dd class="col-sm-9">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm") UTC</dd>

                    @if (Model.TargetDate.HasValue)
                    {
                        <dt class="col-sm-3">Target Date</dt>
                        <dd class="col-sm-9">@Model.TargetDate.Value.ToString("yyyy-MM-dd")</dd>
                    }

                    <dt class="col-sm-3">Description</dt>
                    <dd class="col-sm-9" style="white-space: pre-wrap">@Model.Description</dd>

                    @if (!string.IsNullOrEmpty(Model.ImplementationNotes))
                    {
                        <dt class="col-sm-3">Impl. Notes</dt>
                        <dd class="col-sm-9" style="white-space: pre-wrap">@Model.ImplementationNotes</dd>
                    }
                </dl>
            </div>
        </div>

        @if (steps.Any())
        {
            <div class="card mb-4">
                <div class="card-header"><strong><i class="bi bi-diagram-3"></i> Approval Flow</strong></div>
                <div class="card-body p-0">
                    <table class="table mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Step</th>
                                <th>Approver</th>
                                <th>Status</th>
                                <th>Comment</th>
                                <th>Acted At</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var step in steps)
                            {
                                var statusColor = step.Status switch {
                                    ApprovalStatus.Approved => "success",
                                    ApprovalStatus.Rejected => "danger",
                                    _ => "warning"
                                };
                                <tr>
                                    <td>@step.Order</td>
                                    <td>@step.Approver?.FullName</td>
                                    <td><span class="badge bg-@statusColor">@step.Status</span></td>
                                    <td>@step.Comment</td>
                                    <td>@(step.ActedAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                                    <td>
                                        @if (step.Status == ApprovalStatus.Pending && step.ApproverId == currentUserId)
                                        {
                                            <div class="d-flex gap-1">
                                                <form asp-controller="Approvals" asp-action="Approve" method="post" class="d-inline">
                                                    <input type="hidden" name="stepId" value="@step.Id" />
                                                    <input type="hidden" name="changeRequestId" value="@Model.Id" />
                                                    <input type="text" name="comment" class="form-control form-control-sm d-inline" style="width:120px" placeholder="Comment (opt)" />
                                                    <button type="submit" class="btn btn-sm btn-success">Approve</button>
                                                </form>
                                                <form asp-controller="Approvals" asp-action="Reject" method="post" class="d-inline">
                                                    <input type="hidden" name="stepId" value="@step.Id" />
                                                    <input type="hidden" name="changeRequestId" value="@Model.Id" />
                                                    <input type="text" name="comment" class="form-control form-control-sm d-inline" style="width:120px" placeholder="Reason (req)" />
                                                    <button type="submit" class="btn btn-sm btn-danger">Reject</button>
                                                </form>
                                            </div>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        <div class="card">
            <div class="card-header"><strong><i class="bi bi-chat-dots"></i> Comments</strong></div>
            <div class="card-body">
                @if (!Model.Comments.Any())
                {
                    <p class="text-muted">No comments yet.</p>
                }
                else
                {
                    foreach (var comment in Model.Comments.OrderBy(c => c.CreatedAt))
                    {
                        <div class="border rounded p-2 mb-2 bg-light">
                            <div class="d-flex justify-content-between">
                                <strong>@comment.Author?.FullName</strong>
                                <small class="text-muted">@comment.CreatedAt.ToString("yyyy-MM-dd HH:mm")</small>
                            </div>
                            <p class="mb-0 mt-1">@comment.Content</p>
                        </div>
                    }
                }

                <form asp-action="AddComment" asp-route-id="@Model.Id" method="post" class="mt-3">
                    <div class="input-group">
                        <input type="text" name="content" class="form-control" placeholder="Add a comment..." required />
                        <button type="submit" class="btn btn-outline-secondary"><i class="bi bi-send"></i></button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
