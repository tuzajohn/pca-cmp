@model List<ChangeRequest>
@{
    ViewData["Title"] = "Change Requests";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-ticket-detailed"></i> Change Requests</h2>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> New Request</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No change requests found.</div>
}
else
{
    <div class="card">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Serial #</th>
                        <th>Title</th>
                        <th>Type</th>
                        <th>Priority</th>
                        <th>Status</th>
                        <th>Requested By</th>
                        <th>Created</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cr in Model)
                    {
                        <tr>
                            <td><code>@(string.IsNullOrEmpty(cr.SerialNumber) ? $"Draft-{cr.Id}" : cr.SerialNumber)</code></td>
                            <td>@cr.Title</td>
                            <td><span class="badge bg-info text-dark">@cr.Type</span></td>
                            <td>
                                @{
                                    var pColor = cr.Priority switch {
                                        Priority.Critical => "danger",
                                        Priority.High => "warning",
                                        Priority.Medium => "primary",
                                        _ => "secondary"
                                    };
                                }
                                <span class="badge bg-@pColor">@cr.Priority</span>
                            </td>
                            <td><span class="badge bg-secondary">@cr.Status</span></td>
                            <td>@cr.RequestedBy?.FullName</td>
                            <td>@cr.CreatedAt.ToString("yyyy-MM-dd")</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@cr.Id" class="btn btn-sm btn-outline-primary">View</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
