@using PCA.Shared.Enums
@{
    ViewData["Title"] = "Change Requests";
    var statusFilter = ViewBag.StatusFilter as string;
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Change Requests</h1>
        <p class="page-header-sub mb-0">Manage change requests and implementation workflows</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> New Change Request
    </a>
</div>

<div class="card mb-3">
    <div class="card-body py-2">
        <form id="filter-form" class="d-flex flex-wrap gap-2 align-items-center">
            <select name="status" id="f-status" class="form-select form-select-sm" style="width:auto;">
                <option value="">All Statuses</option>
                @foreach (var s in Enum.GetValues<ChangeStatus>())
                {
                    <option value="@s" selected="@(s.ToString() == statusFilter)">@s</option>
                }
            </select>
            <button class="btn btn-outline-secondary btn-sm" type="submit">Filter</button>
            <button class="btn btn-outline-secondary btn-sm" type="button" id="btn-clear">Clear</button>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <table id="dt-cr" class="table mb-0" style="font-size:13px;">
            <thead>
                <tr>
                    <th class="ps-3">Serial #</th>
                    <th>Title</th>
                    <th>Requested By</th>
                    <th>Type</th>
                    <th>Status</th>
                    <th>Priority</th>
                    <th>Target Date</th>
                    <th>Created</th>
                    <th class="pe-3"></th>
                </tr>
            </thead>
        </table>
    </div>
</div>

@section Scripts {
<script>
(function () {
    const statusBadge = d => `<span class="status-badge status-${d.toLowerCase()}">${d}</span>`;

    const table = new DataTable('#dt-cr', {
        serverSide: true,
        processing: true,
        searching: false,
        pageLength: 25,
        order: [[7, 'desc']],
        ajax: {
            url: '/ChangeRequests/Data',
            data: d => {
                d.status = document.getElementById('f-status').value;
            }
        },
        columns: [
            { data: 'serial',      className: 'ps-3', render: (v, _, r) => `<a href="/ChangeRequests/Details/${r.id}" class="fw-semibold text-decoration-none">${v || '#' + r.id}</a>` },
            { data: 'title' },
            { data: 'requestedBy', defaultContent: '—' },
            { data: 'type',        render: statusBadge },
            { data: 'status',      render: statusBadge },
            { data: 'priority',    render: statusBadge },
            { data: 'targetDate',  render: (v, _, r) => v ? (r.targetOverdue ? `<span class="text-danger fw-semibold">${v}</span>` : v) : '—' },
            { data: 'createdAt' },
            { data: 'id', orderable: false, className: 'pe-3 text-end',
              render: id => `<a href="/ChangeRequests/Details/${id}" class="btn btn-sm btn-outline-secondary" style="padding:2px 8px;"><i class="bi bi-eye"></i></a>` }
        ]
    });

    document.getElementById('filter-form').addEventListener('submit', e => { e.preventDefault(); table.ajax.reload(); });
    document.getElementById('btn-clear').addEventListener('click', () => {
        document.getElementById('f-status').value = '';
        table.ajax.reload();
    });
})();
</script>
}
