@model PCA.Shared.PagedResult<PCA.Modules.ChangeManagement.Models.ChangeRequest>
@using PCA.Shared.Enums
@{
    ViewData["Title"] = "Change Requests";
    var statusFilter = ViewBag.StatusFilter as string;
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Change Requests</h1>
        <p class="page-header-sub mb-0">@Model.TotalCount total change request(s)</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> New Change Request
    </a>
</div>

<div class="card mb-3">
    <div class="card-body py-2">
        <form id="filter-form" method="get" class="d-flex flex-wrap gap-2 align-items-center">
            <select name="status" class="form-select form-select-sm" style="width:auto;">
                <option value="">All Statuses</option>
                @foreach (var s in Enum.GetValues<ChangeStatus>())
                {
                    <option value="@s" @(s.ToString() == statusFilter ? "selected" : "")>@s</option>
                }
            </select>
            <button class="btn btn-outline-secondary btn-sm" type="submit">Filter</button>
            @if (!string.IsNullOrEmpty(statusFilter))
            {
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Clear</a>
            }
        </form>
    </div>
</div>

<div class="card" id="list-container">
    @await Html.PartialAsync("_ChangeRequestList", Model)
</div>

@section Scripts {
<script>
(function () {
    const form = document.getElementById('filter-form');
    const container = document.getElementById('list-container');

    async function loadPage(url) {
        container.style.opacity = '0.5';
        const resp = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
        container.innerHTML = await resp.text();
        container.style.opacity = '1';
        history.pushState(null, '', url);
        bindPagination();
    }

    function bindPagination() {
        container.querySelectorAll('.pagination-link').forEach(a => {
            a.addEventListener('click', e => {
                e.preventDefault();
                const url = new URL(window.location.href);
                url.searchParams.set('page', a.dataset.page);
                loadPage(url.toString());
            });
        });
    }

    form.addEventListener('submit', e => {
        e.preventDefault();
        const url = new URL(window.location.pathname, window.location.origin);
        new FormData(form).forEach((v, k) => { if (v) url.searchParams.set(k, v); });
        url.searchParams.set('page', '1');
        loadPage(url.toString());
    });

    bindPagination();
})();
</script>
}
