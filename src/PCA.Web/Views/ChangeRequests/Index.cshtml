@using PCA.Shared.Enums
@{
    ViewData["Title"] = "Change Requests";
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Change Requests</h1>
        <p class="page-header-sub mb-0">Manage change requests and implementation workflows</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> New Change Request
    </a>
</div>

<div class="card mb-3">
    <div class="card-body py-2">
        <div class="d-flex flex-wrap gap-2 align-items-center">
            <select id="f-status" class="form-select form-select-sm" style="width:auto;">
                <option value="">All Statuses</option>
                @foreach (var s in Enum.GetValues<ChangeStatus>())
                {
                    <option value="@s">@s</option>
                }
            </select>
            <button class="btn btn-primary btn-sm" id="btn-filter">Filter</button>
            <button class="btn btn-outline-secondary btn-sm" id="btn-clear">Clear</button>
        </div>
    </div>
</div>

<div class="card">
    <div id="tbl-cr"></div>
</div>

@section Scripts {
<script>
(function () {
    const badge = d => `<span class="status-badge status-${d.toLowerCase()}">${d}</span>`;

    const tbl = PagedTable.init({
        tableId: 'tbl-cr',
        url: '/ChangeRequests/Data',
        pageSize: 20,
        defaultSort: { col: 'createdAt', dir: 'desc' },
        filters: () => ({ status: document.getElementById('f-status').value }),
        columns: [
            { key: 'serial',      label: 'Serial #',     thClass: 'ps-3', tdClass: 'ps-3 align-middle', render: r => `<a href="/ChangeRequests/Details/${r.id}" class="fw-semibold text-decoration-none">${r.serial}</a>` },
            { key: 'title',       label: 'Title',        tdClass: 'align-middle' },
            { key: 'requestedBy', label: 'Requested By', tdClass: 'align-middle text-muted' },
            { key: 'type',        label: 'Type',         tdClass: 'align-middle', render: r => badge(r.type) },
            { key: 'status',      label: 'Status',       tdClass: 'align-middle', render: r => badge(r.status) },
            { key: 'priority',    label: 'Priority',     tdClass: 'align-middle', render: r => badge(r.priority) },
            { key: 'targetDate',  label: 'Target Date',  tdClass: 'align-middle', render: r => r.targetDate ? (r.targetOverdue ? `<span class="text-danger fw-semibold">${r.targetDate}</span>` : r.targetDate) : '—' },
            { key: 'createdAt',   label: 'Created',      tdClass: 'align-middle text-muted' },
            { key: null, label: '', sortable: false, thClass: 'pe-3', tdClass: 'pe-3 align-middle text-end',
              render: r => `<a href="/ChangeRequests/Details/${r.id}" class="btn btn-sm btn-outline-secondary" style="padding:2px 8px;"><i class="bi bi-eye"></i></a>` }
        ]
    });

    document.getElementById('btn-filter').addEventListener('click', () => tbl.reload());
    document.getElementById('btn-clear').addEventListener('click', () => {
        document.getElementById('f-status').value = '';
        tbl.reload();
    });
})();
</script>
}
