@model List<PCA.Modules.AccessManagement.Models.AccessReview>
@using PCA.Shared.Enums
@{
    ViewData["Title"] = "Access Reviews";
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Access Reviews</h1>
        <p class="page-header-sub mb-0">Quarterly and semi-annual user access review campaigns</p>
    </div>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i> New Review Campaign
        </a>
    }
</div>

<div class="card">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-clipboard2-check" style="font-size:40px;opacity:.3;"></i>
                <p class="mt-3">No access review campaigns found.</p>
            </div>
        }
        else
        {
            <table class="table table-hover mb-0" style="font-size:13px;">
                <thead style="background:var(--bs-tertiary-bg);">
                    <tr>
                        <th class="ps-3">Title</th>
                        <th>Cycle</th>
                        <th>Period</th>
                        <th>Due Date</th>
                        <th>Progress</th>
                        <th>Status</th>
                        <th class="pe-3"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        var statusCls = r.Status switch {
                            AccessReviewStatus.Completed => "status-approved",
                            AccessReviewStatus.Overdue   => "status-rejected",
                            AccessReviewStatus.InProgress => "status-underreview",
                            _                            => "status-submitted"
                        };
                        var total = r.Entries.Count;
                        var done  = r.Entries.Count(e => e.Outcome != AccessReviewEntryOutcome.Pending);
                        var pct   = total > 0 ? (done * 100 / total) : 0;
                        var isOverdue = r.Status != AccessReviewStatus.Completed && r.DueDate < DateTime.UtcNow;
                        <tr>
                            <td class="ps-3 align-middle fw-semibold">
                                <a asp-action="Details" asp-route-id="@r.Id" class="text-decoration-none" style="color:inherit;">@r.Title</a>
                            </td>
                            <td class="align-middle">
                                <span class="badge @(r.Cycle == AccessReviewCycle.Quarterly ? "bg-primary" : "bg-info text-dark")" style="font-size:10px;">
                                    @r.Cycle
                                </span>
                            </td>
                            <td class="align-middle text-muted" style="white-space:nowrap;">
                                @r.ReviewPeriodStart.ToString("dd MMM") – @r.ReviewPeriodEnd.ToString("dd MMM yyyy")
                            </td>
                            <td class="align-middle @(isOverdue ? "text-danger fw-semibold" : "text-muted")" style="white-space:nowrap;">
                                @r.DueDate.ToString("dd MMM yyyy")
                                @if (isOverdue) { <i class="bi bi-exclamation-circle ms-1"></i> }
                            </td>
                            <td class="align-middle" style="min-width:120px;">
                                @if (total > 0)
                                {
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="progress flex-grow-1" style="height:6px;">
                                            <div class="progress-bar" role="progressbar" style="width:@pct%;background:var(--color-primary);"></div>
                                        </div>
                                        <span class="text-muted" style="font-size:11px;white-space:nowrap;">@done/@total</span>
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted">No entries</span>
                                }
                            </td>
                            <td class="align-middle">
                                <span class="status-badge @statusCls" style="font-size:10px;">
                                    @(isOverdue && r.Status != AccessReviewStatus.Completed ? "Overdue" : r.Status.ToString())
                                </span>
                            </td>
                            <td class="pe-3 align-middle">
                                <a asp-action="Details" asp-route-id="@r.Id" class="btn btn-outline-primary btn-sm" style="padding:2px 8px;font-size:11px;">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
