@model PCA.Modules.AccessManagement.Models.AccessReview
@using PCA.Shared.Enums
@{
    ViewData["Title"] = Model.Title;
    var isAdmin = User.IsInRole("Admin");
    var currentUserId = ViewBag.CurrentUserId as string;
    var canUpdate = Model.Status != AccessReviewStatus.Completed && (isAdmin || User.IsInRole("Approver"));
    var statusCls = Model.Status switch {
        AccessReviewStatus.Completed  => "status-approved",
        AccessReviewStatus.Overdue    => "status-rejected",
        AccessReviewStatus.InProgress => "status-underreview",
        _                             => "status-submitted"
    };
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">@Model.Title</h1>
        <p class="page-header-sub mb-0">
            <span class="status-badge @statusCls me-2">@Model.Status</span>
            @Model.Cycle · @Model.Year Q@Model.Quarter
            · Due @Model.DueDate.ToString("dd MMM yyyy")
        </p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i> Back
    </a>
</div>

<div class="row g-3">
    <div class="col-lg-8">

        <div class="form-section">
            <div class="form-section-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-people me-2"></i>Review Entries</span>
            </div>
            <div class="form-section-body p-0">
                <div id="dt-entries"></div>
            </div>
        </div>

    </div>
    <div class="col-lg-4">
        <div class="card position-sticky" style="top:80px;">
            <div class="card-header"><i class="bi bi-info-circle me-2"></i>Campaign Info</div>
            <div class="card-body" style="font-size:13px;">
                <div class="mb-2">
                    <div class="text-muted" style="font-size:11px;text-transform:uppercase;letter-spacing:.05em;">Period</div>
                    <div>@Model.ReviewPeriodStart.ToString("dd MMM yyyy") – @Model.ReviewPeriodEnd.ToString("dd MMM yyyy")</div>
                </div>
                <div class="mb-2">
                    <div class="text-muted" style="font-size:11px;text-transform:uppercase;letter-spacing:.05em;">Created By</div>
                    <div>@(Model.CreatedBy?.FullName ?? "—")</div>
                </div>
                @if (!string.IsNullOrEmpty(Model.Notes))
                {
                    <div class="mb-2">
                        <div class="text-muted" style="font-size:11px;text-transform:uppercase;letter-spacing:.05em;">Notes</div>
                        <div style="white-space:pre-wrap;">@Model.Notes</div>
                    </div>
                }
                @if (Model.CompletedAt.HasValue)
                {
                    <div class="mb-2">
                        <div class="text-muted" style="font-size:11px;text-transform:uppercase;letter-spacing:.05em;">Completed</div>
                        <div>@Model.CompletedAt.Value.ToString("dd MMM yyyy HH:mm")</div>
                    </div>
                }
            </div>
            @if (isAdmin && Model.Status != AccessReviewStatus.Completed)
            {
                <div class="card-footer">
                    <form asp-action="Complete" asp-route-id="@Model.Id" method="post"
                          onsubmit="return confirm('Mark this review as complete?')">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-success btn-sm w-100">
                            <i class="bi bi-check2-all me-1"></i> Mark as Completed
                        </button>
                    </form>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    var reviewId = @Model.Id;
    var canUpdate = @Json.Serialize(canUpdate);
    var outcomeValues = @Json.Serialize(Enum.GetValues<AccessReviewEntryOutcome>().Select(o => o.ToString()).ToArray());
    var token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';

    PagedTable.init({
        tableId: 'dt-entries',
        tableClass: 'table table-sm mb-0',
        url: '/AccessReviews/EntriesData?id=' + reviewId,
        pageSize: 20,
        defaultSort: { col: 'employeeName', dir: 'asc' },
        columns: [
            { key: 'employeeName',  label: 'Employee',       thClass: 'ps-3', tdClass: 'ps-3 align-middle',
              render: r => `<span class="fw-semibold">${r.employeeName}</span>${r.department ? `<div class="text-muted fw-normal" style="font-size:11px;">${r.department}</div>` : ''}` },
            { key: 'systemName',    label: 'System',         tdClass: 'align-middle' },
            { key: 'currentAccess', label: 'Current Access', tdClass: 'align-middle', render: r => r.currentAccess || '<span class="text-muted">—</span>' },
            { key: 'outcome',       label: 'Outcome',        sortable: false, tdClass: 'align-middle',
              render: r => {
                  if (canUpdate) {
                      const opts = outcomeValues.map(o => `<option value="${o}"${r.outcome === o ? ' selected' : ''}>${o}</option>`).join('');
                      return `<form action="/AccessReviews/UpdateEntry/${reviewId}" method="post" class="d-flex gap-1">` +
                          `<input type="hidden" name="__RequestVerificationToken" value="${token}" />` +
                          `<input type="hidden" name="entryId" value="${r.entryId}" />` +
                          `<select name="outcome" class="form-select form-select-sm" style="width:auto;">${opts}</select>` +
                          `<button type="submit" class="btn btn-outline-primary btn-sm" style="padding:2px 8px;">Save</button></form>`;
                  }
                  const cls = { Retain: 'bg-success', Revoke: 'bg-danger', Modify: 'bg-warning text-dark' }[r.outcome] || 'bg-secondary';
                  return `<span class="badge ${cls}" style="font-size:10px;">${r.outcome}</span>`;
              } },
            { key: 'reviewedBy', label: 'Reviewed By', sortable: false, tdClass: 'align-middle text-muted', render: r => r.reviewedBy || '<span class="text-muted">—</span>' },
            { key: 'notes',      label: 'Notes',       sortable: false, thClass: 'pe-3', tdClass: 'pe-3 align-middle',
              render: r => r.notes ? `<span class="fst-italic text-muted" style="font-size:12px;">${r.notes}</span>` : '<span class="text-muted">—</span>' }
        ]
    });
})();
</script>
}
