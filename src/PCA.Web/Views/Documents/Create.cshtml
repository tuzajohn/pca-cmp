@model PCA.Web.Models.DocumentCreateViewModel
@{
    ViewData["Title"] = "New Document";
    var folders = ViewBag.Folders as List<PCA.Modules.Documents.Models.DocumentFolder> ?? new();
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">New Document</h1>
        <p class="page-header-sub mb-0">Upload a new document to the repository</p>
    </div>
    <a asp-action="Index" asp-route-folderId="@Model.FolderId" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i> Cancel
    </a>
</div>

<div class="row g-3">
    <div class="col-lg-8">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 mb-4 small"></div>

            <div class="form-section">
                <div class="form-section-header"><i class="bi bi-file-earmark-text"></i> Document Details</div>
                <div class="form-section-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="Title" class="form-label fw-semibold">Title <span class="text-danger">*</span></label>
                            <input asp-for="Title" class="form-control" placeholder="Document title" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Description" class="form-label">Description</label>
                            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Brief description of this document's content and purpose"></textarea>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="FolderId" class="form-label">Folder</label>
                            <select asp-for="FolderId" class="form-select">
                                <option value="">— Root (no folder) —</option>
                                @foreach (var f in folders.OrderBy(x => x.Name))
                                {
                                    <option value="@f.Id">@f.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Tags" class="form-label">Tags</label>
                            <input asp-for="Tags" class="form-control" placeholder="policy, HR, onboarding (comma-separated)" />
                            <div class="form-text">Separate tags with commas</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="form-section">
                <div class="form-section-header"><i class="bi bi-cloud-upload"></i> File Upload</div>
                <div class="form-section-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">File <span class="text-danger">*</span></label>
                        <div class="upload-zone" id="uploadZone">
                            <i class="bi bi-cloud-upload" style="font-size:36px;color:var(--color-primary);opacity:.7;"></i>
                            <p class="mb-1 mt-2" style="font-size:14px;font-weight:600;">Drag and drop or click to choose file</p>
                            <p class="text-muted mb-3" style="font-size:12px;">PDF, DOCX, XLSX, PPTX, TXT, CSV, PNG, JPG, ZIP — max 50 MB</p>
                            <input asp-for="File" type="file" id="fileInput" class="d-none" />
                            <button type="button" class="btn btn-outline-primary" onclick="document.getElementById('fileInput').click()">
                                <i class="bi bi-folder2-open me-1"></i> Browse Files
                            </button>
                            <div id="fileLabel" class="mt-3 fw-semibold" style="font-size:13px;color:var(--color-primary);"></div>
                        </div>
                        <span asp-validation-for="File" class="text-danger small"></span>
                    </div>
                    <div class="mb-0">
                        <label asp-for="ChangeNotes" class="form-label">Initial Version Notes</label>
                        <input asp-for="ChangeNotes" class="form-control" placeholder="e.g. Initial upload, version 1.0" />
                    </div>
                </div>
            </div>

            <div class="form-section">
                <div class="form-section-header"><i class="bi bi-calendar-check"></i> Review Schedule</div>
                <div class="form-section-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Review Period</label>
                            <select id="reviewPeriodSelect" class="form-select">
                                <option value="">— No scheduled review —</option>
                                <option value="30">Monthly (30 days)</option>
                                <option value="60">Every 2 months (60 days)</option>
                                <option value="90">Quarterly (90 days)</option>
                                <option value="180">Semi-annually (180 days)</option>
                                <option value="365">Annually (365 days)</option>
                                <option value="730">Every 2 years (730 days)</option>
                                <option value="custom">Custom…</option>
                            </select>
                            <input asp-for="ReviewPeriodDays" type="number" id="reviewPeriodCustom"
                                   class="form-control mt-2 d-none" placeholder="Enter days (1–3650)" min="1" max="3650" />
                            <div class="form-text">Sets how often this document must be reviewed.</div>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="NextReviewDate" class="form-label fw-semibold">Period Start Date</label>
                            <input asp-for="NextReviewDate" type="date" id="nextReviewDate" class="form-control" />
                            <div class="form-text" id="nextReviewHint">The first review will fall due one period after this date.</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check2 me-1"></i> Create Document
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<partial name="_ValidationScriptsPartial" />
<script>
const dropzone = document.getElementById('uploadZone');
const fileInput = document.getElementById('fileInput');
const fileLabel = document.getElementById('fileLabel');

dropzone.addEventListener('dragover', e => { e.preventDefault(); dropzone.classList.add('dragover'); });
dropzone.addEventListener('dragleave', () => dropzone.classList.remove('dragover'));
dropzone.addEventListener('drop', e => {
    e.preventDefault();
    dropzone.classList.remove('dragover');
    if (e.dataTransfer.files.length) {
        fileInput.files = e.dataTransfer.files;
        fileLabel.textContent = e.dataTransfer.files[0].name;
    }
});
fileInput.addEventListener('change', () => {
    fileLabel.textContent = fileInput.files[0]?.name ?? '';
});

// ── Review schedule ──────────────────────────────────────────────────────────
const periodSelect  = document.getElementById('reviewPeriodSelect');
const periodCustom  = document.getElementById('reviewPeriodCustom');
const periodHidden  = document.getElementById('ReviewPeriodDays');
const startDate     = document.getElementById('nextReviewDate');
const reviewHint    = document.getElementById('nextReviewHint');

function addDays(dateStr, days) {
    if (!dateStr) return '';
    const d = new Date(dateStr);
    d.setDate(d.getDate() + days);
    return d.toISOString().slice(0, 10);
}

function updateHint() {
    const days = parseInt(periodHidden.value);
    const start = startDate.value;
    if (!isNaN(days) && start) {
        reviewHint.textContent = `First review due: ${addDays(start, days)}`;
    } else {
        reviewHint.textContent = 'The first review will fall due one period after this date.';
    }
}

periodSelect.addEventListener('change', function () {
    if (this.value === 'custom') {
        periodCustom.classList.remove('d-none');
        periodHidden.value = '';
    } else {
        periodCustom.classList.add('d-none');
        periodHidden.value = this.value;
        if (this.value && !startDate.value)
            startDate.value = new Date().toISOString().slice(0, 10);
        if (!this.value) startDate.value = '';
    }
    updateHint();
});

periodCustom.addEventListener('input', function () {
    periodHidden.value = this.value;
    updateHint();
});

startDate.addEventListener('change', updateHint);
</script>
}
