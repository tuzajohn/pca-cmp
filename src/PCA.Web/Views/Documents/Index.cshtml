@model PCA.Web.Models.DocumentIndexViewModel
@using PCA.Shared.Enums
@using PCA.Modules.Documents.Models
@{
    ViewData["Title"] = "Document Repository";
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Document Repository</h1>
        <p class="page-header-sub mb-0">Browse, search and manage organisational documents</p>
    </div>
    <div class="d-flex gap-2">
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="CreateFolder" asp-route-parentId="@Model.ActiveFolderId" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-folder-plus me-1"></i> New Folder
            </a>
        }
        <a asp-action="Create" asp-route-folderId="@Model.ActiveFolderId" class="btn btn-primary btn-sm">
            <i class="bi bi-file-earmark-plus me-1"></i> New Document
        </a>
    </div>
</div>

<div class="row g-3">
    <!-- Left: folder tree -->
    <div class="col-lg-3">
        <div class="card h-100">
            <div class="card-header d-flex align-items-center justify-content-between" style="font-size:13px;font-weight:600;">
                <span><i class="bi bi-diagram-3 me-2"></i>Folders</span>
            </div>
            <div class="card-body p-0">
                <div class="folder-tree">
                    <a href="@Url.Action("Index", "Documents")"
                       class="folder-tree-item @(Model.ActiveFolderId == null && string.IsNullOrEmpty(Model.SearchQuery) ? "active" : "")">
                        <i class="bi bi-house me-1"></i>
                        <span>All Documents</span>
                    </a>
                    @foreach (var item in Model.FlatFolderTree)
                    {
                        var isActive = Model.ActiveFolderId == item.Folder.Id;
                        var indent = 14 + item.Depth * 14;
                        var folderIcon = isActive ? "folder2-open" : "folder2";
                        <a href="@Url.Action("Index", "Documents", new { folderId = item.Folder.Id })"
                           class="folder-tree-item @(isActive ? "active" : "")"
                           style="padding-left: @(indent)px;">
                            <i class="bi bi-@(folderIcon) me-1"></i>
                            <span>@item.Folder.Name</span>
                            <span class="ms-auto text-muted" style="font-size:11px;">@item.Folder.Documents.Count</span>
                        </a>
                    }
                </div>

                <!-- Status filters -->
                <div class="px-3 pt-2 pb-3" style="border-top:1px solid var(--bs-border-color);margin-top:8px;">
                    <div style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.05em;color:var(--color-primary);margin-bottom:6px;">Status</div>
                    @foreach (var s in Enum.GetValues<DocumentStatus>())
                    {
                        var cls = s.ToString() == Model.StatusFilter ? "fw-semibold" : "text-muted";
                        <a href="@Url.Action("Index", "Documents", new { folderId = Model.ActiveFolderId, status = s.ToString() })"
                           class="d-block py-1 text-decoration-none @cls" style="font-size:13px;">
                            <span class="status-badge @StatusClass(s) me-1" style="font-size:10px;">@s</span>
                        </a>
                    }
                    @if (!string.IsNullOrEmpty(Model.StatusFilter))
                    {
                        <a href="@Url.Action("Index", "Documents", new { folderId = Model.ActiveFolderId })"
                           class="d-block text-muted text-decoration-none mt-1" style="font-size:12px;">
                            <i class="bi bi-x me-1"></i>Clear filter
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Right: search + document grid -->
    <div class="col-lg-9">
        <!-- Search bar -->
        <form method="get" asp-action="Index" class="mb-3">
            <input type="hidden" name="folderId" value="@Model.ActiveFolderId" />
            <div class="input-group">
                <span class="input-group-text bg-white"><i class="bi bi-search text-muted"></i></span>
                <input type="text" name="q" value="@Model.SearchQuery" class="form-control"
                       placeholder="Search by title, serial number or tags…" />
                <button class="btn btn-primary" type="submit">Search</button>
                @if (!string.IsNullOrEmpty(Model.SearchQuery))
                {
                    <a href="@Url.Action("Index", "Documents", new { folderId = Model.ActiveFolderId })"
                       class="btn btn-outline-secondary">Clear</a>
                }
            </div>
        </form>

        <!-- Breadcrumb / folder context -->
        @if (Model.ActiveFolderId.HasValue)
        {
            var activeFolder = Model.FolderTree.FirstOrDefault(f => f.Id == Model.ActiveFolderId);
            if (activeFolder != null)
            {
                <div class="d-flex align-items-center gap-2 mb-3" style="font-size:13px;">
                    <a href="@Url.Action("Index", "Documents")" class="text-muted text-decoration-none">All Documents</a>
                    <i class="bi bi-chevron-right text-muted" style="font-size:10px;"></i>
                    <span class="fw-semibold">@activeFolder.Name</span>
                    @if (!string.IsNullOrEmpty(activeFolder.Description))
                    {
                        <span class="text-muted">— @activeFolder.Description</span>
                    }
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="EditFolder" asp-route-id="@Model.ActiveFolderId" class="btn btn-outline-secondary btn-sm ms-2" style="padding:2px 8px;font-size:12px;">
                            <i class="bi bi-pencil me-1"></i>Edit folder
                        </a>
                        <form asp-action="DeleteFolder" method="post" class="d-inline"
                              onsubmit="return confirm('Delete this folder? It must be empty.');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.ActiveFolderId" />
                            <button class="btn btn-outline-danger btn-sm" style="padding:2px 8px;font-size:12px;">
                                <i class="bi bi-trash me-1"></i>Delete
                            </button>
                        </form>
                    }
                </div>

                <!-- Folder permissions panel -->
                @if (User.IsInRole("Admin") && activeFolder.Permissions.Any())
                {
                    <div class="card mb-3" style="border:1px solid color-mix(in srgb,var(--color-primary) 20%,transparent);background:color-mix(in srgb,var(--color-primary) 4%,transparent);">
                        <div class="card-body py-2 px-3">
                            <div class="d-flex align-items-center gap-2 flex-wrap">
                                <i class="bi bi-shield-lock text-muted" style="font-size:13px;"></i>
                                <span style="font-size:12px;font-weight:600;">Folder Permissions:</span>
                                @foreach (var p in activeFolder.Permissions)
                                {
                                    <span class="badge" style="background:var(--color-primary);font-size:11px;">
                                        @p.SubjectType: @p.SubjectId — @p.AccessLevel
                                    </span>
                                }
                            </div>
                        </div>
                    </div>
                }
            }
        }

        @if (!Model.Documents.Any())
        {
            <div class="card">
                <div class="card-body text-center py-5 text-muted">
                    <i class="bi bi-folder2-open" style="font-size:40px;opacity:.3;"></i>
                    <p class="mt-3 mb-1">No documents found</p>
                    <small>@(string.IsNullOrEmpty(Model.SearchQuery) ? "Upload the first document using the button above." : "Try a different search term.")</small>
                </div>
            </div>
        }
        else
        {
            <div class="row g-3">
                @foreach (var doc in Model.Documents)
                {
                    var cv = doc.Versions.FirstOrDefault(v => v.IsCurrentVersion);
                    var ext = cv != null ? System.IO.Path.GetExtension(cv.OriginalFileName).TrimStart('.').ToUpper() : "—";
                    <div class="col-md-6 col-xl-4">
                        <div class="card h-100 doc-card">
                            <div class="card-body">
                                <div class="d-flex align-items-start gap-2 mb-2">
                                    <div class="doc-icon">
                                        <i class="bi @FileIcon(ext)"></i>
                                    </div>
                                    <div class="flex-grow-1 min-width-0">
                                        <a asp-action="Details" asp-route-id="@doc.Id"
                                           class="text-decoration-none fw-semibold d-block"
                                           style="font-size:14px;line-height:1.3;color:inherit;word-break:break-word;">@doc.Title</a>
                                        <div class="text-muted" style="font-size:11px;">@doc.SerialNumber</div>
                                    </div>
                                </div>

                                @if (!string.IsNullOrEmpty(doc.Tags))
                                {
                                    <div class="d-flex flex-wrap gap-1 mb-2">
                                        @foreach (var tag in doc.Tags.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                                        {
                                            <span class="badge" style="background:color-mix(in srgb,var(--color-primary) 12%,transparent);color:var(--color-primary);font-size:10px;">@tag</span>
                                        }
                                    </div>
                                }

                                <div class="d-flex align-items-center justify-content-between mt-auto pt-2" style="border-top:1px solid var(--bs-border-color);margin-top:8px;">
                                    <span class="status-badge @StatusClass(doc.Status)" style="font-size:10px;">@doc.Status</span>
                                    <span class="text-muted" style="font-size:11px;">
                                        @(cv != null ? $"v{cv.VersionNumber} · {FormatSize(cv.FileSizeBytes)}" : "No file")
                                    </span>
                                </div>

                                <div class="d-flex align-items-center justify-content-between mt-2">
                                    <span class="text-muted" style="font-size:11px;">
                                        <i class="bi bi-clock me-1"></i>@doc.UpdatedAt.ToString("dd MMM yyyy")
                                    </span>
                                    <div class="d-flex gap-1">
                                        @if (cv != null)
                                        {
                                            <a asp-action="Download" asp-route-versionId="@cv.Id"
                                               class="btn btn-outline-secondary btn-sm" style="padding:2px 7px;font-size:11px;">
                                                <i class="bi bi-download"></i>
                                            </a>
                                        }
                                        <a asp-action="Details" asp-route-id="@doc.Id"
                                           class="btn btn-outline-primary btn-sm" style="padding:2px 7px;font-size:11px;">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@functions {
    string FormatSize(long bytes) => bytes switch {
        < 1024 => $"{bytes} B",
        < 1048576 => $"{bytes / 1024.0:F1} KB",
        _ => $"{bytes / 1048576.0:F1} MB"
    };

    string StatusClass(DocumentStatus s) => s switch {
        DocumentStatus.Active => "status-approved",
        DocumentStatus.Draft => "status-draft",
        DocumentStatus.UnderReview => "status-submitted",
        DocumentStatus.Superseded => "status-implemented",
        DocumentStatus.Retired => "status-closed",
        _ => ""
    };

    string FileIcon(string ext) => ext.ToUpper() switch {
        "PDF" => "bi-file-earmark-pdf",
        "DOC" or "DOCX" => "bi-file-earmark-word",
        "XLS" or "XLSX" => "bi-file-earmark-excel",
        "PPT" or "PPTX" => "bi-file-earmark-ppt",
        "PNG" or "JPG" or "JPEG" or "GIF" => "bi-file-earmark-image",
        "ZIP" => "bi-file-earmark-zip",
        "TXT" => "bi-file-earmark-text",
        "CSV" => "bi-file-earmark-spreadsheet",
        _ => "bi-file-earmark"
    };


}
