@model PCA.Web.Models.DocumentEditViewModel
@using PCA.Shared.Enums
@{
    ViewData["Title"] = "Edit Document";
    var folders = ViewBag.Folders as List<PCA.Modules.Documents.Models.DocumentFolder> ?? new();
    var users = ViewBag.Users as List<PCA.Modules.Identity.Models.ApplicationUser> ?? new();
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Edit Document</h1>
        <p class="page-header-sub mb-0">Update metadata for this document</p>
    </div>
    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i> Back
    </a>
</div>

<div class="row g-3">
    <div class="col-lg-7">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 mb-4 small"></div>

            <div class="form-section">
                <div class="form-section-header"><i class="bi bi-file-earmark-text"></i> Document Details</div>
                <div class="form-section-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="Title" class="form-label fw-semibold">Title <span class="text-danger">*</span></label>
                            <input asp-for="Title" class="form-control" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Description" class="form-label">Description</label>
                            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="FolderId" class="form-label">Folder</label>
                            <select asp-for="FolderId" class="form-select">
                                <option value="">— Root (no folder) —</option>
                                @foreach (var f in folders.OrderBy(x => x.Name))
                                {
                                    if (Model.FolderId == f.Id)
                                    {
                                        <option value="@f.Id" selected>@f.Name</option>
                                    }
                                    else
                                    {
                                        <option value="@f.Id">@f.Name</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Tags" class="form-label">Tags</label>
                            <input asp-for="Tags" class="form-control" placeholder="policy, HR (comma-separated)" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Status" class="form-label">Status</label>
                            <select asp-for="Status" class="form-select">
                                @foreach (var s in Enum.GetValues<DocumentStatus>())
                                {
                                    if (Model.Status == s)
                                    {
                                        <option value="@s" selected>@s</option>
                                    }
                                    else
                                    {
                                        <option value="@s">@s</option>
                                    }
                                }
                            </select>
                        </div>
                        @if (User.IsInRole("Admin"))
                        {
                            <div class="col-md-6">
                                <label asp-for="OwnerId" class="form-label">Owner</label>
                                <select asp-for="OwnerId" class="form-select">
                                    @foreach (var u in users)
                                    {
                                        if (Model.OwnerId == u.Id)
                                        {
                                            <option value="@u.Id" selected>@u.FullName (@u.Email)</option>
                                        }
                                        else
                                        {
                                            <option value="@u.Id">@u.FullName (@u.Email)</option>
                                        }
                                    }
                                </select>
                            </div>
                        }
                        else
                        {
                            <input asp-for="OwnerId" type="hidden" />
                        }
                    </div>
                </div>
            </div>

            <div class="form-section mt-4">
                <div class="form-section-header"><i class="bi bi-calendar-check"></i> Review Schedule</div>
                <div class="form-section-body">
                    @{
                        var knownPeriods = new[] { 30, 60, 90, 180, 365, 730 };
                        var savedDays    = Model.ReviewPeriodDays;
                        var isCustom     = savedDays.HasValue && !knownPeriods.Contains(savedDays.Value);
                    }
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Review Period</label>
                            <select id="reviewPeriodSelect" class="form-select">
                                @if (savedDays == null)      { <option value="" selected>— No scheduled review —</option> }
                                else                         { <option value="">— No scheduled review —</option> }
                                @if (savedDays == 30)        { <option value="30" selected>Monthly (30 days)</option> }
                                else                         { <option value="30">Monthly (30 days)</option> }
                                @if (savedDays == 60)        { <option value="60" selected>Every 2 months (60 days)</option> }
                                else                         { <option value="60">Every 2 months (60 days)</option> }
                                @if (savedDays == 90)        { <option value="90" selected>Quarterly (90 days)</option> }
                                else                         { <option value="90">Quarterly (90 days)</option> }
                                @if (savedDays == 180)       { <option value="180" selected>Semi-annually (180 days)</option> }
                                else                         { <option value="180">Semi-annually (180 days)</option> }
                                @if (savedDays == 365)       { <option value="365" selected>Annually (365 days)</option> }
                                else                         { <option value="365">Annually (365 days)</option> }
                                @if (savedDays == 730)       { <option value="730" selected>Every 2 years (730 days)</option> }
                                else                         { <option value="730">Every 2 years (730 days)</option> }
                                @if (isCustom)               { <option value="custom" selected>Custom…</option> }
                                else                         { <option value="custom">Custom…</option> }
                            </select>
                            <input asp-for="ReviewPeriodDays" type="number" id="reviewPeriodCustom"
                                   class="form-control mt-2 @(isCustom ? "" : "d-none")"
                                   placeholder="Enter days (1–3650)" min="1" max="3650" />
                            <div class="form-text">Sets how often this document must be reviewed.</div>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="NextReviewDate" class="form-label fw-semibold">Period Start Date</label>
                            <input asp-for="NextReviewDate" type="date" id="nextReviewDate" class="form-control" />
                            <div class="form-text" id="nextReviewHint"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check2 me-1"></i> Save Changes
                </button>
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<partial name="_ValidationScriptsPartial" />
<script>
const periodSelect = document.getElementById('reviewPeriodSelect');
const periodCustom = document.getElementById('reviewPeriodCustom');
const periodHidden = document.getElementById('ReviewPeriodDays');
const startDate    = document.getElementById('nextReviewDate');
const reviewHint   = document.getElementById('nextReviewHint');

function addDays(dateStr, days) {
    if (!dateStr) return '';
    const d = new Date(dateStr);
    d.setDate(d.getDate() + days);
    return d.toISOString().slice(0, 10);
}

function updateHint() {
    const days  = parseInt(periodHidden.value);
    const start = startDate.value;
    if (!isNaN(days) && days > 0 && start) {
        reviewHint.textContent = `First review due: ${addDays(start, days)}`;
    } else if (!isNaN(days) && days > 0) {
        reviewHint.textContent = 'Set a start date to calculate the first due date.';
    } else {
        reviewHint.textContent = '';
    }
}

periodSelect.addEventListener('change', function () {
    if (this.value === 'custom') {
        periodCustom.classList.remove('d-none');
        periodHidden.value = '';
    } else {
        periodCustom.classList.add('d-none');
        periodHidden.value = this.value;
        if (this.value && !startDate.value)
            startDate.value = new Date().toISOString().slice(0, 10);
        if (!this.value) startDate.value = '';
    }
    updateHint();
});

periodCustom.addEventListener('input', function () {
    periodHidden.value = this.value;
    updateHint();
});

startDate.addEventListener('change', updateHint);

// Initialise hint on load
updateHint();
</script>
}
