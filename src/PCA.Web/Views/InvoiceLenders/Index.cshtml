@{ ViewData["Title"] = "Invoice Lenders"; }

<div class="page-header">
    <div>
        <h1 class="page-header-title">Invoice Lenders</h1>
        <p class="page-header-sub mb-0">Configure lenders for invoice generation</p>
    </div>
    <a asp-action="Create" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i> New Lender</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-body p-0">
        <table id="tbl-lenders" class="table table-hover mb-0" style="font-size:13px;">
            <thead style="background:var(--bs-tertiary-bg);"></thead>
            <tbody></tbody>
        </table>
    </div>
    <div class="card-footer py-2" id="tbl-lenders-pagination"></div>
</div>

@section Scripts {
<script>
PagedTable.init({
    tableId: 'tbl-lenders',
    url: '/InvoiceLenders/IndexData',
    pageSize: 25,
    defaultSort: { col: 'name', dir: 'asc' },
    paginationId: 'tbl-lenders-pagination',
    columns: [
        { key: 'name',          label: 'Name',           thClass: 'ps-3', tdClass: 'ps-3 align-middle fw-semibold' },
        { key: 'companyType',   label: 'Company Type',   tdClass: 'align-middle text-muted' },
        { key: 'deductionCode', label: 'Deduction Code', tdClass: 'align-middle text-muted' },
        { key: 'isActive',      label: 'Status',         tdClass: 'align-middle', render: r => r.isActive
            ? '<span class="status-badge status-approved" style="font-size:10px;">Active</span>'
            : '<span class="status-badge status-draft" style="font-size:10px;">Inactive</span>' },
        { key: null, label: '', sortable: false, thClass: 'pe-3', tdClass: 'pe-3 align-middle text-end',
          render: r => `<a href="/InvoiceLenders/Edit/${r.id}" class="btn btn-outline-secondary btn-sm me-1" style="padding:2px 8px;font-size:11px;"><i class="bi bi-pencil"></i></a>
                        <button class="btn btn-outline-danger btn-sm" style="padding:2px 8px;font-size:11px;"
                                onclick="if(confirm('Delete this lender?')){const f=document.createElement('form');f.method='post';f.action='/InvoiceLenders/Delete/${r.id}';const t=document.createElement('input');t.type='hidden';t.name='__RequestVerificationToken';t.value=document.querySelector('input[name=__RequestVerificationToken]')?.value||'';f.appendChild(t);document.body.appendChild(f);f.submit();}"><i class="bi bi-trash"></i></button>` }
    ]
});
</script>
}
