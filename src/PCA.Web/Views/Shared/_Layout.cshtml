@using PCA.Web.Services
@inject IThemeService ThemeService
@{
    var theme = await ThemeService.GetThemeAsync();
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var action = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    bool isAuth = User.Identity?.IsAuthenticated == true;

    string ActiveIf(string ctrl, string? act = null) =>
        controller.Equals(ctrl, StringComparison.OrdinalIgnoreCase) &&
        (act == null || action.Equals(act, StringComparison.OrdinalIgnoreCase))
        ? "active" : "";

    string UserInitials() {
        var name = User.Identity?.Name ?? "?";
        var parts = name.Split('@')[0].Split('.');
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[1][0]}".ToUpper()
            : name.Length >= 2 ? name[..2].ToUpper() : name.ToUpper();
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – PCA Management Portal</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        :root {
            --color-primary:       @theme.PrimaryColor;
            --color-primary-hover: @theme.AccentHover;
            --color-sidebar-bg:    @theme.SidebarBg;
            --color-sidebar-text:  @theme.SidebarText;
            --color-app-bg:        @theme.AppBg;
            --color-card-bg:       @theme.CardBg;
            --color-topbar-bg:     @theme.TopbarBg;
            --font-family:         @theme.FontFamily;
        }
    </style>
</head>
<body>

@if (!isAuth)
{
    @RenderBody()
}
else
{
    <!-- Sidebar -->
    <aside class="sidebar">
        <div class="sidebar-logo">
            <div class="logo-icon">@theme.LogoText</div>
            <div class="logo-text">
                @theme.LogoText
                <small>Management Portal</small>
            </div>
        </div>

        <nav class="sidebar-nav">
            <div class="sidebar-section-label">Main</div>

            <a asp-controller="Home" asp-action="Index"
               class="sidebar-link @ActiveIf("Home")">
                <i class="bi bi-speedometer2"></i>
                <span>Dashboard</span>
            </a>

            <div class="sidebar-section-label">Change Management</div>

            <a asp-controller="ChangeRequests" asp-action="Index"
               class="sidebar-link @ActiveIf("ChangeRequests")">
                <i class="bi bi-ticket-detailed"></i>
                <span>Change Requests</span>
            </a>

            @if (User.IsInRole("Admin") || User.IsInRole("Approver"))
            {
                <a asp-controller="Approvals" asp-action="Index"
                   class="sidebar-link @ActiveIf("Approvals")">
                    <i class="bi bi-check2-circle"></i>
                    <span>Approvals</span>
                    @if (ViewBag.PendingCount is int cnt && cnt > 0)
                    {
                        <span class="sidebar-badge">@cnt</span>
                    }
                </a>
            }

            <div class="sidebar-section-label">Documents</div>

            <a asp-controller="Documents" asp-action="Index"
               class="sidebar-link @ActiveIf("Documents")">
                <i class="bi bi-folder2"></i>
                <span>Document Repository</span>
            </a>

            @if (User.IsInRole("Admin"))
            {
                <div class="sidebar-section-label">Administration</div>

                <a asp-controller="Admin" asp-action="Index"
                   class="sidebar-link @ActiveIf("Admin", "Index")">
                    <i class="bi bi-diagram-3"></i>
                    <span>Approval Templates</span>
                </a>

                <a asp-controller="Admin" asp-action="Users"
                   class="sidebar-link @ActiveIf("Admin", "Users")">
                    <i class="bi bi-people"></i>
                    <span>Users</span>
                </a>

                <a asp-controller="Admin" asp-action="Theme"
                   class="sidebar-link @ActiveIf("Admin", "Theme")">
                    <i class="bi bi-palette"></i>
                    <span>Theme &amp; Branding</span>
                </a>
            }
        </nav>

        <div class="sidebar-footer">
            <form asp-controller="Account" asp-action="Logout" method="post">
                <button type="submit" class="sidebar-link w-100" style="background:none;border:none;cursor:pointer;text-align:left;">
                    <i class="bi bi-box-arrow-left"></i>
                    <span>Sign Out</span>
                </button>
            </form>
        </div>
    </aside>

    <!-- Main -->
    <div class="main-wrap">
        <header class="topbar">
            <div class="topbar-title">
                @(ViewData["Title"] ?? "Dashboard")
                @if (ViewData["Subtitle"] != null)
                {
                    <small>@ViewData["Subtitle"]</small>
                }
            </div>
            <div class="topbar-actions">
                <div class="dropdown">
                    <button class="btn btn-primary btn-sm px-3 dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="bi bi-plus-lg me-1"></i> Quick Action
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 mt-1" style="border-radius:10px;font-size:13px;min-width:200px;">
                        <li><span class="dropdown-item-text text-muted" style="font-size:10px;padding:8px 16px 4px;text-transform:uppercase;letter-spacing:.06em;">Change Management</span></li>
                        <li>
                            <a class="dropdown-item" asp-controller="ChangeRequests" asp-action="Create">
                                <i class="bi bi-ticket-detailed me-2"></i>New Change Request
                            </a>
                        </li>
                        <li><hr class="dropdown-divider my-1" /></li>
                        <li><span class="dropdown-item-text text-muted" style="font-size:10px;padding:8px 16px 4px;text-transform:uppercase;letter-spacing:.06em;">Documents</span></li>
                        <li>
                            <a class="dropdown-item" asp-controller="Documents" asp-action="Create">
                                <i class="bi bi-file-earmark-plus me-2"></i>New Document
                            </a>
                        </li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li>
                                <a class="dropdown-item" asp-controller="Documents" asp-action="CreateFolder">
                                    <i class="bi bi-folder-plus me-2"></i>New Folder
                                </a>
                            </li>
                        }
                    </ul>
                </div>
                <div class="dropdown">
                    <a href="#" class="topbar-user dropdown-toggle" data-bs-toggle="dropdown">
                        <div class="avatar">@UserInitials()</div>
                        @User.Identity!.Name?.Split('@')[0]
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0" style="border-radius:10px;font-size:13px;">
                        <li><span class="dropdown-item-text text-muted" style="font-size:11px;padding:8px 16px 4px;">Signed in as</span></li>
                        <li><span class="dropdown-item-text fw-semibold px-4" style="font-size:13px;">@User.Identity.Name</span></li>
                        <li><hr class="dropdown-divider my-1" /></li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li><a class="dropdown-item" asp-controller="Admin" asp-action="Theme"><i class="bi bi-palette me-2"></i>Theme Settings</a></li>
                        }
                        <li>
                            <form asp-controller="Account" asp-action="Logout" method="post">
                                <button type="submit" class="dropdown-item text-danger">
                                    <i class="bi bi-box-arrow-right me-2"></i>Sign Out
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>
            </div>
        </header>

        <!-- Toast notifications -->
        @if (TempData["Success"] != null || TempData["Error"] != null)
        {
            <div class="toast-area" id="toastArea">
                @if (TempData["Success"] != null)
                {
                    <div class="toast-item success">
                        <i class="bi bi-check-circle-fill"></i>
                        <span>@TempData["Success"]</span>
                        <button class="toast-close" onclick="this.closest('.toast-item').remove()">×</button>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="toast-item error">
                        <i class="bi bi-exclamation-circle-fill"></i>
                        <span>@TempData["Error"]</span>
                        <button class="toast-close" onclick="this.closest('.toast-item').remove()">×</button>
                    </div>
                }
            </div>
        }

        <main class="page-content">
            @RenderBody()
        </main>
    </div>
}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
    // Auto-dismiss toasts after 4 seconds
    setTimeout(() => {
        document.querySelectorAll('.toast-item').forEach(el => {
            el.style.transition = 'opacity .3s';
            el.style.opacity = '0';
            setTimeout(() => el.remove(), 300);
        });
    }, 4000);
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
