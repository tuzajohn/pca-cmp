@model PCA.Modules.Approvals.Models.ApprovalTemplate
@{
    ViewData["Title"] = "Edit Approval Template";
    var users = ViewBag.Users as List<PCA.Modules.Identity.Models.ApplicationUser> ?? new();
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Edit Approval Template</h1>
        <p class="page-header-sub mb-0">@Model.Name</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i> Back to Templates
    </a>
</div>

<div class="row">
    <div class="col-lg-7">
        <div class="form-section">
            <div class="form-section-header"><i class="bi bi-diagram-3"></i> Template Details</div>
            <div class="form-section-body">
                <form asp-action="EditTemplate" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Template Name <span class="text-danger">*</span></label>
                        <input type="text" name="name" value="@Model.Name" class="form-control" required />
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Module</label>
                            <select name="entityType" id="entityType" class="form-select">
                                @if (Model.EntityType == "Incident")
                                {
                                    <option value="ChangeRequest">Change Request</option>
                                    <option value="Incident" selected>Incident</option>
                                    <option value="Document">Document</option>
                                }
                                else if (Model.EntityType == "Document")
                                {
                                    <option value="ChangeRequest">Change Request</option>
                                    <option value="Incident">Incident</option>
                                    <option value="Document" selected>Document</option>
                                }
                                else
                                {
                                    <option value="ChangeRequest" selected>Change Request</option>
                                    <option value="Incident">Incident</option>
                                    <option value="Document">Document</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6" id="subTypeRow" style="@(Model.EntityType == "Incident" || Model.EntityType == "Document" ? "display:none;" : "")">
                            <label class="form-label fw-semibold">Change Type</label>
                            <select name="entitySubType" class="form-select">
                                <option value="">— Any —</option>
                                @foreach (var ct in new[] { "Standard", "Normal", "Emergency" })
                                {
                                    if (Model.EntitySubType == ct)
                                    {
                                        <option value="@ct" selected>@ct</option>
                                    }
                                    else
                                    {
                                        <option value="@ct">@ct</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Approval Mode</label>
                            <select name="approvalMode" class="form-select">
                                <option value="AllMustApprove" @(Model.ApprovalMode == PCA.Modules.Approvals.Models.ApprovalMode.AllMustApprove ? "selected" : "")>All Must Approve</option>
                                <option value="AnyCanApprove" @(Model.ApprovalMode == PCA.Modules.Approvals.Models.ApprovalMode.AnyCanApprove ? "selected" : "")>Any Can Approve</option>
                            </select>
                            <div class="form-text">AnyCanApprove: one approval from any step completes the flow.</div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Auto-Trigger</label>
                            <select name="autoTriggerOn" class="form-select">
                                <option value="None" @(Model.AutoTriggerOn == PCA.Modules.Approvals.Models.AutoTriggerOn.None ? "selected" : "")>None (manual)</option>
                                <option value="OnSubmit" @(Model.AutoTriggerOn == PCA.Modules.Approvals.Models.AutoTriggerOn.OnSubmit ? "selected" : "")>On Submit / Creation</option>
                                <option value="OnStatusChange" @(Model.AutoTriggerOn == PCA.Modules.Approvals.Models.AutoTriggerOn.OnStatusChange ? "selected" : "")>On Status Change</option>
                            </select>
                        </div>
                    </div>

                    <div class="row g-3 mb-3" id="conditionRow">
                        <div class="col-md-6">
                            <label class="form-label">Condition Field <small class="text-muted">(optional)</small></label>
                            <input type="text" name="conditionField" value="@Model.ConditionField" class="form-control" placeholder="e.g. Priority" />
                            <div class="form-text">Only trigger if this field equals the value below.</div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Condition Value</label>
                            <input type="text" name="conditionValue" value="@Model.ConditionValue" class="form-control" placeholder="e.g. Critical" />
                        </div>
                    </div>

                    <h6 class="mt-4 mb-3">Approval Steps</h6>
                    <div id="stepsContainer">
                        @foreach (var step in Model.Steps.OrderBy(s => s.Order))
                        {
                            <div class="row g-2 mb-2 step-row">
                                <div class="col-md-6">
                                    <label class="form-label small">Approver</label>
                                    <select name="approverIds" class="form-select">
                                        @foreach (var u in users)
                                        {
                                            if (step.ApproverId == u.Id)
                                            {
                                                <option value="@u.Id" selected>@u.FullName (@u.Email)</option>
                                            }
                                            else
                                            {
                                                <option value="@u.Id">@u.FullName (@u.Email)</option>
                                            }
                                        }
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label small">Role Label</label>
                                    <input type="text" name="roleNames" value="@step.RoleName" class="form-control" placeholder="e.g. Manager" />
                                </div>
                                <div class="col-md-2 d-flex align-items-end">
                                    <button type="button" class="btn btn-outline-danger btn-sm remove-step">Remove</button>
                                </div>
                            </div>
                        }
                    </div>

                    <button type="button" id="addStep" class="btn btn-outline-secondary btn-sm mb-4">
                        <i class="bi bi-plus"></i> Add Step
                    </button>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check2 me-1"></i> Save Changes
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
const userOptions = `@Html.Raw(string.Join("", users.Select(u => $"<option value='{u.Id}'>{System.Net.WebUtility.HtmlEncode(u.FullName)} ({System.Net.WebUtility.HtmlEncode(u.Email ?? "")})</option>")))`;

document.getElementById('entityType').addEventListener('change', function() {
    document.getElementById('subTypeRow').style.display = this.value === 'ChangeRequest' ? '' : 'none';
});
// Initialise
document.getElementById('subTypeRow').style.display = document.getElementById('entityType').value === 'ChangeRequest' ? '' : 'none';

document.getElementById('addStep').addEventListener('click', () => {
    const container = document.getElementById('stepsContainer');
    const div = document.createElement('div');
    div.className = 'row g-2 mb-2 step-row';
    div.innerHTML = `
        <div class="col-md-6">
            <label class="form-label small">Approver</label>
            <select name="approverIds" class="form-select">${userOptions}</select>
        </div>
        <div class="col-md-4">
            <label class="form-label small">Role Label</label>
            <input type="text" name="roleNames" class="form-control" placeholder="e.g. Manager" />
        </div>
        <div class="col-md-2 d-flex align-items-end">
            <button type="button" class="btn btn-outline-danger btn-sm remove-step">Remove</button>
        </div>`;
    container.appendChild(div);
});

document.addEventListener('click', (e) => {
    if (e.target.classList.contains('remove-step')) e.target.closest('.step-row').remove();
});
</script>
}
