@model PCA.Modules.Approvals.Models.ApprovalTemplate
@{
    ViewData["Title"] = "Edit Approval Template";
    var users = ViewBag.Users as List<PCA.Modules.Identity.Models.ApplicationUser> ?? new();
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Edit Approval Template</h1>
        <p class="page-header-sub mb-0">@Model.Name</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i> Back to Templates
    </a>
</div>

<div class="row">
    <div class="col-lg-7">
        <div class="form-section">
            <div class="form-section-header"><i class="bi bi-diagram-3"></i> Template Details</div>
            <div class="form-section-body">
                <form asp-action="EditTemplate" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Template Name <span class="text-danger">*</span></label>
                        <input type="text" name="name" value="@Model.Name" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Change Type</label>
                        <select name="changeType" class="form-select">
                            @foreach (var ct in Enum.GetValues<PCA.Shared.Enums.ChangeType>())
                            {
                                <option value="@ct" @(Model.ChangeType == ct ? "selected" : "")>@ct</option>
                            }
                        </select>
                    </div>

                    <h6 class="mt-4 mb-3">Approval Steps</h6>
                    <div id="stepsContainer">
                        @foreach (var step in Model.Steps.OrderBy(s => s.Order))
                        {
                            <div class="row g-2 mb-2 step-row">
                                <div class="col-md-6">
                                    <label class="form-label small">Approver</label>
                                    <select name="approverIds" class="form-select">
                                        @foreach (var u in users)
                                        {
                                            <option value="@u.Id" @(step.ApproverId == u.Id ? "selected" : "")>@u.FullName (@u.Email)</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label small">Role Name</label>
                                    <input type="text" name="roleNames" value="@step.RoleName" class="form-control" placeholder="e.g. Manager" />
                                </div>
                                <div class="col-md-2 d-flex align-items-end">
                                    <button type="button" class="btn btn-outline-danger btn-sm remove-step">Remove</button>
                                </div>
                            </div>
                        }
                    </div>

                    <button type="button" id="addStep" class="btn btn-outline-secondary btn-sm mb-4">
                        <i class="bi bi-plus"></i> Add Step
                    </button>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check2 me-1"></i> Save Changes
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const userOptions = `@Html.Raw(string.Join("", users.Select(u => $"<option value='{u.Id}'>{System.Web.HttpUtility.HtmlEncode(u.FullName)} ({System.Web.HttpUtility.HtmlEncode(u.Email)})</option>")))`;

    document.getElementById('addStep').addEventListener('click', () => {
        const container = document.getElementById('stepsContainer');
        const div = document.createElement('div');
        div.className = 'row g-2 mb-2 step-row';
        div.innerHTML = `
            <div class="col-md-6">
                <label class="form-label small">Approver</label>
                <select name="approverIds" class="form-select">${userOptions}</select>
            </div>
            <div class="col-md-4">
                <label class="form-label small">Role Name</label>
                <input type="text" name="roleNames" class="form-control" placeholder="e.g. Manager" />
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button type="button" class="btn btn-outline-danger btn-sm remove-step">Remove</button>
            </div>`;
        container.appendChild(div);
    });

    document.addEventListener('click', (e) => {
        if (e.target.classList.contains('remove-step')) {
            e.target.closest('.step-row').remove();
        }
    });
</script>
}
