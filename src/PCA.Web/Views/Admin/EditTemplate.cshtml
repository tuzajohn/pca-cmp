@model PCA.Modules.Approvals.Models.ApprovalTemplate
@{
    ViewData["Title"] = "Edit Approval Template";
    var users = ViewBag.Users as List<PCA.Modules.Identity.Models.ApplicationUser> ?? new();
}

<h2 class="mb-4"><i class="bi bi-pencil"></i> Edit Template: @Model.Name</h2>
<div class="alert alert-info">To modify steps, delete this template and create a new one, or update via the database directly. Full step editing UI coming in next iteration.</div>

<div class="row">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Name</dt>
                    <dd class="col-sm-8">@Model.Name</dd>
                    <dt class="col-sm-4">Change Type</dt>
                    <dd class="col-sm-8">@Model.ChangeType</dd>
                </dl>
                <h6 class="mt-3">Steps</h6>
                <ol>
                    @foreach (var step in Model.Steps.OrderBy(s => s.Order))
                    {
                        <li>@step.Approver?.FullName — @step.RoleName</li>
                    }
                </ol>
                <a asp-action="Index" class="btn btn-secondary mt-2">Back</a>
            </div>
        </div>
    </div>
</div>
