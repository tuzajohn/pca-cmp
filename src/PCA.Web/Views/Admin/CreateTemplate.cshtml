@{
    ViewData["Title"] = "Create Approval Template";
    var users = ViewBag.Users as List<PCA.Modules.Identity.Models.ApplicationUser> ?? new();
}

<div class="page-header">
    <h1 class="page-header-title">Create Approval Template</h1>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i> Back</a>
</div>

<div class="row">
    <div class="col-lg-7">
        <div class="form-section">
            <div class="form-section-header"><i class="bi bi-diagram-3"></i> Template</div>
            <div class="form-section-body">
                <form asp-action="CreateTemplate" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Template Name <span class="text-danger">*</span></label>
                        <input type="text" name="name" class="form-control" required />
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Module</label>
                            <select name="entityType" id="entityType" class="form-select">
                                <option value="ChangeRequest">Change Request</option>
                                <option value="Incident">Incident</option>
                                <option value="Document">Document</option>
                            </select>
                        </div>
                        <div class="col-md-6" id="subTypeRow">
                            <label class="form-label fw-semibold">Change Type</label>
                            <select name="entitySubType" class="form-select">
                                <option value="">— Any —</option>
                                <option value="Standard">Standard</option>
                                <option value="Normal">Normal</option>
                                <option value="Emergency">Emergency</option>
                            </select>
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Approval Mode</label>
                            <select name="approvalMode" class="form-select">
                                <option value="AllMustApprove">All Must Approve</option>
                                <option value="AnyCanApprove">Any Can Approve</option>
                            </select>
                            <div class="form-text">AnyCanApprove: one approval from any step completes the flow.</div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Auto-Trigger</label>
                            <select name="autoTriggerOn" class="form-select">
                                <option value="None">None (manual)</option>
                                <option value="OnSubmit">On Submit / Creation</option>
                                <option value="OnStatusChange">On Status Change</option>
                            </select>
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Condition Field <small class="text-muted">(optional)</small></label>
                            <select name="conditionField" id="conditionField" class="form-select">
                                <option value="">— None —</option>
                            </select>
                            <div class="form-text">Only trigger when this field matches the value on the right.</div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Condition Value</label>
                            <select name="conditionValue" id="conditionValue" class="form-select">
                                <option value="">— Select a field first —</option>
                            </select>
                        </div>
                    </div>

                    <h5 class="mt-4 mb-3" style="font-size:14px;font-weight:600;">Approval Steps</h5>
                    <div id="stepsContainer">
                        <div class="row g-2 mb-2 step-row">
                            <div class="col-md-6">
                                <label class="form-label small">Approver</label>
                                <select name="approverIds" class="form-select">
                                    @foreach (var u in users)
                                    {
                                        <option value="@u.Id">@u.FullName (@u.Email)</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small">Role Label</label>
                                <input type="text" name="roleNames" class="form-control" placeholder="e.g. Manager" />
                            </div>
                            <div class="col-md-2 d-flex align-items-end">
                                <button type="button" class="btn btn-outline-danger btn-sm remove-step">Remove</button>
                            </div>
                        </div>
                    </div>

                    <button type="button" id="addStep" class="btn btn-outline-secondary btn-sm mb-4">
                        <i class="bi bi-plus"></i> Add Step
                    </button>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Create Template</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
const userOptions = `@Html.Raw(string.Join("", users.Select(u => $"<option value='{u.Id}'>{System.Net.WebUtility.HtmlEncode(u.FullName)} ({System.Net.WebUtility.HtmlEncode(u.Email ?? "")})</option>")))`;

const conditionOptions = {
    ChangeRequest: {
        Type:     ['Standard', 'Normal', 'Emergency'],
        Priority: ['Low', 'Medium', 'High', 'Critical'],
        Status:   ['Draft', 'Submitted', 'UnderReview', 'Approved', 'Rejected', 'Implemented', 'Closed'],
    },
    Incident: {
        Severity: ['Low', 'Medium', 'High', 'Critical'],
        Priority: ['Low', 'Medium', 'High', 'Critical'],
        Category: ['Infrastructure', 'Application', 'Security', 'Network', 'Hardware', 'Other'],
        Status:   ['Open', 'InProgress', 'Resolved', 'Closed'],
    },
    Document: {
        Status: ['Draft', 'UnderReview', 'Active', 'Retired'],
    },
};

function refreshConditionDropdowns(entityType, selectedField, selectedValue) {
    const fieldSel  = document.getElementById('conditionField');
    const valueSel  = document.getElementById('conditionValue');
    const fields    = conditionOptions[entityType] || {};

    fieldSel.innerHTML = '<option value="">— None —</option>';
    Object.keys(fields).forEach(f => {
        fieldSel.innerHTML += `<option value="${f}"${f === selectedField ? ' selected' : ''}>${f}</option>`;
    });

    refreshValueDropdown(fields, selectedField || fieldSel.value, selectedValue);
}

function refreshValueDropdown(fields, field, selectedValue) {
    const valueSel = document.getElementById('conditionValue');
    const values   = (fields && fields[field]) || [];
    if (!values.length) {
        valueSel.innerHTML = '<option value="">— Select a field first —</option>';
        return;
    }
    valueSel.innerHTML = '<option value="">— Any —</option>';
    values.forEach(v => {
        valueSel.innerHTML += `<option value="${v}"${v === selectedValue ? ' selected' : ''}>${v}</option>`;
    });
}

document.getElementById('entityType').addEventListener('change', function() {
    document.getElementById('subTypeRow').style.display = this.value === 'ChangeRequest' ? '' : 'none';
    refreshConditionDropdowns(this.value, '', '');
});

document.getElementById('conditionField').addEventListener('change', function() {
    const entityType = document.getElementById('entityType').value;
    refreshValueDropdown(conditionOptions[entityType] || {}, this.value, '');
});

refreshConditionDropdowns(document.getElementById('entityType').value, '', '');

document.getElementById('addStep').addEventListener('click', () => {
    const container = document.getElementById('stepsContainer');
    const div = document.createElement('div');
    div.className = 'row g-2 mb-2 step-row';
    div.innerHTML = `
        <div class="col-md-6">
            <label class="form-label small">Approver</label>
            <select name="approverIds" class="form-select">${userOptions}</select>
        </div>
        <div class="col-md-4">
            <label class="form-label small">Role Label</label>
            <input type="text" name="roleNames" class="form-control" placeholder="e.g. Manager" />
        </div>
        <div class="col-md-2 d-flex align-items-end">
            <button type="button" class="btn btn-outline-danger btn-sm remove-step">Remove</button>
        </div>`;
    container.appendChild(div);
});

document.addEventListener('click', (e) => {
    if (e.target.classList.contains('remove-step')) e.target.closest('.step-row').remove();
});
</script>
}
