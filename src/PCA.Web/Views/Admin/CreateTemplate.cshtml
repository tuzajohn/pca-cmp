@{
    ViewData["Title"] = "Create Approval Template";
    var users = ViewBag.Users as List<PCA.Modules.Identity.Models.ApplicationUser> ?? new();
}

<h2 class="mb-4"><i class="bi bi-plus-circle"></i> Create Approval Template</h2>

<div class="row">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-body">
                <form asp-action="CreateTemplate" method="post">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Template Name</label>
                        <input type="text" name="name" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Change Type</label>
                        <select name="changeType" asp-items="Html.GetEnumSelectList<PCA.Shared.Enums.ChangeType>()" class="form-select"></select>
                    </div>

                    <h5 class="mt-4">Approval Steps</h5>
                    <div id="stepsContainer">
                        <div class="row g-2 mb-2 step-row">
                            <div class="col-md-6">
                                <label class="form-label small">Approver</label>
                                <select name="approverIds" class="form-select">
                                    @foreach (var u in users)
                                    {
                                        <option value="@u.Id">@u.FullName (@u.Email)</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small">Role Name</label>
                                <input type="text" name="roleNames" class="form-control" placeholder="e.g. Manager" />
                            </div>
                            <div class="col-md-2 d-flex align-items-end">
                                <button type="button" class="btn btn-outline-danger btn-sm remove-step">Remove</button>
                            </div>
                        </div>
                    </div>

                    <button type="button" id="addStep" class="btn btn-outline-secondary btn-sm mb-3">
                        <i class="bi bi-plus"></i> Add Step
                    </button>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Create Template</button>
                        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const userOptions = `@Html.Raw(string.Join("", users.Select(u => $"<option value='{u.Id}'>{u.FullName} ({u.Email})</option>")))`;

    document.getElementById('addStep').addEventListener('click', () => {
        const container = document.getElementById('stepsContainer');
        const div = document.createElement('div');
        div.className = 'row g-2 mb-2 step-row';
        div.innerHTML = `
            <div class="col-md-6">
                <label class="form-label small">Approver</label>
                <select name="approverIds" class="form-select">${userOptions}</select>
            </div>
            <div class="col-md-4">
                <label class="form-label small">Role Name</label>
                <input type="text" name="roleNames" class="form-control" placeholder="e.g. Manager" />
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button type="button" class="btn btn-outline-danger btn-sm remove-step">Remove</button>
            </div>`;
        container.appendChild(div);
    });

    document.addEventListener('click', (e) => {
        if (e.target.classList.contains('remove-step')) {
            e.target.closest('.step-row').remove();
        }
    });
</script>
}
