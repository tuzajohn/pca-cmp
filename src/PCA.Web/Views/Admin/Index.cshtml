@model List<PCA.Modules.Approvals.Models.ApprovalTemplate>
@{
    ViewData["Title"] = "Admin - Approval Templates";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-gear"></i> Approval Templates</h2>
    <div class="d-flex gap-2">
        <a asp-action="Users" class="btn btn-outline-secondary"><i class="bi bi-people"></i> Users</a>
        <a asp-action="CreateTemplate" class="btn btn-primary"><i class="bi bi-plus-lg"></i> New Template</a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No templates defined yet.</div>
}
else
{
    <div class="row g-3">
        @foreach (var template in Model)
        {
            <div class="col-md-6 col-xl-4">
                <div class="card h-100">
                    <div class="card-header d-flex justify-content-between">
                        <strong>@template.Name</strong>
                        <span class="badge bg-primary">@template.EntityType</span>
                        @if (!string.IsNullOrEmpty(template.EntitySubType))
                        {
                            <span class="badge bg-info text-dark ms-1">@template.EntitySubType</span>
                        }
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-sm mb-0" style="font-size:13px;">
                            <tbody>
                                <tr>
                                    <td class="text-muted ps-3" style="width:110px;">Mode</td>
                                    <td>@template.ApprovalMode</td>
                                </tr>
                                <tr>
                                    <td class="text-muted ps-3">Trigger</td>
                                    <td>
                                        @if (template.AutoTriggerOn != PCA.Modules.Approvals.Models.AutoTriggerOn.None)
                                        {
                                            <span>⚡ @template.AutoTriggerOn</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Manual</span>
                                        }
                                    </td>
                                </tr>
                                <tr>
                                    <td class="text-muted ps-3">Steps</td>
                                    <td>@template.Steps.Count</td>
                                </tr>
                                @if (!string.IsNullOrEmpty(template.ConditionField))
                                {
                                    <tr>
                                        <td class="text-muted ps-3">Condition</td>
                                        <td><code style="font-size:11px;">@template.ConditionField = @template.ConditionValue</code></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="card-footer d-flex gap-2">
                        <a asp-action="TemplateDetails" asp-route-id="@template.Id" class="btn btn-sm btn-outline-secondary">
                            <i class="bi bi-eye me-1"></i>Details
                        </a>
                        <a asp-action="EditTemplate" asp-route-id="@template.Id" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-pencil me-1"></i>Edit
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}
