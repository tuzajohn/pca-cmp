@model List<PCA.Modules.Approvals.Models.ApprovalTemplate>
@{
    ViewData["Title"] = "Admin - Approval Templates";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-gear"></i> Approval Templates</h2>
    <div class="d-flex gap-2">
        <a asp-action="Users" class="btn btn-outline-secondary"><i class="bi bi-people"></i> Users</a>
        <a asp-action="CreateTemplate" class="btn btn-primary"><i class="bi bi-plus-lg"></i> New Template</a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No templates defined yet.</div>
}
else
{
    <div class="row g-3">
        @foreach (var template in Model)
        {
            <div class="col-md-6 col-xl-4">
                <div class="card h-100">
                    <div class="card-header d-flex justify-content-between">
                        <strong>@template.Name</strong>
                        <span class="badge bg-info text-dark">@template.ChangeType</span>
                    </div>
                    <div class="card-body">
                        <h6 class="mb-2">Approval Steps</h6>
                        <ol class="mb-0">
                            @foreach (var step in template.Steps.OrderBy(s => s.Order))
                            {
                                <li>@step.Approver?.FullName <small class="text-muted">(@step.RoleName)</small></li>
                            }
                        </ol>
                    </div>
                    <div class="card-footer">
                        <a asp-action="EditTemplate" asp-route-id="@template.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                    </div>
                </div>
            </div>
        }
    </div>
}
