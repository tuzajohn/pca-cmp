@model List<PCA.Modules.Approvals.Models.ApprovalTemplate>
@{
    ViewData["Title"] = "Admin - Approval Templates";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-gear"></i> Approval Templates</h2>
    <div class="d-flex gap-2">
        <a asp-action="Users" class="btn btn-outline-secondary"><i class="bi bi-people"></i> Users</a>
        <a asp-action="CreateTemplate" class="btn btn-primary"><i class="bi bi-plus-lg"></i> New Template</a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No templates defined yet.</div>
}
else
{
    <div class="row g-3">
        @foreach (var template in Model)
        {
            <div class="col-md-6 col-xl-4">
                <div class="card h-100">
                    <div class="card-header d-flex justify-content-between">
                        <strong>@template.Name</strong>
                        <span class="badge bg-primary">@template.EntityType</span>
                        @if (!string.IsNullOrEmpty(template.EntitySubType))
                        {
                            <span class="badge bg-info text-dark ms-1">@template.EntitySubType</span>
                        }
                    </div>
                    <div class="card-body p-0">
                        <div class="d-flex gap-2 flex-wrap px-3 pt-3 pb-2">
                            <span class="badge bg-secondary" style="font-size:10px;">@template.ApprovalMode</span>
                            @if (template.AutoTriggerOn != PCA.Modules.Approvals.Models.AutoTriggerOn.None)
                            {
                                <span class="badge bg-warning text-dark" style="font-size:10px;">⚡ @template.AutoTriggerOn</span>
                            }
                            @if (!string.IsNullOrEmpty(template.ConditionField))
                            {
                                <span class="badge bg-light text-dark border" style="font-size:10px;">If @template.ConditionField = @template.ConditionValue</span>
                            }
                        </div>

                        @{
                            var previewSteps = template.Steps.OrderBy(s => s.Order)
                                .Select(s => new PCA.Modules.Approvals.Models.ApprovalStep
                                {
                                    Order      = s.Order,
                                    RoleName   = s.RoleName,
                                    Approver   = s.Approver,
                                    ApproverId = s.ApproverId,
                                    Status     = PCA.Shared.Enums.ApprovalStatus.Pending
                                }).ToList();
                        }
                        @await Html.PartialAsync("_ApprovalFlowChart", (object)null!, new ViewDataDictionary(ViewData)
                        {
                            ["Steps"]      = previewSteps,
                            ["EntityType"] = template.EntityType,
                            ["EntityId"]   = 0
                        })
                    </div>
                    <div class="card-footer d-flex gap-2">
                        <a asp-action="TemplateDetails" asp-route-id="@template.Id" class="btn btn-sm btn-outline-secondary">
                            <i class="bi bi-eye me-1"></i>Details
                        </a>
                        <a asp-action="EditTemplate" asp-route-id="@template.Id" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-pencil me-1"></i>Edit
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}
