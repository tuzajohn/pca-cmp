@model List<PCA.Modules.Identity.Models.ApplicationUser>
@{
    ViewData["Title"] = "Admin - Users";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-people"></i> Users</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to Templates</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Department</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>@user.FullName</td>
                        <td>@user.Email</td>
                        <td>@user.Department</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
