@model List<UserListItemViewModel>
@{
    ViewData["Title"] = "Users";
    ViewData["Subtitle"] = "Manage system users and role assignments";

    string RoleBadge(string role) => role switch {
        "Admin"     => "background:#fef2f2;color:#b91c1c;",
        "Approver"  => "background:#eff6ff;color:#2563eb;",
        "Requester" => "background:#f0fdf4;color:#15803d;",
        _           => "background:#f3f4f6;color:#6b7280;"
    };
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Users</h1>
        <p class="page-header-sub mb-0">@Model.Count user(s) registered</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="CreateUser" class="btn btn-primary">
            <i class="bi bi-person-plus me-1"></i> Add User
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i> Templates
        </a>
    </div>
</div>

<div class="card">
    @if (!Model.Any())
    {
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-people fs-1 d-block mb-2 opacity-25"></i>
            No users yet. <a asp-action="CreateUser"><i class="bi bi-person-plus me-1"></i>Add the first user</a>
        </div>
    }
    else
    {
        <table class="table mb-0">
            <thead>
                <tr>
                    <th>Full Name</th>
                    <th>Email</th>
                    <th>Department</th>
                    <th>Roles</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>
                            <div class="fw-semibold">@user.FullName</div>
                        </td>
                        <td class="text-muted">@user.Email</td>
                        <td class="text-muted">@(string.IsNullOrEmpty(user.Department) ? "—" : user.Department)</td>
                        <td>
                            <div class="d-flex flex-wrap gap-1">
                                @foreach (var role in user.Roles)
                                {
                                    <span class="status-badge" style="@RoleBadge(role)">@role</span>
                                }
                                @if (!user.Roles.Any())
                                {
                                    <span class="text-muted" style="font-size:12px;">No roles</span>
                                }
                            </div>
                        </td>
                        <td>
                            <div class="d-flex gap-1 justify-content-end">
                                <a asp-action="EditUser" asp-route-id="@user.Id"
                                   class="btn btn-sm btn-outline-primary" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form asp-action="DeleteUser" method="post" class="d-inline"
                                      onsubmit="return confirm('Delete @user.FullName? This cannot be undone.')">
                                    <input type="hidden" name="id" value="@user.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
