@model List<PCA.Web.Models.ApiKey>
@{
    ViewData["Title"] = "API Keys";
    var newKey    = TempData["NewKey"]    as string;
    var newKeyApp = TempData["NewKeyApp"] as string;
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">API Keys</h1>
        <p class="page-header-sub mb-0">Manage keys that allow external applications to write logs.</p>
    </div>
    <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#createModal">
        <i class="bi bi-plus-lg me-1"></i> New API Key
    </button>
</div>

@if (!string.IsNullOrEmpty(newKey))
{
    <div class="alert alert-success border-0 mb-4" style="background:#f0fdf4;">
        <div class="fw-semibold mb-1"><i class="bi bi-key me-2"></i>New key for <strong>@newKeyApp</strong> — copy it now, it will not be shown again.</div>
        <div class="d-flex align-items-center gap-2 mt-2">
            <code id="newKeyDisplay" class="p-2 rounded flex-grow-1"
                  style="background:#dcfce7;font-size:13px;word-break:break-all;">@newKey</code>
            <button class="btn btn-sm btn-outline-success"
                    onclick="navigator.clipboard.writeText('@newKey');this.textContent='Copied!'">
                <i class="bi bi-clipboard me-1"></i>Copy
            </button>
        </div>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="card">
    <div class="card-body p-0">
        <table class="table table-sm mb-0" style="font-size:13px;">
            <thead>
                <tr>
                    <th class="ps-3">Application</th>
                    <th>Key Prefix</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th>Last Used</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var key in Model)
                {
                    <tr>
                        <td class="ps-3 fw-semibold">@key.AppName</td>
                        <td><code>@key.KeyPrefix…</code></td>
                        <td>
                            @if (key.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Revoked</span>
                            }
                        </td>
                        <td class="text-muted">@key.CreatedAt.ToString("dd MMM yyyy")</td>
                        <td class="text-muted">
                            @(key.LastUsedAt.HasValue ? key.LastUsedAt.Value.ToString("dd MMM yyyy HH:mm") : "Never")
                        </td>
                        <td class="text-end pe-3">
                            @if (key.IsActive)
                            {
                                <form asp-action="Revoke" asp-route-id="@key.Id" method="post" class="d-inline"
                                      onsubmit="return confirm('Revoke this key? External apps using it will lose access immediately.')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-slash-circle me-1"></i>Revoke
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="px-3 py-4 text-muted text-center">No API keys yet.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="mt-4 p-3 rounded" style="background:var(--bs-tertiary-bg);font-size:13px;max-width:600px;">
    <div class="fw-semibold mb-2"><i class="bi bi-info-circle me-1"></i>Usage</div>
    <p class="mb-1">Send a <code>POST</code> to <code>/api/logs</code> with the header:</p>
    <code>X-Api-Key: &lt;your-key&gt;</code>
    <p class="mt-2 mb-1">Request body:</p>
<pre class="mb-0" style="font-size:12px;">{
  "message": "Something happened",
  "level":   "Warning",
  "source":  "MyService"
}</pre>
</div>

<!-- Create modal -->
<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title">New API Key</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <label class="form-label">Application Name</label>
                    <input name="appName" class="form-control" placeholder="e.g. BillingService" required />
                    <div class="form-text">Identifies which app is sending logs.</div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary btn-sm">Generate Key</button>
                </div>
            </form>
        </div>
    </div>
</div>
