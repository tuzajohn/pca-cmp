@{
    ViewData["Title"] = "API Keys";
    var newKey    = TempData["NewKey"]    as string;
    var newKeyApp = TempData["NewKeyApp"] as string;
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">API Keys</h1>
        <p class="page-header-sub mb-0">Manage keys that allow external applications to write logs.</p>
    </div>
    <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#createModal">
        <i class="bi bi-plus-lg me-1"></i> New API Key
    </button>
</div>

@if (!string.IsNullOrEmpty(newKey))
{
    <div class="alert alert-success border-0 mb-4" style="background:#f0fdf4;">
        <div class="fw-semibold mb-1"><i class="bi bi-key me-2"></i>New key for <strong>@newKeyApp</strong> — copy it now, it will not be shown again.</div>
        <div class="d-flex align-items-center gap-2 mt-2">
            <code class="p-2 rounded flex-grow-1" style="background:#dcfce7;font-size:13px;word-break:break-all;">@newKey</code>
            <button class="btn btn-sm btn-outline-success"
                    onclick="navigator.clipboard.writeText('@newKey');this.textContent='Copied!'">
                <i class="bi bi-clipboard me-1"></i>Copy
            </button>
        </div>
    </div>
}

@if (TempData["Error"] != null) { <div class="alert alert-danger">@TempData["Error"]</div> }

@Html.AntiForgeryToken()

<div class="card">
    <div id="tbl-apikeys"></div>
</div>

<div class="mt-4 p-3 rounded" style="background:var(--bs-tertiary-bg);font-size:13px;max-width:600px;">
    <div class="fw-semibold mb-2"><i class="bi bi-info-circle me-1"></i>Usage</div>
    <p class="mb-1">Send a <code>POST</code> to <code>/api/logs</code> with the header <code>X-Api-Key: &lt;your-key&gt;</code></p>
<pre class="mb-0" style="font-size:12px;">{ "message": "Something happened", "level": "Warning", "source": "MyService" }</pre>
</div>

<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title">New API Key</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <label class="form-label">Application Name</label>
                    <input name="appName" class="form-control" placeholder="e.g. BillingService" required />
                    <div class="form-text">Identifies which app is sending logs.</div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary btn-sm">Generate Key</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    const csrf = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
    PagedTable.init({
        tableId: 'tbl-apikeys',
        tableClass: 'table table-sm mb-0',
        url: '/ApiKeys/IndexData',
        pageSize: 25,
        defaultSort: { col: 'createdAt', dir: 'desc' },
        columns: [
            { key: 'appName',   label: 'Application', thClass: 'ps-3', tdClass: 'ps-3 align-middle fw-semibold' },
            { key: 'prefix',    label: 'Key Prefix',  tdClass: 'align-middle', render: r => `<code>${r.prefix}…</code>` },
            { key: 'isActive',  label: 'Status',      tdClass: 'align-middle', render: r => r.isActive ? '<span class="badge bg-success">Active</span>' : '<span class="badge bg-secondary">Revoked</span>' },
            { key: 'createdAt', label: 'Created',     tdClass: 'align-middle text-muted' },
            { key: 'lastUsed',  label: 'Last Used',   tdClass: 'align-middle text-muted', render: r => r.lastUsed || 'Never' },
            { key: null, label: '', sortable: false, thClass: 'pe-3', tdClass: 'pe-3 align-middle text-end',
              render: r => r.isActive
                ? `<button class="btn btn-sm btn-outline-danger" onclick="if(confirm('Revoke this key?')){const f=document.createElement('form');f.method='post';f.action='/ApiKeys/Revoke/${r.id}';const t=document.createElement('input');t.type='hidden';t.name='__RequestVerificationToken';t.value='${csrf}';f.appendChild(t);document.body.appendChild(f);f.submit();}"><i class="bi bi-slash-circle me-1"></i>Revoke</button>`
                : '' }
        ]
    });
})();
</script>
}
