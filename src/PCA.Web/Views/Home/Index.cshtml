@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<h2 class="mb-4"><i class="bi bi-speedometer2"></i> Dashboard</h2>

<div class="row g-3 mb-4">
    @{
        var statuses = new[] {
            (PCA.Shared.Enums.ChangeStatus.Draft, "secondary", "bi-file-earmark"),
            (PCA.Shared.Enums.ChangeStatus.Submitted, "primary", "bi-send"),
            (PCA.Shared.Enums.ChangeStatus.UnderReview, "info", "bi-search"),
            (PCA.Shared.Enums.ChangeStatus.Approved, "success", "bi-check-circle"),
            (PCA.Shared.Enums.ChangeStatus.Rejected, "danger", "bi-x-circle"),
            (PCA.Shared.Enums.ChangeStatus.Implemented, "warning", "bi-gear"),
            (PCA.Shared.Enums.ChangeStatus.Closed, "dark", "bi-archive"),
        };
    }
    @foreach (var (status, color, icon) in statuses)
    {
        var count = Model.StatusCounts.TryGetValue(status, out var c) ? c : 0;
        <div class="col-6 col-md-3">
            <div class="card border-@color h-100">
                <div class="card-body text-center">
                    <i class="bi @icon fs-2 text-@color"></i>
                    <h3 class="mt-1 mb-0">@count</h3>
                    <small class="text-muted">@status</small>
                </div>
            </div>
        </div>
    }
    <div class="col-6 col-md-3">
        <div class="card border-dark h-100 bg-dark text-white">
            <div class="card-body text-center">
                <i class="bi bi-stack fs-2"></i>
                <h3 class="mt-1 mb-0">@Model.TotalChangeRequests</h3>
                <small>Total</small>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <strong><i class="bi bi-clock-history"></i> Recent Change Requests</strong>
                <a asp-controller="ChangeRequests" asp-action="Create" class="btn btn-sm btn-primary">
                    <i class="bi bi-plus"></i> New CR
                </a>
            </div>
            <div class="card-body p-0">
                @if (!Model.RecentChangeRequests.Any())
                {
                    <p class="text-muted p-3 mb-0">No change requests yet.</p>
                }
                else
                {
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Serial #</th>
                                <th>Title</th>
                                <th>Status</th>
                                <th>Priority</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var cr in Model.RecentChangeRequests)
                            {
                                <tr>
                                    <td><a asp-controller="ChangeRequests" asp-action="Details" asp-route-id="@cr.Id">@(string.IsNullOrEmpty(cr.SerialNumber) ? $"#{cr.Id}" : cr.SerialNumber)</a></td>
                                    <td>@cr.Title</td>
                                    <td><span class="badge bg-secondary">@cr.Status</span></td>
                                    <td><span class="badge bg-@(cr.Priority == Priority.Critical ? "danger" : cr.Priority == Priority.High ? "warning" : "light text-dark")">@cr.Priority</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card">
            <div class="card-header">
                <strong><i class="bi bi-bell"></i> My Pending Approvals</strong>
            </div>
            <div class="card-body p-0">
                @if (!Model.PendingApprovals.Any())
                {
                    <p class="text-muted p-3 mb-0">No pending approvals.</p>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var step in Model.PendingApprovals)
                        {
                            <li class="list-group-item">
                                <a asp-controller="ChangeRequests" asp-action="Details" asp-route-id="@step.ChangeRequestId">
                                    CR #@step.ChangeRequestId &ndash; Step @step.Order
                                </a>
                                <span class="badge bg-warning float-end">Pending</span>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>
