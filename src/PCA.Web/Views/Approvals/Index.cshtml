@model List<PCA.Modules.Approvals.Models.ApprovalStep>
@{
    ViewData["Title"] = "Approvals";
    var labels = ViewBag.Labels as Dictionary<(string, int), string> ?? new();
    string GetLabel(string entityType, int entityId)
        => labels.TryGetValue((entityType, entityId), out var l) ? l : $"{entityType} #{entityId}";

    var grouped = Model.GroupBy(s => s.EntityType).ToList();
}

<div class="page-header">
    <h1 class="page-header-title">Approval Queue</h1>
</div>

@if (!Model.Any())
{
    <div class="card">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-check-all fs-1 d-block mb-2 opacity-25"></i>
            <strong>All caught up!</strong> No items currently need your approval.
        </div>
    </div>
}
else
{
    @foreach (var group in grouped)
    {
        <h5 class="mb-2 mt-3" style="font-size:13px;font-weight:600;text-transform:uppercase;letter-spacing:.05em;color:var(--color-primary);">
            @group.Key
        </h5>
        <div class="card mb-4">
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th>Item</th>
                        <th>Step</th>
                        <th>Role</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var step in group)
                    {
                        <tr>
                            <td>
                                <span class="fw-semibold" style="font-size:13px;">@GetLabel(step.EntityType, step.EntityId)</span>
                            </td>
                            <td class="text-muted" style="font-size:12px;">Step @step.Order</td>
                            <td class="text-muted" style="font-size:12px;">@step.RoleName</td>
                            <td>
                                @{
                                    var ctrl = group.Key switch {
                                        "Incident" => "Incidents",
                                        "Document" => "Documents",
                                        _ => "ChangeRequests"
                                    };
                                }
                                <a asp-controller="@ctrl" asp-action="Details" asp-route-id="@step.EntityId"
                                   class="btn btn-sm btn-primary">
                                    <i class="bi bi-eye me-1"></i> Review
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

