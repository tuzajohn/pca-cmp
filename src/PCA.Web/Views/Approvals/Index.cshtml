@model List<PCA.Modules.ChangeManagement.Models.ChangeRequest>
@using PCA.Modules.Approvals.Models
@using PCA.Shared.Enums
@{
    ViewData["Title"] = "Approvals";
    string StatusCls(ChangeStatus st) => st switch {
        ChangeStatus.UnderReview => "status-underreview",
        ChangeStatus.Approved => "status-approved",
        ChangeStatus.Rejected => "status-rejected",
        _ => "status-submitted"
    };
}

<div class="page-header">
    <h1 class="page-header-title">Approval Queue</h1>
</div>

@if (!Model.Any())
{
    <div class="card">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-check-all fs-1 d-block mb-2 opacity-25"></i>
            <strong>All caught up!</strong> No change requests currently need your approval.
        </div>
    </div>
}
else
{
    <div class="card">
        <table class="table mb-0">
            <thead>
                <tr>
                    <th>Serial #</th>
                    <th>Title</th>
                    <th>Type</th>
                    <th>Status</th>
                    <th>Requested By</th>
                    <th>Target Date</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cr in Model)
                {
                    <tr>
                        <td>
                            <a asp-controller="ChangeRequests" asp-action="Details" asp-route-id="@cr.Id"
                               class="fw-semibold" style="color:var(--color-primary);">
                                @(string.IsNullOrEmpty(cr.SerialNumber) ? $"#{cr.Id}" : cr.SerialNumber)
                            </a>
                        </td>
                        <td>@cr.Title</td>
                        <td><span class="status-badge status-submitted">@cr.Type</span></td>
                        <td><span class="status-badge @StatusCls(cr.Status)">@cr.Status</span></td>
                        <td class="text-muted">@(cr.RequestedBy?.FullName ?? cr.RequestedBy?.UserName ?? "—")</td>
                        <td class="text-muted" style="font-size:12px;">@(cr.TargetDate?.ToString("dd MMM yyyy") ?? "—")</td>
                        <td>
                            <a asp-controller="ChangeRequests" asp-action="Details" asp-route-id="@cr.Id"
                               class="btn btn-sm btn-primary">
                                <i class="bi bi-eye me-1"></i> Review
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
