@model PCA.Web.Models.IncidentEditViewModel
@using PCA.Shared.Enums
@{
    ViewData["Title"] = "Edit Incident";
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Edit Incident</h1>
    </div>
    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i> Back
    </a>
</div>

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <div class="row g-3">
        <div class="col-lg-8">
            <div class="form-section">
                <div class="form-section-header"><i class="bi bi-pencil"></i> Incident Details</div>
                <div class="form-section-body">
                    <div class="mb-3">
                        <label asp-for="Title" class="form-label fw-semibold">Title <span class="text-danger">*</span></label>
                        <input asp-for="Title" class="form-control" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-semibold">Description <span class="text-danger">*</span></label>
                        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="Category" class="form-label fw-semibold">Category</label>
                            <select asp-for="Category" class="form-select" asp-items="Html.GetEnumSelectList<IncidentCategory>()"></select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Severity" class="form-label fw-semibold">Severity</label>
                            <select asp-for="Severity" class="form-select" asp-items="Html.GetEnumSelectList<IncidentSeverity>()"></select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Priority" class="form-label fw-semibold">Priority</label>
                            <select asp-for="Priority" class="form-select" asp-items="Html.GetEnumSelectList<Priority>()"></select>
                        </div>
                    </div>
                    <div class="row g-3 mt-1">
                        <div class="col-md-6">
                            <label asp-for="DetectedAt" class="form-label fw-semibold">Detected At</label>
                            <input asp-for="DetectedAt" type="datetime-local" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="LinkedChangeRequestId" class="form-label fw-semibold">Linked CR ID</label>
                            <input asp-for="LinkedChangeRequestId" type="number" class="form-control" placeholder="Optional" />
                        </div>
                    </div>
                    <div class="mt-3">
                        <label asp-for="AffectedSystems" class="form-label fw-semibold">Affected Systems</label>
                        <input asp-for="AffectedSystems" class="form-control" />
                    </div>
                    <div class="mt-3">
                        <label asp-for="ImpactDescription" class="form-label fw-semibold">Impact Description</label>
                        <textarea asp-for="ImpactDescription" class="form-control" rows="3"></textarea>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card position-sticky" style="top:80px;">
                <div class="card-footer">
                    <button type="submit" class="btn btn-primary w-100">Save Changes</button>
                </div>
            </div>
        </div>
    </div>
</form>
