@using PCA.Shared.Enums
@using PCA.Web.Helpers
@{
    ViewData["Title"] = "Incidents";
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Incidents</h1>
        <p class="page-header-sub mb-0">Track and manage operational incidents</p>
    </div>
    <a asp-action="Create" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg me-1"></i> Report Incident
    </a>
</div>

<div class="card mb-3">
    <div class="card-body py-2">
        <div class="d-flex flex-wrap gap-2 align-items-center">
            <select id="f-status" class="form-select form-select-sm" style="width:auto;">
                <option value="">All Statuses</option>
                @foreach (var s in Enum.GetValues<IncidentStatus>())
                {
                    <option value="@s">@s</option>
                }
            </select>
            <select id="f-severity" class="form-select form-select-sm" style="width:auto;">
                <option value="">All Severities</option>
                @foreach (var sv in Enum.GetValues<IncidentSeverity>())
                {
                    <option value="@sv">@IncidentViewHelpers.SeverityLabel(sv)</option>
                }
            </select>
            <select id="f-category" class="form-select form-select-sm" style="width:auto;">
                <option value="">All Categories</option>
                @foreach (var cat in Enum.GetValues<IncidentCategory>())
                {
                    <option value="@cat">@cat</option>
                }
            </select>
            <button class="btn btn-primary btn-sm" id="btn-filter">Filter</button>
            <button class="btn btn-outline-secondary btn-sm" id="btn-clear">Clear</button>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <table id="tbl-inc" class="table mb-0" style="font-size:13px;">
            <thead style="background:var(--bs-tertiary-bg);"></thead>
            <tbody></tbody>
        </table>
    </div>
    <div class="card-footer py-2" id="tbl-inc-pagination"></div>
</div>

@section Scripts {
<script>
(function () {
    const badge = d => `<span class="status-badge status-${d.toLowerCase()}">${d}</span>`;

    const tbl = PagedTable.init({
        tableId: 'tbl-inc',
        url: '/Incidents/Data',
        pageSize: 25,
        defaultSort: { col: 'detected', dir: 'desc' },
        filters: () => ({
            status:   document.getElementById('f-status').value,
            severity: document.getElementById('f-severity').value,
            category: document.getElementById('f-category').value
        }),
        paginationId: 'tbl-inc-pagination',
        columns: [
            { key: 'serial',     label: 'Serial',      thClass: 'ps-3', tdClass: 'ps-3 align-middle', render: r => `<a href="/Incidents/Details/${r.id}" class="fw-semibold text-decoration-none">${r.serial}</a>` },
            { key: 'title',      label: 'Title',       tdClass: 'align-middle' },
            { key: 'category',   label: 'Category',    tdClass: 'align-middle', render: r => badge(r.category) },
            { key: 'severity',   label: 'Severity',    tdClass: 'align-middle', render: r => badge(r.severity) },
            { key: 'priority',   label: 'Priority',    tdClass: 'align-middle', render: r => badge(r.priority) },
            { key: 'status',     label: 'Status',      tdClass: 'align-middle', render: r => badge(r.status) },
            { key: 'assignedTo', label: 'Assigned To', tdClass: 'align-middle text-muted', render: r => r.assignedTo || '<span class="text-muted">Unassigned</span>' },
            { key: 'detected',   label: 'Detected',    tdClass: 'align-middle text-muted' },
            { key: null, label: '', sortable: false, thClass: 'pe-3', tdClass: 'pe-3 align-middle text-end',
              render: r => `<a href="/Incidents/Details/${r.id}" class="btn btn-sm btn-outline-secondary" style="padding:2px 8px;"><i class="bi bi-eye"></i></a>` }
        ]
    });

    document.getElementById('btn-filter').addEventListener('click', () => tbl.reload());
    document.getElementById('btn-clear').addEventListener('click', () => {
        ['f-status', 'f-severity', 'f-category'].forEach(id => document.getElementById(id).value = '');
        tbl.reload();
    });
})();
</script>
}
